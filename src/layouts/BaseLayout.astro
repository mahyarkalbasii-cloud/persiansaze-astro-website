---
import SiteFooter from "@/components/SiteFooter.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import PersianDigitsScript from "@/components/PersianDigitsScript.astro";
import { site } from "@/content/home";
import "../styles/global.css";

type Props = {
  title: string;
  description: string;
  canonicalPath?: string;
  structuredData?: unknown | unknown[];
  noindex?: boolean;
};

const { title, description, canonicalPath = "/", structuredData, noindex = false } = Astro.props;
const canonicalUrl = new URL(canonicalPath, site.url).toString();
const ogImageUrl = new URL("/assets/og/persiansaze-og.png", site.url).toString();
const ogImageAlt = "پرشین‌سازه؛ پروژه‌های ساختمانی فعال را زودتر پیدا کنید";
const schemaItems = structuredData ? (Array.isArray(structuredData) ? structuredData : [structuredData]) : [];
---

<!doctype html>
<html lang="fa-IR" dir="rtl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preload" href="/fonts/estedad-arabic-400.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/estedad-arabic-700.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/estedad-arabic-800.woff2" as="font" type="font/woff2" crossorigin />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta
      name="robots"
      content={noindex ? "noindex, follow" : "index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"}
    />
    {!noindex && <link rel="canonical" href={canonicalUrl} />}
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="fa_IR" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={ogImageAlt} />
    {schemaItems.map((schema) => (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}
  </head>
  <body>
    <SiteHeader />
    <slot />
    <SiteFooter />
    <PersianDigitsScript />
  </body>
</html>
