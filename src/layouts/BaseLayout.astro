---
import SiteFooter from "@/components/SiteFooter.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import PersianDigitsScript from "@/components/PersianDigitsScript.astro";
import { site } from "@/content/home";
import "../styles/global.css";

type Props = {
  title: string;
  description: string;
  canonicalPath?: string;
  canonicalURL?: string;
  ogImage?: string;
  structuredData?: unknown | unknown[];
  noindex?: boolean;
  homeHeader?: boolean;
  bodyClass?: string;
};

const {
  title,
  description,
  ogImage = "/assets/company/og-home.jpg",
  structuredData,
  noindex = false,
  homeHeader = false,
  bodyClass = "home-color-anthropic",
} = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();
const canonicalOrigin = new URL(canonicalURL).origin;
const ogImageUrl = new URL(ogImage, canonicalOrigin).href;
const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "@id": `${site.url}/#organization`,
  name: "PersianSaze",
  legalName: site.legalName,
  alternateName: [site.name, site.alternateName],
  url: site.url,
  description:
    "PersianSaze is a B2B SaaS and construction data intelligence platform for suppliers selling to active construction projects.",
  industry: "Construction intelligence",
  areaServed: ["Tehran", "Karaj", "Lavasan"],
  serviceArea: ["Tehran", "Karaj", "Lavasan"].map((name) => ({
    "@type": "City",
    name,
  })),
  sameAs: site.sameAs,
  contactPoint: site.contacts.map((contact) => ({
    "@type": "ContactPoint",
    name: contact.label,
    telephone: contact.telephone,
    contactType: contact.contactType,
    areaServed: "IR",
    availableLanguage: ["fa-IR", "Persian"],
  })),
};
const propSchemaItems = structuredData ? (Array.isArray(structuredData) ? structuredData : [structuredData]) : [];
const hasOrganizationSchema = propSchemaItems.some((schema) => {
  if (!schema || typeof schema !== "object") return false;
  const schemaType = (schema as Record<string, unknown>)["@type"];
  return schemaType === "Organization" || (Array.isArray(schemaType) && schemaType.includes("Organization"));
});
const schemaItems = hasOrganizationSchema ? propSchemaItems : [organizationSchema, ...propSchemaItems];
const cfBeaconToken = import.meta.env.PUBLIC_CF_BEACON_TOKEN;
---

<!doctype html>
<html lang="fa-IR" dir="rtl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta
      name="robots"
      content={noindex ? "noindex, nofollow" : "index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"}
    />
    {!noindex && <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site)} />}
    <link rel="preload" href="/fonts/estedad-arabic-400.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/estedad-arabic-600.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="64x64" href="/favicon-64.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="fa_IR" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="پرشین‌سازه - زیرساخت فروش پروژه‌محور" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {schemaItems.map((schema) => (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}
  </head>
  <body class={bodyClass}>
    <SiteHeader home={homeHeader} />
    <slot />
    <SiteFooter />
    <PersianDigitsScript />
    {cfBeaconToken && (
      <script
        is:inline
        defer
        src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon={JSON.stringify({ token: cfBeaconToken })}
      />
    )}
  </body>
</html>
