---
import { coverageMenuLinks } from "@/content/coverageAreas";
---

<div class="nav-mega">
  <button class="nav-mega-trigger" type="button" aria-haspopup="true" aria-expanded="false">
    مناطق تحت پوشش
  </button>
  <div class="nav-mega-panel" role="group" aria-label="مناطق تحت پوشش پرشین‌سازه">
    <a class="nav-mega-featured" href="/projects/">
      <span>هاب مناطق</span>
      <strong>همه شهرها و محله‌های فعال</strong>
      <small>نقشه HTML داخلی برای خزش گوگل و انتخاب بازار هدف فروش B2B</small>
    </a>
    <div class="nav-mega-links">
      {coverageMenuLinks.map((link) => (
        <a href={link.href}>
          <span>{link.cityName}</span>
          <strong>{link.label}</strong>
        </a>
      ))}
    </div>
  </div>
</div>
