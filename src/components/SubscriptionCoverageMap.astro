---
import coverageMapImage from "@/assets/images/subscriptions/subscription-coverage-map.png";
import { Image } from "astro:assets";

type Props = {
  planCount: string;
  neighborhoodCount: string;
};

const { planCount, neighborhoodCount } = Astro.props as Props;
const pins = [
  [1198, 503, 0],
  [971, 529, 0.35],
  [1374, 452, 0.7],
  [1230, 662, 1.05],
  [979, 679, 1.4],
  [1140, 278, 1.75],
  [1452, 603, 2.1],
];
const planMeters = [
  { label: "بنیان", level: "پایه", width: "32%" },
  { label: "رویان", level: "رشد", width: "56%" },
  { label: "تابان", level: "اصلی", width: "78%" },
  { label: "تابان پلاس", level: "کامل", width: "100%" },
];
---

<div class="scm-stage" aria-label="نمای پوشش اشتراک‌های پرشین‌سازه روی نقشه پروژه‌ها">
  <Image
    src={coverageMapImage}
    alt="نمای تصویری پوشش اشتراک‌های پرشین‌سازه روی نقشه پروژه‌های ساختمانی و سطح دسترسی پلن‌ها"
    width="1792"
    height="1024"
    loading="eager"
    fetchpriority="high"
    decoding="async"
  />

  <svg class="scm-fx" viewBox="0 0 1792 1024" preserveAspectRatio="xMidYMid slice" aria-hidden="true" focusable="false">
    <defs>
      <radialGradient id="scm-hotspot" cx="50%" cy="50%" r="50%">
        <stop offset="0%" stop-color="#fff1dc" stop-opacity="0.95" />
        <stop offset="38%" stop-color="#f08a48" stop-opacity="0.48" />
        <stop offset="100%" stop-color="#f08a48" stop-opacity="0" />
      </radialGradient>
      <filter id="scm-soft-glow" x="-80%" y="-80%" width="260%" height="260%">
        <feGaussianBlur stdDeviation="9" />
      </filter>
    </defs>
    <ellipse class="scm-core-bloom" cx="1198" cy="503" rx="155" ry="155" fill="url(#scm-hotspot)" />
    <ellipse class="scm-orbit scm-orbit-outer" cx="1197" cy="513" rx="455" ry="320" />
    <ellipse class="scm-orbit scm-orbit-mid" cx="1192" cy="515" rx="310" ry="218" />
    <ellipse class="scm-orbit scm-orbit-inner" cx="1196" cy="512" rx="170" ry="120" />
    <path class="scm-route-glow" d="M 500 896 L 786 896 L 1052 897 L 1248 897 L 1478 895" pathLength="1000" />
    <path class="scm-route-core" d="M 500 896 L 786 896 L 1052 897 L 1248 897 L 1478 895" pathLength="1000" />
    {pins.map(([x, y, delay]) => (
      <g style={`--delay: ${delay}s`}>
        <circle class="scm-pin-bloom" cx={x} cy={y} r="34" filter="url(#scm-soft-glow)" />
        <circle class="scm-pin-ring" cx={x} cy={y} r="21" />
      </g>
    ))}
  </svg>

  <div class="scm-readout" aria-hidden="true">
    <span>اشتراک‌ها</span>
    <strong>{planCount} پلن</strong>
    <small>{neighborhoodCount} محدوده پروژه‌محور در ۳ شهر</small>
  </div>

  <div class="scm-plan-stack" aria-hidden="true">
    {planMeters.map((plan) => (
      <div class="scm-plan-row">
        <span>{plan.label}</span>
        <i><b style={`inline-size: ${plan.width}`}></b></i>
        <small>{plan.level}</small>
      </div>
    ))}
  </div>
</div>

<style>
  .scm-stage {
    position: relative;
    overflow: hidden;
    inline-size: 100%;
    block-size: 100%;
    aspect-ratio: 1672 / 941;
    background: #11100f;
    isolation: isolate;
  }

  .scm-stage img {
    display: block;
    inline-size: 100%;
    block-size: 100%;
    object-fit: cover;
  }

  .scm-fx {
    position: absolute;
    inset: 0;
    z-index: 1;
    inline-size: 100%;
    block-size: 100%;
    mix-blend-mode: screen;
    pointer-events: none;
  }

  .scm-core-bloom {
    opacity: 0.58;
    transform-box: fill-box;
    transform-origin: center;
    animation: scm-core 5.6s ease-in-out infinite;
  }

  .scm-orbit {
    fill: none;
    stroke: #f08a48;
    stroke-linecap: round;
    opacity: 0.5;
    transform-box: fill-box;
    transform-origin: center;
    animation: scm-orbit 6.8s ease-in-out infinite;
  }

  .scm-orbit-outer {
    stroke-width: 2.2;
  }

  .scm-orbit-mid {
    stroke-width: 2.6;
    animation-delay: 0.35s;
  }

  .scm-orbit-inner {
    stroke-width: 3;
    animation-delay: 0.7s;
  }

  .scm-route-glow,
  .scm-route-core {
    fill: none;
    stroke-linecap: round;
    stroke-dasharray: 90 1000;
    animation: scm-route 8.8s linear infinite;
  }

  .scm-route-glow {
    stroke: #ffad6f;
    stroke-width: 13;
    opacity: 0.38;
    filter: blur(7px);
  }

  .scm-route-core {
    stroke: #ffe4c0;
    stroke-width: 3;
    opacity: 0.78;
  }

  .scm-pin-bloom {
    fill: #f08a48;
    opacity: 0;
    transform-box: fill-box;
    transform-origin: center;
    animation: scm-pin-bloom 6.4s ease-out infinite;
    animation-delay: var(--delay);
  }

  .scm-pin-ring {
    fill: none;
    stroke: #ffe4c0;
    stroke-width: 4;
    opacity: 0;
    transform-box: fill-box;
    transform-origin: center;
    animation: scm-pin-ring 6.4s ease-out infinite;
    animation-delay: var(--delay);
  }

  .scm-readout,
  .scm-plan-stack {
    position: absolute;
    z-index: 2;
    border: 1px solid rgb(255 196 138 / 18%);
    background: rgb(18 15 12 / 66%);
    color: #f9efe4;
    box-shadow:
      inset 0 1px 0 rgb(255 255 255 / 8%),
      0 1rem 2rem -1.5rem rgb(0 0 0 / 62%);
    backdrop-filter: blur(12px) saturate(1.1);
    -webkit-backdrop-filter: blur(12px) saturate(1.1);
  }

  .scm-readout {
    inset-block-start: clamp(0.75rem, 2vw, 1.25rem);
    inset-inline-end: clamp(0.75rem, 2vw, 1.25rem);
    display: grid;
    gap: 0.15rem;
    border-radius: 0.85rem;
    padding: 0.78rem 0.95rem;
    text-align: right;
  }

  .scm-readout span,
  .scm-readout small,
  .scm-plan-row small {
    color: rgb(249 239 228 / 68%);
    font-size: 0.72rem;
    font-weight: 750;
  }

  .scm-readout strong {
    color: #fff6ea;
    font-size: clamp(1.05rem, 1.8vw, 1.45rem);
    font-weight: 900;
    line-height: 1.1;
  }

  .scm-plan-stack {
    inset-block-end: clamp(0.75rem, 2vw, 1rem);
    inset-inline-start: clamp(0.75rem, 2vw, 1rem);
    display: grid;
    gap: 0.5rem;
    inline-size: min(17rem, calc(100% - 1.5rem));
    border-radius: 0.95rem;
    padding: 0.85rem;
  }

  .scm-plan-row {
    display: grid;
    grid-template-columns: 4.2rem minmax(0, 1fr) 2.75rem;
    align-items: center;
    gap: 0.55rem;
    font-size: 0.74rem;
    font-weight: 850;
  }

  .scm-plan-row span {
    color: #fff6ea;
  }

  .scm-plan-row i {
    overflow: hidden;
    block-size: 0.44rem;
    border: 1px solid rgb(255 196 138 / 16%);
    border-radius: 999px;
    background: rgb(255 255 255 / 8%);
  }

  .scm-plan-row b {
    display: block;
    block-size: 100%;
    border-radius: inherit;
    background: linear-gradient(90deg, #d77943, #ffd2a4);
    box-shadow: 0 0 1rem rgb(240 138 72 / 46%);
  }

  @keyframes scm-core {
    0%,
    100% {
      opacity: 0.44;
      transform: scale(0.92);
    }

    50% {
      opacity: 0.72;
      transform: scale(1.06);
    }
  }

  @keyframes scm-orbit {
    0%,
    100% {
      opacity: 0.28;
      transform: scale(0.99);
    }

    50% {
      opacity: 0.58;
      transform: scale(1.012);
    }
  }

  @keyframes scm-route {
    0% {
      stroke-dashoffset: 1090;
      opacity: 0;
    }

    8% {
      opacity: 1;
    }

    58% {
      stroke-dashoffset: -90;
      opacity: 1;
    }

    70%,
    100% {
      stroke-dashoffset: -90;
      opacity: 0;
    }
  }

  @keyframes scm-pin-bloom {
    0% {
      opacity: 0;
      transform: scale(0.5);
    }

    7% {
      opacity: 0.42;
      transform: scale(1);
    }

    18%,
    100% {
      opacity: 0;
      transform: scale(1.45);
    }
  }

  @keyframes scm-pin-ring {
    0% {
      opacity: 0;
      transform: scale(0.45);
    }

    6% {
      opacity: 0.95;
      transform: scale(0.8);
    }

    17%,
    100% {
      opacity: 0;
      transform: scale(1.95);
    }
  }

  @media (max-width: 767px) {
    .scm-stage img {
      object-position: 58% 50%;
    }

    .scm-fx {
      transform: scale(1.08);
      transform-origin: 58% 50%;
    }

    .scm-plan-stack {
      display: none;
    }

    .scm-readout {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .scm-fx {
      display: none;
    }
  }
</style>
