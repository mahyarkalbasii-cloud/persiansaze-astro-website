---
import coverageMapImage from "@/assets/images/subscriptions/subscription-coverage-map.png";
import { Image } from "astro:assets";
---

<div class="scm-stage" aria-label="نمای پوشش اشتراک‌های پرشین‌سازه روی نقشه پروژه‌ها">
  <Image
    src={coverageMapImage}
    alt="نمای تصویری پوشش اشتراک‌های پرشین‌سازه روی نقشه پروژه‌های ساختمانی و سطح دسترسی پلن‌ها"
    width="1792"
    height="1024"
    loading="eager"
    fetchpriority="high"
    decoding="async"
  />
</div>

<style>
  .scm-stage {
    position: relative;
    overflow: hidden;
    inline-size: 100%;
    block-size: 100%;
    aspect-ratio: 1672 / 941;
    background: #11100f;
    isolation: isolate;
  }

  .scm-stage img {
    display: block;
    inline-size: 100%;
    block-size: 100%;
    object-fit: cover;
    object-position: 50% 50%;
  }

  @media (max-width: 767px) {
    .scm-stage img {
      object-position: 62% 50%;
    }
  }
</style>
