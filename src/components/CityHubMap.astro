---
import cityHubDesktopImage from "@/assets/images/cities/city-hub-map-desktop.webp";
import cityHubMobileImage from "@/assets/images/cities/city-hub-map-mobile.webp";
import { Image } from "astro:assets";

const beacons = [
  { desktop: [53.5, 55.7], mobile: [61.6, 66.5], delay: "0s" },
  { desktop: [13.5, 43.8], mobile: [18.8, 44.9], delay: "1.35s" },
  { desktop: [83.7, 17.1], mobile: [81.8, 21.5], delay: "2.7s" },
  { desktop: [35.8, 48.8], mobile: [43.3, 55.3], delay: "4.05s" },
  { desktop: [66.2, 45.7], mobile: [67.4, 38.6], delay: "5.4s" },
];
---

<div class="city-hub-map" aria-label="نقشه پوشش شهری پرشین‌سازه در تهران، کرج و لواسان">
  <Image
    class="city-hub-map-image city-hub-map-image-desktop"
    src={cityHubDesktopImage}
    alt="نقشه تیره پوشش شهرهای تهران، کرج و لواسان با مسیرهای متصل و پین‌های پروژه"
    width="1586"
    height="992"
    loading="eager"
    fetchpriority="high"
    decoding="async"
  />
  <Image
    class="city-hub-map-image city-hub-map-image-mobile"
    src={cityHubMobileImage}
    alt="نقشه عمودی پوشش شهرهای تهران، کرج و لواسان با مسیرهای متصل و پین‌های پروژه"
    width="887"
    height="1774"
    loading="eager"
    fetchpriority="high"
    decoding="async"
  />
  <div class="city-hub-beacon-layer" aria-hidden="true">
    {beacons.map((beacon) => (
      <span
        class="city-hub-beacon"
        style={`--x-desktop: ${beacon.desktop[0]}%; --y-desktop: ${beacon.desktop[1]}%; --x-mobile: ${beacon.mobile[0]}%; --y-mobile: ${beacon.mobile[1]}%; --delay: ${beacon.delay}`}
      ></span>
    ))}
  </div>
</div>

<style>
  .city-hub-map {
    position: relative;
    overflow: hidden;
    inline-size: 100%;
    aspect-ratio: 1672 / 941;
    border: 1px solid rgb(255 176 112 / 16%);
    border-radius: 1.125rem;
    background: #0f0e0d;
    box-shadow:
      0 1.35rem 3.4rem -2.35rem rgb(19 17 15 / 58%),
      inset 0 1px 0 rgb(255 255 255 / 7%);
    isolation: isolate;
  }

  .city-hub-map::after {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 58% 56%, rgb(255 135 66 / 16%), transparent 28%),
      linear-gradient(180deg, transparent 62%, rgb(0 0 0 / 18%));
    content: "";
    pointer-events: none;
    z-index: 1;
  }

  .city-hub-map :global(.city-hub-map-image) {
    display: block;
    position: absolute;
    inset: 0;
    inline-size: 100%;
    block-size: 100%;
    object-fit: cover;
    object-position: center;
  }

  .city-hub-map :global(.city-hub-map-image-mobile) {
    display: none;
  }

  .city-hub-beacon-layer {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
  }

  .city-hub-beacon {
    position: absolute;
    left: var(--x-desktop);
    top: var(--y-desktop);
    inline-size: clamp(1rem, 1.7vw, 1.8rem);
    block-size: clamp(1rem, 1.7vw, 1.8rem);
    border-radius: 999px;
    transform: translate(-50%, -50%);
  }

  .city-hub-beacon::before,
  .city-hub-beacon::after {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    content: "";
    opacity: 0;
    transform: scale(0.42);
    transform-origin: center;
    animation: city-hub-beacon 7.8s ease-out infinite;
    animation-delay: var(--delay);
  }

  .city-hub-beacon::before {
    border: 2px solid rgb(255 218 178 / 88%);
    box-shadow:
      0 0 0.8rem rgb(255 143 69 / 54%),
      inset 0 0 0.36rem rgb(255 230 201 / 56%);
    mix-blend-mode: screen;
  }

  .city-hub-beacon::after {
    inset: 40%;
    background: #ffe1ba;
    box-shadow: 0 0 1rem rgb(255 151 75 / 78%);
    animation-name: city-hub-beacon-core;
  }

  @keyframes city-hub-beacon {
    0% {
      opacity: 0;
      transform: scale(0.42);
    }

    4% {
      opacity: 0.92;
      transform: scale(0.72);
    }

    14%,
    100% {
      opacity: 0;
      transform: scale(2.05);
    }
  }

  @keyframes city-hub-beacon-core {
    0% {
      opacity: 0;
      transform: scale(0.68);
    }

    4% {
      opacity: 0.88;
      transform: scale(1);
    }

    12%,
    100% {
      opacity: 0;
      transform: scale(1.22);
    }
  }

  @media (max-width: 767px) {
    .city-hub-map {
      aspect-ratio: 941 / 1250;
      border-radius: 1rem;
    }

    .city-hub-map::after {
      background:
        radial-gradient(circle at 55% 48%, rgb(255 135 66 / 14%), transparent 24%),
        linear-gradient(180deg, transparent 68%, rgb(0 0 0 / 16%));
    }

    .city-hub-map :global(.city-hub-map-image-desktop) {
      display: none;
    }

    .city-hub-map :global(.city-hub-map-image-mobile) {
      display: block;
    }

    .city-hub-beacon {
      left: var(--x-mobile);
      top: var(--y-mobile);
      inline-size: clamp(0.95rem, 4.8vw, 1.35rem);
      block-size: clamp(0.95rem, 4.8vw, 1.35rem);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .city-hub-beacon-layer {
      display: none;
    }
  }
</style>
