---
// دکمه تغییر تم روشن/تاریک — انتخاب کاربر در localStorage ذخیره می‌شود
// و در نبود انتخاب، از prefers-color-scheme سیستم پیروی می‌کند.
---

<button
  class="theme-toggle"
  type="button"
  aria-label="تغییر به حالت تاریک"
  data-theme-toggle
>
  <span class="theme-toggle-track" aria-hidden="true">
    <svg class="theme-toggle-icon icon-sun" viewBox="0 0 24 24" focusable="false">
      <circle cx="12" cy="12" r="4.4" />
      <path d="M12 2.6v2.2M12 19.2v2.2M21.4 12h-2.2M4.8 12H2.6M18.6 5.4l-1.55 1.55M6.95 17.05 5.4 18.6M18.6 18.6l-1.55-1.55M6.95 6.95 5.4 5.4" />
    </svg>
    <svg class="theme-toggle-icon icon-moon" viewBox="0 0 24 24" focusable="false">
      <path d="M20.2 14.1A8.3 8.3 0 0 1 9.9 3.8 8.3 8.3 0 1 0 20.2 14.1Z" />
    </svg>
  </span>
</button>

<script is:inline>
  (() => {
    const root = document.documentElement;
    const STORAGE_KEY = "ps-theme";
    const media = window.matchMedia("(prefers-color-scheme: dark)");

    const currentTheme = () => (root.getAttribute("data-theme") === "dark" ? "dark" : "light");

    const syncButtons = () => {
      const dark = currentTheme() === "dark";
      document.querySelectorAll("[data-theme-toggle]").forEach((button) => {
        button.setAttribute("aria-label", dark ? "تغییر به حالت روشن" : "تغییر به حالت تاریک");
        button.setAttribute("aria-pressed", String(dark));
      });
    };

    const applyTheme = (theme) => {
      root.setAttribute("data-theme", theme);
      syncButtons();
    };

    const switchTheme = (theme, origin) => {
      try {
        localStorage.setItem(STORAGE_KEY, theme);
      } catch {
        /* حالت خصوصی مرورگر */
      }

      const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      if (!document.startViewTransition || reduceMotion) {
        applyTheme(theme);
        return;
      }

      // افکت پرده‌برداری دایره‌ای از محل کلیک (View Transitions API)
      const x = origin?.x ?? window.innerWidth / 2;
      const y = origin?.y ?? 0;
      const radius = Math.hypot(Math.max(x, window.innerWidth - x), Math.max(y, window.innerHeight - y));

      const transition = document.startViewTransition(() => applyTheme(theme));
      transition.ready
        .then(() => {
          root.animate(
            { clipPath: [`circle(0px at ${x}px ${y}px)`, `circle(${radius}px at ${x}px ${y}px)`] },
            {
              duration: 520,
              easing: "cubic-bezier(0.4, 0, 0.2, 1)",
              pseudoElement: "::view-transition-new(root)",
            },
          );
        })
        .catch(() => {});
    };

    document.querySelectorAll("[data-theme-toggle]").forEach((button) => {
      button.addEventListener("click", (event) => {
        const next = currentTheme() === "dark" ? "light" : "dark";
        const rect = button.getBoundingClientRect();
        switchTheme(next, {
          x: event.clientX || rect.left + rect.width / 2,
          y: event.clientY || rect.top + rect.height / 2,
        });
      });
    });

    media.addEventListener("change", (event) => {
      let stored = null;
      try {
        stored = localStorage.getItem(STORAGE_KEY);
      } catch {
        /* حالت خصوصی مرورگر */
      }
      if (stored !== "dark" && stored !== "light") {
        applyTheme(event.matches ? "dark" : "light");
      }
    });

    syncButtons();
  })();
</script>
