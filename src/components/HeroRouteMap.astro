---
/**
 * HeroRouteMap.astro — هیبرید v3، سینک‌شده با تصویر جدید بدون قاب
 * تکنیک عیناً از دموی تاییدشده route-icon-hybrid-v2 (screen blend — دست نخورده).
 * همه اعداد به هندسه route-icon.webp جدید (۱۲۵۴×۱۲۵۴) قفل شده‌اند:
 *   طول مسیر = 1183 → dasharray "200 1183"، sweep ‎200→‎-983،
 *   keyTimes 0;0.8309;1، پینگ 82.09/83.09/92.09٪
 * - تصویر: وب‌پی جدا و کش‌پذیر (بیس‌۶۴ ممنوع)
 * - صفر جاوااسکریپت، صفر هیدریشن، لایه نور aria-hidden
 */
import routeIconImage from "@/assets/company/route-icon.webp";
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";

interface Props {
  src?: ImageMetadata;
  alt?: string;
  class?: string;
  eager?: boolean;
}
const {
  src = routeIconImage,
  alt = 'مسیر کشف پروژه ساختمانی فعال روی نقشه — از موقعیت تا پروژه',
  class: className = '',
  eager = true,
} = Astro.props;
---

<figure class={`route-map ${className}`}>
  <Image
    src={src}
    alt={alt}
    width="1254"
    height="1254"
    loading={eager ? 'eager' : 'lazy'}
    fetchpriority={eager ? 'high' : 'auto'}
    decoding="async"
  />
  <svg viewBox="0 0 1254 1254" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <defs>
      <filter id="hrm-blur-wide" x="-60%" y="-60%" width="220%" height="220%">
        <feGaussianBlur stdDeviation="11"/>
      </filter>
      <filter id="hrm-blur-soft" x="-60%" y="-60%" width="220%" height="220%">
        <feGaussianBlur stdDeviation="3.5"/>
      </filter>
      <radialGradient id="hrm-halo-grad">
        <stop offset="0" stop-color="#ff9d57" stop-opacity=".5"/>
        <stop offset="1" stop-color="#ff9d57" stop-opacity="0"/>
      </radialGradient>
      <path id="hrm-route" d="M 1008.0 313.0 L 1010.0 344.0 L 1004.0 353.0 L 1003.0 364.0 L 991.0 393.0 L 973.0 460.0 L 959.0 491.0 L 943.0 509.0 L 922.0 522.0 L 889.0 531.0 L 847.0 529.0 L 833.0 533.0 L 752.0 539.0 L 745.0 551.0 L 717.0 580.0 L 711.0 597.0 L 680.0 760.0 L 662.0 811.0 L 647.0 842.0 L 624.0 870.0 L 598.0 880.0 L 572.0 899.0 L 561.0 917.0 L 542.0 936.0 L 537.0 955.0 L 527.0 973.0 L 516.0 1026.0 L 499.0 1056.0 L 483.0 1070.0 L 466.0 1079.0 L 425.0 1085.0 L 405.0 1092.0 L 347.0 1089.0 L 340.0 1078.0"/>
    </defs>

    <ellipse class="halo"   cx="1008" cy="326"  rx="92"  ry="40" fill="url(#hrm-halo-grad)"/>
    <ellipse class="halo b" cx="340"  cy="1090" rx="100" ry="44" fill="url(#hrm-halo-grad)"/>

    <g style="mix-blend-mode:screen">
      <use href="#hrm-route" class="comet" fill="none" stroke="#ffb36b" stroke-width="30"
           stroke-linecap="round" filter="url(#hrm-blur-wide)" opacity=".9"/>
      <use href="#hrm-route" class="comet-core" fill="none" stroke="#fff3e4" stroke-width="9"
           stroke-linecap="round" filter="url(#hrm-blur-soft)"/>
    </g>

    <g>
      <circle r="10.5" fill="#fff" stroke="#e07238" stroke-width="5.5">
        <animateMotion dur="5.6s" repeatCount="indefinite"
          keyPoints="0;1;1" keyTimes="0;0.8309;1" calcMode="linear">
          <mpath href="#hrm-route"/>
        </animateMotion>
      </circle>
    </g>

    <!-- ping lands on the construction-site node -->
    <circle class="ping" cx="340" cy="1078" r="58" fill="none"
            stroke="#ff9d57" stroke-width="7"/>

    <ellipse class="glint" cx="1009" cy="205" rx="26" ry="40"
             fill="#ffffff" filter="url(#hrm-blur-wide)"/>
  </svg>
</figure>

<style>
  .route-map {
    position: relative;
    margin: 0;
    aspect-ratio: 1;
  }
  .route-map img {
    display: block;
    width: 100%;
    height: 100%;
    border-radius: inherit;
  }
  .route-map svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }

  /* ── موشن: تکنیک v2، اعداد سینک با مسیر جدید (L=1183) ── */
  .comet, .comet-core{
    stroke-dasharray: 200 1183;
    animation: sweep 5.6s linear infinite;
  }
  @keyframes sweep{
    from{ stroke-dashoffset: 200; }
    to  { stroke-dashoffset: -983; }
  }

  /* arrival ping at the construction-site node */
  .ping{ transform-box:fill-box; transform-origin:center;
    animation: ping 5.6s linear infinite; opacity:0; }
  @keyframes ping{
    0%, 82.09% { transform:scale(.3); opacity:0; }
    83.09%     { transform:scale(.4); opacity:.85; }
    92.09%     { transform:scale(1.5); opacity:0; }
    100%{ opacity:0; }
  }

  .halo{ transform-box:fill-box; transform-origin:center;
    animation: breathe 4.2s ease-in-out infinite; }
  .halo.b{ animation-delay:2.1s; }
  @keyframes breathe{
    0%,100%{ transform:scale(1); opacity:0; }
    50%    { transform:scale(1.22); opacity:.5; }
  }

  .glint{ transform-box:fill-box; transform-origin:center;
    animation: glint 4.2s ease-in-out infinite; }
  @keyframes glint{ 0%,100%{ opacity:0; } 50%{ opacity:.45; } }

  @media (prefers-reduced-motion: reduce) {
    .route-map svg { display: none; }
  }
</style>
