---
import BaseLayout from "@/layouts/BaseLayout.astro";
import BreadcrumbSchema from "@/components/BreadcrumbSchema.astro";
import { absoluteUrl, site } from "@/content/home";
import {
  constructionStages,
  getWorkFieldsForStage,
  getWorkSubcategoriesForStage,
  type ConstructionStage,
} from "@/content/construction";

export function getStaticPaths() {
  return constructionStages.map((stage) => ({
    params: { slug: stage.slug },
    props: { stage },
  }));
}

const { stage } = Astro.props as { stage: ConstructionStage };
const relatedFields = getWorkFieldsForStage(stage.id);
const relatedSubcategories = getWorkSubcategoriesForStage(stage.id);
const stageIndex = constructionStages.findIndex((item) => item.id === stage.id);
const title = `${stage.title} | مرحله ساخت ساختمان | پرشین‌سازه`;
const description = `${stage.title} در چرخه ساخت ساختمان: تعریف مرحله، نکات مهم برای سازنده، دسته‌های کاری و زیر‌دسته‌های محصول یا خدمت مرتبط.`;
const toPersianDigits = (value: string | number) => String(value).replace(/\d/g, (digit) => "۰۱۲۳۴۵۶۷۸۹"[Number(digit)]);
const relatedFieldsCount = toPersianDigits(relatedFields.length);
const relatedSubcategoriesCount = toPersianDigits(relatedSubcategories.length);
const structuredData = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: stage.title,
  description: stage.definition,
  isPartOf: absoluteUrl("/construction-stages/"),
  publisher: { "@type": "Organization", name: site.name, url: site.url },
  author: { "@type": "Organization", name: site.name, url: site.url },
  inLanguage: "fa-IR",
  mainEntityOfPage: absoluteUrl(`/construction-stages/${stage.slug}/`),
};
---

<BaseLayout
  title={title}
  description={description}
  canonicalPath={`/construction-stages/${stage.slug}/`}
  structuredData={structuredData}
>
  <BreadcrumbSchema
    items={[
      { name: "مراحل ساخت", path: "/construction-stages/" },
      { name: stage.title, path: `/construction-stages/${stage.slug}/` },
    ]}
  />
  <main>
    <section class="content-hero stage-page-hero stage-window-hero">
      <div class="container content-hero-grid stage-page-hero-grid">
        <div class="stage-page-intro">
          <nav class="breadcrumb" aria-label="مسیر صفحه">
            <a href="/construction-stages/">مراحل ساخت</a>
            <span aria-hidden="true">←</span>
            <span>{stage.title}</span>
          </nav>
          <p class="content-eyebrow">مرحله ساخت</p>
          <h1>{stage.title}</h1>
          <p>{toPersianDigits(stage.summary)}</p>
          <div class="action-row">
            <a class="button button-primary" href="/#demo">درخواست دمو</a>
            <a class="button button-secondary" href="/construction-stages/">همه مراحل ساخت</a>
          </div>
        </div>
        <aside class="content-summary-card stage-summary-card" aria-label="خلاصه مرحله">
          <span>نمای سریع مرحله</span>
          <dl class="compact-facts">
            <div>
              <dt>{relatedFieldsCount}</dt>
              <dd>زمینه کاری مرتبط</dd>
            </div>
            <div>
              <dt>{relatedSubcategoriesCount}</dt>
              <dd>زیر‌دسته محصول و خدمت</dd>
            </div>
          </dl>
        </aside>
      </div>
    </section>

    <section class="section stage-cycle-band">
      <div class="container">
        <div class="stage-fit-rail stage-cycle-rail" aria-label="چرخه مراحل ساخت">
          {constructionStages.map((item, index) => (
            <a
              class={item.id === stage.id ? "stage-fit-tile is-active" : "stage-fit-tile"}
              href={`/construction-stages/${item.slug}/`}
              aria-current={item.id === stage.id ? "page" : undefined}
            >
              <span>{toPersianDigits(index + 1)}</span>
              <strong>{item.title}</strong>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="section stage-page-section">
      <div class="container detail-layout">
        <aside class="detail-sidebar">
          <h2>جایگاه در چرخه</h2>
          <p>
            این مرحله، گام {toPersianDigits(stageIndex + 1)} از {toPersianDigits(constructionStages.length)} در مسیر
            پرشین‌سازه است و باید با زمان فروش محصول شما تطبیق داده شود.
          </p>

          <h2>زمان اقدام فروش</h2>
          <p>{toPersianDigits(stage.buyerTiming)}</p>

          <h2>نکات مهم برای سازنده</h2>
          <ul class="numbered-list">
            {stage.builderNotes.map((note) => <li>{toPersianDigits(note)}</li>)}
          </ul>
        </aside>

        <article class="detail-main">
          <section>
            <h2>تعریف مرحله ساخت</h2>
            <p>{toPersianDigits(stage.definition)}</p>
          </section>

          <section>
            <h2>زمینه‌های کاری مرتبط با این مرحله</h2>
            <div class="related-grid">
              {relatedFields.map((field) => (
                <article class="related-card">
                  <h3>{field.title}</h3>
                  <p>{toPersianDigits(field.definition)}</p>
                  <ul class="tag-list">
                    {field.subcategories
                      .filter((subcategory) => subcategory.stageIds.includes(stage.id))
                      .map((subcategory) => (
                        <li>
                          <a href={`/work-fields/${field.slug}/${subcategory.slug}/`}>{subcategory.title}</a>
                        </li>
                      ))}
                  </ul>
                  <a class="text-link" href={`/work-fields/${field.slug}/`}>جزئیات زمینه کاری ←</a>
                </article>
              ))}
            </div>
          </section>

          <section>
            <h2>زیر‌دسته‌های محصول و خدمت در این مرحله</h2>
            <div class="subcategory-grid">
              {relatedSubcategories.map((subcategory) => (
                <article class="related-card">
                  <h3>{subcategory.title}</h3>
                  <p>{subcategory.parentTitle}</p>
                  <p>{toPersianDigits(subcategory.definition)}</p>
                  <a class="text-link" href={`/work-fields/${subcategory.parentSlug}/${subcategory.slug}/`}>صفحه زیر‌دسته ←</a>
                </article>
              ))}
            </div>
          </section>
        </article>
      </div>
    </section>
  </main>
</BaseLayout>
