---
import BaseLayout from "@/layouts/BaseLayout.astro";
import {
  constructionStages,
  getWorkFieldsForStage,
  type ConstructionStage,
} from "@/content/construction";

export function getStaticPaths() {
  return constructionStages.map((stage) => ({
    params: { slug: stage.slug },
    props: { stage },
  }));
}

const { stage } = Astro.props as { stage: ConstructionStage };
const relatedFields = getWorkFieldsForStage(stage.id);
const title = `${stage.title} | مرحله ساخت ساختمان | پرشین‌سازه`;
const description = `${stage.title} در چرخه ساخت ساختمان، تصمیم‌های فروش، محصولات و خدمات مرتبط و زمان مناسب اقدام برای تیم فروش پروژه‌محور.`;
---

<BaseLayout title={title} description={description} canonicalPath={`/construction-stages/${stage.slug}/`}>
  <main>
    <section class="content-hero">
      <div class="container content-hero-grid">
        <div>
          <p class="content-eyebrow">مرحله ساخت</p>
          <h1>{stage.title}</h1>
          <p>{stage.summary}</p>
          <div class="action-row">
            <a class="button button-primary" href="/#demo">درخواست دمو</a>
            <a class="button button-secondary" href="/construction-stages/">همه مراحل ساخت</a>
          </div>
        </div>
        <aside class="content-summary-card">
          <strong>{relatedFields.length}</strong>
          <span>زمینه کاری مرتبط</span>
          <p>{stage.sourcePhase}</p>
        </aside>
      </div>
    </section>

    <section class="section">
      <div class="container detail-layout">
        <aside class="detail-sidebar">
          <h2>زمان اقدام فروش</h2>
          <p>{stage.buyerTiming}</p>
        </aside>

        <article class="detail-main">
          <section>
            <h2>زمینه‌های کاری مرتبط با این مرحله</h2>
            <div class="related-grid">
              {relatedFields.map((field) => (
                <article class="related-card">
                  <h3>{field.title}</h3>
                  <p>{field.definition}</p>
                  <a class="text-link" href={`/work-fields/${field.slug}/`}>جزئیات زمینه کاری ←</a>
                </article>
              ))}
            </div>
          </section>
        </article>
      </div>
    </section>
  </main>
</BaseLayout>
