---
import BaseLayout from "@/layouts/BaseLayout.astro";
import BreadcrumbSchema from "@/components/BreadcrumbSchema.astro";
import StagesTimelineHybrid from "@/components/StagesTimelineHybrid.astro";
import { absoluteUrl, site } from "@/content/home";
import {
  constructionStages,
  getWorkFieldsForStage,
  getWorkSubcategoriesForStage,
} from "@/content/construction";

const title = "مراحل ساخت ساختمان | پرشین‌سازه";
const description =
  "مراحل ساخت ساختمان از طراحی و اخذ جواز تا ظریف‌کاری و پایان کار، همراه با زمینه‌های کاری، زیر‌دسته‌های محصول و خدمت و نکات مهم برای سازنده.";
const stagePrinciples = [
  {
    title: "مرحله ساخت",
    body: "وضعیت فیزیکی پروژه را روشن می‌کند؛ از طراحی و جواز تا اجرای سازه، تاسیسات، نازک‌کاری و تحویل.",
  },
  {
    title: "زمان اجرا",
    body: "مشخص می‌کند محصول یا خدمت شما چه زمانی واقعا وارد پروژه می‌شود و چه زمانی هنوز زود یا دیر است.",
  },
  {
    title: "زمان فروش",
    body: "لحظه مناسب معرفی، مذاکره، تماس یا پیگیری را از روی چرخه پروژه به زبان تیم فروش ترجمه می‌کند.",
  },
];
const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: title,
    description,
    url: absoluteUrl("/construction-stages/"),
    inLanguage: "fa-IR",
    isPartOf: { "@type": "WebSite", name: site.name, url: site.url },
  },
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    name: "فهرست مراحل ساخت ساختمان",
    itemListElement: constructionStages.map((stage, index) => ({
      "@type": "ListItem",
      position: index + 1,
      name: stage.title,
      url: absoluteUrl(`/construction-stages/${stage.slug}/`),
      description: stage.definition,
    })),
  },
];
---

<BaseLayout
  title={title}
  description={description}
  canonicalPath="/construction-stages/"
  structuredData={structuredData}
>
  <BreadcrumbSchema items={[{ name: "مراحل ساخت", path: "/construction-stages/" }]} />
  <main>
    <section class="content-hero stage-index-hero">
      <div class="container content-hero-grid stage-hero-grid">
        <p class="content-eyebrow">مراحل ساخت</p>
        <h1>مراحل ساخت را به پنجره‌های فروش تبدیل کنید</h1>
        <div class="stage-hero-visual" aria-label="تایم‌لاین تصویری مراحل ساخت">
          <StagesTimelineHybrid />
        </div>
        <p class="stage-hero-lede">
          هر مرحله ساخت فقط یک وضعیت فنی نیست؛ برای تامین‌کننده یعنی زمان متفاوتی برای ورود، معرفی محصول، مذاکره یا
          پیگیری. این صفحه رابطه مرحله، زمینه کاری و زیر‌دسته محصول را شفاف می‌کند.
        </p>
        <div class="action-row">
          <a class="button button-primary" href="/#demo">درخواست دمو</a>
          <a class="button button-secondary" href="/work-fields/">مشاهده زمینه‌های کاری</a>
        </div>
      </div>
    </section>

    <section class="section stage-principles-section">
      <div class="container stage-principle-grid">
        {stagePrinciples.map((item) => (
          <article>
            <h2>{item.title}</h2>
            <p>{item.body}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section">
      <div class="container stage-list stage-cycle-list csx-spine">
        {constructionStages.map((stage, index) => {
          const relatedFields = getWorkFieldsForStage(stage.id);
          const relatedSubcategories = getWorkSubcategoriesForStage(stage.id);
          const visibleSubcategories = relatedSubcategories.slice(0, 6);
          const hiddenCount = relatedSubcategories.length - visibleSubcategories.length;
          return (
            <article class="stage-row csx-spine-row">
              <div class="csx-spine-node">
                <span class="stage-index">{String(index + 1).padStart(2, "0")}</span>
              </div>
              <div class="csx-spine-card">
                <p class="content-eyebrow">{stage.sourcePhase}</p>
                <h2>{stage.title}</h2>
                <p class="stage-definition">{stage.definition}</p>
                <p class="stage-timing"><strong>زمان فروش:</strong> {stage.buyerTiming}</p>
                <p><strong>پوشش محتوایی:</strong> {relatedFields.length} دسته و {relatedSubcategories.length} زیر‌دسته مرتبط</p>
                <ul class="tag-list">
                  {visibleSubcategories.map((subcategory) => (
                    <li>
                      <a href={`/work-fields/${subcategory.parentSlug}/${subcategory.slug}/`}>{subcategory.title}</a>
                    </li>
                  ))}
                  {hiddenCount > 0 && (
                    <li>
                      <a class="tag-more" href={`/construction-stages/${stage.slug}/`}>
                        {`و ${hiddenCount} مورد دیگر ←`}
                      </a>
                    </li>
                  )}
                </ul>
                <a class="text-link" href={`/construction-stages/${stage.slug}/`}>
                  مشاهده صفحه کامل مرحله ←
                </a>
              </div>
            </article>
          );
        })}
      </div>
    </section>
  </main>
</BaseLayout>
