---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { constructionStages, getWorkFieldsForStage } from "@/content/construction";

const title = "مراحل ساخت ساختمان | پرشین‌سازه";
const description =
  "مراحل ساخت ساختمان از طراحی و اخذ جواز تا ظریف‌کاری و پایان کار، همراه با زمینه‌های کاری و زمان مناسب فروش پروژه‌محور.";
---

<BaseLayout title={title} description={description} canonicalPath="/construction-stages/">
  <main>
    <section class="content-hero">
      <div class="container content-hero-grid">
        <div>
          <p class="content-eyebrow">مراحل ساخت</p>
          <h1>چرخه ساخت را به زبان فروش پروژه‌محور بخوانید</h1>
          <p>
            این صفحه مراحل ساخت را از منابع جدید ساختاردهی می‌کند تا معلوم شود هر مرحله چه تصمیم‌هایی دارد و کدام
            زمینه‌های کاری در آن مرحله فعال‌ترند.
          </p>
          <div class="action-row">
            <a class="button button-primary" href="/#demo">درخواست دمو</a>
            <a class="button button-secondary" href="/work-fields/">مشاهده زمینه‌های کاری</a>
          </div>
        </div>
        <aside class="content-summary-card">
          <strong>{constructionStages.length}</strong>
          <span>مرحله ساخت</span>
          <p>از طراحی و جواز تا تحویل و پایان کار</p>
        </aside>
      </div>
    </section>

    <section class="section">
      <div class="container stage-list">
        {constructionStages.map((stage, index) => {
          const relatedFields = getWorkFieldsForStage(stage.id);
          return (
            <article class="stage-row">
              <span class="stage-index">{String(index + 1).padStart(2, "0")}</span>
              <div>
                <p class="content-eyebrow">{stage.sourcePhase}</p>
                <h2>{stage.title}</h2>
                <p>{stage.summary}</p>
                <p><strong>زمان فروش:</strong> {stage.buyerTiming}</p>
                <a class="text-link" href={`/construction-stages/${stage.slug}/`}>
                  مشاهده {relatedFields.length} زمینه مرتبط ←
                </a>
              </div>
            </article>
          );
        })}
      </div>
    </section>
  </main>
</BaseLayout>
