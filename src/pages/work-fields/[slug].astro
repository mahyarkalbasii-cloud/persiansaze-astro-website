---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { constructionStages, getWorkFieldsForStage, workFields, type WorkField } from "@/content/construction";

export function getStaticPaths() {
  return workFields.map((field) => ({
    params: { slug: field.slug },
    props: { field },
  }));
}

const { field } = Astro.props as { field: WorkField };
const stages = constructionStages.filter((stage) => field.stageIds.includes(stage.id));
const stageIdSet = new Set(field.stageIds);
const title = `${field.title} | زمینه کاری ساختمان | پرشین‌سازه`;
const description = `${field.title} در چرخه ساخت ساختمان: زیر‌دسته‌های محصول و خدمت، معادل مرحله ساخت، تعریف فنی و نکات مهم برای سازنده.`;
const relatedFields = [
  ...new Map(
    stages
      .flatMap((stage) => getWorkFieldsForStage(stage.id))
      .filter((item) => item.slug !== field.slug)
      .map((item) => [item.slug, item])
  ).values(),
].slice(0, 6);
---

<BaseLayout title={title} description={description} canonicalPath={`/work-fields/${field.slug}/`}>
  <main>
    <section class="content-hero work-fit-hero">
      <div class="container content-hero-grid">
        <div>
          <nav class="breadcrumb" aria-label="مسیر صفحه">
            <a href="/work-fields/">زمینه‌های کاری</a>
            <span aria-hidden="true">‹</span>
            <span>{field.title}</span>
          </nav>
          <p class="content-eyebrow">تناسب با ساخت</p>
          <h1>{field.title}</h1>
          <p>{field.definition}</p>
          <div class="action-row">
            <a class="button button-primary" href="/#demo">درخواست دمو</a>
            <a class="button button-secondary" href="/work-fields/">همه زمینه‌های کاری</a>
          </div>
        </div>
        <aside class="content-summary-card work-fit-summary-card">
          <strong>{field.subcategories.length}</strong>
          <span>زیر‌دسته محصول و خدمت</span>
          <p>{field.equivalent}</p>
        </aside>
      </div>
    </section>

    <section class="work-stage-band">
      <div class="container">
        <div class="section-heading">
          <h2>محصول من کجای ساخت می‌فروشد؟</h2>
          <p>مراحل روشن، پنجره‌های فروش این زمینه کاری‌اند؛ بقیه مراحل برای مقایسه و جهت‌یابی محو شده‌اند.</p>
        </div>
        <div class="stage-fit-rail work-stage-rail" aria-label="ریل تناسب مراحل ساخت">
          {constructionStages.map((stage, index) => (
            <a
              class={stageIdSet.has(stage.id) ? "stage-fit-tile is-active" : "stage-fit-tile"}
              href={`/construction-stages/${stage.slug}/`}
            >
              <span>{String(index + 1).padStart(2, "0")}</span>
              <strong>{stage.title}</strong>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container detail-layout">
        <aside class="detail-sidebar work-fit-sidebar">
          <h2>شناسه محتوایی</h2>
          <dl class="compact-facts">
            <div>
              <dt>نام دسته</dt>
              <dd>{field.title}</dd>
            </div>
            <div>
              <dt>مرحله منبع</dt>
              <dd><span class="template-tag">{field.sourceLifecycle}</span></dd>
            </div>
            <div>
              <dt>معادل مرحله ساخت</dt>
              <dd>{field.equivalent}</dd>
            </div>
          </dl>

          <h2>مرحله‌های مرتبط</h2>
          <ul class="link-list">
            {stages.map((stage) => (
              <li><a href={`/construction-stages/${stage.slug}/`}>{stage.title}</a></li>
            ))}
          </ul>
        </aside>

        <article class="detail-main work-fit-main">
          <section class="work-definition-card">
            <h2>تعریف محصول یا خدمت در این دسته</h2>
            <p>{field.definition}</p>
            <p><span class="template-tag">{field.sourceLifecycle}</span></p>
          </section>

          <section>
            <h2>آیتم‌های محصول یا خدمت</h2>
            <p>
              هر آیتم فعلاً URL مستقل دارد، اما تا زمان تولید محتوای یکتا، زیرصفحه‌ها به صفحه والد canonical می‌شوند.
            </p>
            <div class="work-product-grid">
              {field.subcategories.map((subcategory) => (
                <a href={`/work-fields/${field.slug}/${subcategory.slug}/`}>{subcategory.title}</a>
              ))}
            </div>
          </section>

          <section>
            <h2>نکات مهم برای سازنده</h2>
            <ul class="benefit-check-list">
              {field.benefits.map((benefit) => (
                <li>
                  <span aria-hidden="true">✓</span>
                  <p>{benefit}</p>
                </li>
              ))}
            </ul>
          </section>

          <section>
            <h2>تعریف مرحله‌های مرتبط</h2>
            <div class="related-grid">
              {stages.map((stage) => (
                <article class="related-card">
                  <h3>{stage.title}</h3>
                  <p>{stage.definition}</p>
                  <a class="text-link" href={`/construction-stages/${stage.slug}/`}>صفحه مرحله ←</a>
                </article>
              ))}
            </div>
          </section>

          {relatedFields.length > 0 && (
            <section>
              <h2>زمینه‌های هم‌خانواده</h2>
              <ul class="template-chip-list">
                {relatedFields.map((item) => (
                  <li><a href={`/work-fields/${item.slug}/`}>{item.title}</a></li>
                ))}
              </ul>
            </section>
          )}

          <section class="work-fit-cta">
            <h2>فرصت‌های این زمینه کاری را مرحله‌به‌مرحله ببینید</h2>
            <p>پرشین‌سازه کمک می‌کند محصول یا خدمت را به پروژه‌هایی وصل کنید که همین حالا در مرحله مناسب خرید هستند.</p>
            <div class="action-row">
              <a class="button button-primary" href="/#demo">درخواست دمو</a>
              <a class="button button-secondary" href="/construction-stages/">مشاهده مراحل ساخت</a>
            </div>
          </section>
        </article>
      </div>
    </section>
  </main>
</BaseLayout>
