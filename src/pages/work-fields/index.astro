---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { constructionStages, stageTitleById, workFields } from "@/content/construction";

const title = "زمینه‌های کاری ساختمان | پرشین‌سازه";
const description =
  "دسته‌بندی زمینه‌های کاری، محصولات و خدمات ساختمانی بر اساس چرخه ساخت، مرحله استفاده و زمان مناسب فروش پروژه‌محور.";
---

<BaseLayout title={title} description={description} canonicalPath="/work-fields/">
  <main>
    <section class="content-hero">
      <div class="container content-hero-grid">
        <div>
          <p class="content-eyebrow">زمینه‌های کاری</p>
          <h1>زمینه‌های کاری را بر اساس مرحله ساخت ببینید</h1>
          <p>
            این صفحه از منابع جدید مراحل و محصولات ساخت ساختمان ساخته شده و هر گروه محصول یا خدمت را به مرحله‌های مرتبط
            در چرخه پروژه وصل می‌کند.
          </p>
          <div class="action-row">
            <a class="button button-primary" href="/#demo">درخواست دمو</a>
            <a class="button button-secondary" href="/construction-stages/">مشاهده مراحل ساخت</a>
          </div>
        </div>
        <aside class="content-summary-card">
          <strong>{workFields.length}</strong>
          <span>گروه کاری ساختاریافته</span>
          <p>{constructionStages.length} مرحله ساخت برای زمان‌بندی فروش پروژه‌محور</p>
        </aside>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="content-card-grid">
          {workFields.map((field) => (
            <article class="content-card">
              <p class="content-eyebrow">{field.stageIds.map((id) => stageTitleById.get(id)).filter(Boolean).join(" / ")}</p>
              <h2>{field.title}</h2>
              <p>{field.definition}</p>
              <dl class="compact-facts">
                <div>
                  <dt>محصولات و خدمات</dt>
                  <dd>{field.products}</dd>
                </div>
                <div>
                  <dt>زمان استفاده</dt>
                  <dd>{field.lifecycle}</dd>
                </div>
              </dl>
              <a class="text-link" href={`/work-fields/${field.slug}/`}>مشاهده جزئیات ←</a>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
