---
import BaseLayout from "@/layouts/BaseLayout.astro";
import BreadcrumbSchema from "@/components/BreadcrumbSchema.astro";
import WorkFieldsAtlasHybrid from "@/components/WorkFieldsAtlasHybrid.astro";
import { absoluteUrl, site } from "@/content/home";
import { constructionStages, stageTitleById, workFields } from "@/content/construction";

const title = "زمینه‌های کاری ساختمان | پرشین‌سازه";
const description =
  "دسته‌بندی کامل زمینه‌های کاری، زیر‌دسته‌های محصول و خدمات ساختمانی، معادل مرحله ساخت، تعریف فنی و نکات مهم برای سازنده.";
const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: title,
    description,
    url: absoluteUrl("/work-fields/"),
    inLanguage: "fa-IR",
    isPartOf: { "@type": "WebSite", name: site.name, url: site.url },
  },
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    name: "فهرست زمینه‌های کاری ساختمان",
    itemListElement: workFields.map((field, index) => ({
      "@type": "ListItem",
      position: index + 1,
      name: field.title,
      url: absoluteUrl(`/work-fields/${field.slug}/`),
      description: field.definition,
    })),
  },
];
---

<BaseLayout title={title} description={description} canonicalPath="/work-fields/" structuredData={structuredData}>
  <BreadcrumbSchema items={[{ name: "زمینه‌های کاری", path: "/work-fields/" }]} />
  <main>
    <section class="content-hero work-index-hero">
      <div class="container content-hero-grid">
        <div>
          <p class="content-eyebrow">زمینه‌های کاری</p>
          <h1>زمینه‌های کاری را بر اساس مرحله ساخت ببینید</h1>
          <p>
            هر زمینه کاری یک دسته محتوایی مستقل دارد و زیر‌دسته‌های محصول یا خدمت آن هم صفحه جداگانه دارند. معادل مرحله
            ساخت، تعریف فنی منبع و نکات مهم برای سازنده در همین ساختار حفظ شده‌اند.
          </p>
          <div class="action-row">
            <a class="button button-primary" href="/#demo">درخواست دمو</a>
            <a class="button button-secondary" href="/construction-stages/">مشاهده مراحل ساخت</a>
          </div>
        </div>
        <div class="work-index-visual" aria-label="اطلس تصویری زمینه‌های کاری ساختمان">
          <WorkFieldsAtlasHybrid />
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="content-card-grid work-field-card-grid">
          {workFields.map((field) => (
            <article class="content-card work-field-card">
              <p class="content-eyebrow">{field.stageIds.map((id) => stageTitleById.get(id)).filter(Boolean).join(" / ")}</p>
              <h2>{field.title}</h2>
              <p>{field.definition}</p>
              <div class="stage-fit-rail work-card-stage-rail" aria-label={`مراحل مرتبط ${field.title}`}>
                {constructionStages.map((stage, index) => (
                  <a
                    class={field.stageIds.includes(stage.id) ? "stage-fit-tile is-active" : "stage-fit-tile"}
                    href={`/construction-stages/${stage.slug}/`}
                    aria-label={stage.title}
                  >
                    <span>{String(index + 1).padStart(2, "0")}</span>
                  </a>
                ))}
              </div>
              <dl class="compact-facts">
                <div>
                  <dt>معادل مرحله ساخت</dt>
                  <dd>{field.equivalent}</dd>
                </div>
                <div>
                  <dt>مرحله منبع</dt>
                  <dd>{field.sourceLifecycle}</dd>
                </div>
              </dl>
              <div>
                <p class="content-eyebrow">زیر‌دسته‌ها</p>
                <ul class="tag-list work-card-tags">
                  {field.subcategories.map((subcategory) => (
                    <li>
                      <a href={`/work-fields/${field.slug}/${subcategory.slug}/`}>{subcategory.title}</a>
                    </li>
                  ))}
                </ul>
              </div>
              <a class="text-link" href={`/work-fields/${field.slug}/`}>مشاهده جزئیات →</a>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
