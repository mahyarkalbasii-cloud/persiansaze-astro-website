---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { absoluteUrl, site } from "@/content/home";

type RuleTerm = {
  title: string;
  body: string;
};

type RuleSection = {
  id: string;
  title: string;
  terms?: RuleTerm[];
  items?: string[];
};

const title = "قوانین استفاده از خدمات | پرشین‌سازه";
const description =
  "قوانین و مقررات استفاده از خدمات پرشین‌سازه، شامل شرایط اشتراک، مالکیت معنوی، حساب کاربری، پرداخت، حریم خصوصی، پشتیبانی و حل اختلاف.";

const rulesSections: RuleSection[] = [
  {
    id: "definitions",
    title: "ماده ۱: تعاریف و اصطلاحات",
    terms: [
      {
        title: "سامانه",
        body: "وب‌سایت، اپلیکیشن و کلیه پلتفرم‌های متعلق به پرشین‌سازه که خدمات از طریق آن‌ها ارائه می‌شود.",
      },
      {
        title: "کاربر",
        body: "هر شخص حقیقی یا حقوقی که با پرداخت هزینه اشتراک، حساب کاربری ایجاد کرده و از خدمات سامانه استفاده می‌کند.",
      },
      {
        title: "خدمات",
        body: "دسترسی به اطلاعات پروژه‌های ساختمانی در حال ساخت که توسط تیم پرشین‌سازه جمع‌آوری، پردازش و در اختیار کاربران قرار می‌گیرد و سایر امکاناتی که در سامانه ارائه می‌شود.",
      },
      {
        title: "اطلاعات",
        body: "شامل داده‌ها، مشخصات فنی، اطلاعات تماس، تصاویر و هرگونه محتوای مرتبط با پروژه‌های ساختمانی موجود در سامانه.",
      },
      {
        title: "حساب کاربری",
        body: "پنل اختصاصی کاربر که پس از پرداخت حق اشتراک ایجاد شده و دسترسی به خدمات از طریق آن امکان‌پذیر است.",
      },
    ],
  },
  {
    id: "service-scope",
    title: "ماده ۲: محدوده و شرایط خدمات",
    items: [
      "خدمات پرشین‌سازه، ارائه اطلاعات پروژه‌های ساختمانی در قالب یک پلتفرم تخصصی B2B است. این خدمات صرفاً در طول دوره اشتراک فعال کاربر قابل دسترسی خواهد بود.",
      "پس از پایان دوره اشتراک، دسترسی کاربر به پنل کاربری و کلیه اطلاعات سامانه به‌طور کامل قطع می‌گردد و شرکت هیچ تعهدی برای نگهداری داده‌های فعالیت کاربر نخواهد داشت.",
    ],
  },
  {
    id: "intellectual-property",
    title: "ماده ۳: مالکیت معنوی و حقوق استفاده",
    items: [
      "کلیه اطلاعات، داده‌ها، نرم‌افزار، طراحی وب‌سایت، لوگو و محتوای موجود در سامانه، جزو اموال و دارایی‌های معنوی شرکت پرشین‌سازه محسوب می‌شود.",
      "کاربر حق دارد از اطلاعات دریافت‌شده صرفاً برای مقاصد تجاری و توسعه کسب‌وکار شخصی یا شرکتی خود استفاده نماید.",
      "هرگونه کپی‌برداری، انتقال، فروش، بازنشر، واگذاری حساب کاربری یا در اختیار قرار دادن اطلاعات به هر شخص ثالث خارج از مجموعه مستقیم کاربر، اکیداً ممنوع است.",
      "استفاده از اطلاعات برای ایجاد سرویس مشابه یا رقیب، نقض صریح این توافق‌نامه تلقی شده و شرکت حق لغو فوری اشتراک و پیگیری قانونی را برای خود محفوظ می‌دارد.",
    ],
  },
  {
    id: "account-security",
    title: "ماده ۴: حساب کاربری و امنیت",
    items: [
      "مسئولیت حفظ محرمانگی نام کاربری و رمز عبور بر عهده کاربر است.",
      "تمامی فعالیت‌هایی که از طریق حساب کاربری انجام می‌شود، به منزله فعالیت صاحب حساب تلقی شده و مسئولیت قانونی آن متوجه وی خواهد بود.",
      "هر اشتراک برای استفاده یک تیم مشخص، با تعداد کاربران تعریف‌شده در اشتراک خریداری‌شده است. به‌اشتراک‌گذاری اطلاعات ورود با افراد خارج از آن تیم مجاز نیست.",
    ],
  },
  {
    id: "payments",
    title: "ماده ۵: هزینه‌ها و سیاست پرداخت",
    items: [
      "هزینه اشتراک‌ها مطابق با تعرفه‌های رسمی اعلام‌شده در وب‌سایت یا از طریق نمایندگان فروش شرکت دریافت می‌شود.",
      "وجه پرداختی بابت خرید اشتراک، تحت هیچ شرایطی قابل استرداد نیست. لطفاً پیش از خرید، از انطباق خدمات با نیازهای خود اطمینان حاصل فرمایید.",
      "هرگونه تغییر در پلن اشتراک یا تمدید آن، مستلزم پرداخت هزینه‌های جدید مطابق با تعرفه‌های روز شرکت است.",
    ],
  },
  {
    id: "restrictions",
    title: "ماده ۶: محدودیت‌ها و فعالیت‌های غیرمجاز",
    items: [
      "تلاش برای نفوذ، هک یا اختلال در عملکرد سامانه اکیداً ممنوع و قابل پیگرد حقوقی و قانونی است.",
      "استفاده از هرگونه ابزار خودکار مانند ربات، اسکریپت یا نرم‌افزارهای استخراج داده برای برداشت انبوه اطلاعات از سامانه غیرمجاز است و می‌تواند منجر به مسدود شدن فوری حساب کاربری و پیگرد قانونی شود.",
      "استفاده از خدمات برای هرگونه فعالیت غیرقانونی و مغایر با قوانین جمهوری اسلامی ایران ممنوع است.",
    ],
  },
  {
    id: "responsibility",
    title: "ماده ۷: تعهدات و سلب مسئولیت پرشین‌سازه",
    items: [
      "پرشین‌سازه متعهد است با بهره‌گیری از تیم میدانی خود، اطلاعات دقیق و به‌روزی را جمع‌آوری و ارائه نماید.",
      "با توجه به ماهیت پویا و متغیر صنعت ساختمان، ممکن است برخی پروژه‌ها متوقف شده، مشخصات آن‌ها تغییر کند یا اطلاعات تماس سازندگان عوض شود. پرشین‌سازه مسئولیتی در قبال این تغییرات خارج از کنترل شرکت نخواهد داشت.",
      "اطلاعات ارائه‌شده همان‌طور که هست عرضه می‌شود و شرکت تضمینی مبنی بر موفقیت قطعی کاربر در عقد قرارداد با پروژه‌ها ارائه نمی‌دهد. موفقیت کاربر به کیفیت محصول، استراتژی فروش و نحوه مذاکره خود او وابسته است.",
      "خدمات جانبی مانند CRM، پنل پیامکی و پشتیبانی، بر اساس شرایط اشتراک خریداری‌شده ارائه می‌گردد.",
    ],
  },
  {
    id: "privacy",
    title: "ماده ۸: حریم خصوصی",
    items: [
      "شرکت متعهد است اطلاعات شخصی و داده‌های مربوط به فعالیت کاربران را محرمانه تلقی کرده و از آن‌ها مطابق با سیاست حفظ حریم خصوصی پرشین‌سازه محافظت نماید. این اطلاعات در اختیار هیچ شخص ثالثی قرار نخواهد گرفت، مگر به حکم قانون.",
    ],
  },
  {
    id: "support",
    title: "ماده ۹: پشتیبانی",
    items: [
      "خدمات پشتیبانی فنی و کاربری در ساعات اداری، شنبه تا چهارشنبه از ساعت ۹ الی ۱۷، و از طریق کانال‌های ارتباطی رسمی شرکت ارائه می‌شود. شرکت مسئولیتی در قبال مشکلات ناشی از زیرساخت اینترنت، سخت‌افزار یا نرم‌افزارهای متفرقه کاربر ندارد.",
    ],
  },
  {
    id: "force-majeure",
    title: "ماده ۱۰: فورس ماژور",
    items: [
      "در صورت بروز حوادث غیرمترقبه و خارج از کنترل، مانند بلایای طبیعی، جنگ یا قطعی سراسری اینترنت، که منجر به عدم امکان ارائه سرویس شود، مسئولیتی متوجه شرکت نخواهد بود و پس از رفع شرایط، ارائه خدمات از سر گرفته خواهد شد.",
    ],
  },
  {
    id: "disputes",
    title: "ماده ۱۱: حل اختلاف",
    items: [
      "هرگونه اختلاف ناشی از تفسیر یا اجرای این توافق‌نامه، ابتدا از طریق مذاکره مستقیم میان طرفین حل‌وفصل خواهد شد. در صورت عدم دستیابی به توافق، مرجع صالح برای رسیدگی، دادگاه‌های شهر تهران خواهد بود.",
    ],
  },
  {
    id: "changes",
    title: "ماده ۱۲: تغییرات در قوانین و مقررات",
    items: [
      "شرکت حق دارد در هر زمان، بندهای این توافق‌نامه را اصلاح یا تکمیل نماید. نسخه جدید قوانین از طریق وب‌سایت به اطلاع کاربران خواهد رسید و ادامه استفاده کاربر از خدمات، به منزله پذیرش نسخه به‌روزرسانی‌شده خواهد بود.",
    ],
  },
];

const structuredData = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: title,
  description,
  url: absoluteUrl("/rules/"),
  inLanguage: "fa-IR",
  isPartOf: { "@type": "WebSite", name: site.name, url: site.url },
  about: {
    "@type": "Thing",
    name: "قوانین استفاده از خدمات پرشین‌سازه",
  },
};
---

<BaseLayout title={title} description={description} canonicalPath="/rules/" structuredData={structuredData}>
  <main class="rules-page">
    <section class="content-hero rules-hero">
      <div class="container content-hero-grid">
        <div>
          <p class="content-eyebrow">قوانین و مقررات</p>
          <h1>قوانین استفاده از خدمات پرشین‌سازه</h1>
          <p>
            این سند، توافق‌نامه‌ای میان شرکت پرشین‌سازه و کاربر است. استفاده از هر یک از خدمات پرشین‌سازه به منزله مطالعه،
            درک و پذیرش کامل تمامی بندهای این توافق‌نامه است.
          </p>
          <div class="action-row">
            <a class="button button-primary" href="#rules-content">مطالعه قوانین</a>
            <a class="button button-secondary" href="/#demo">تماس با پرشین‌سازه</a>
          </div>
        </div>
        <aside class="content-summary-card rules-summary-card">
          <strong>{rulesSections.length}</strong>
          <span>ماده حقوقی</span>
          <p>شرایط استفاده، مالکیت اطلاعات، حساب کاربری، پرداخت، حریم خصوصی و پشتیبانی در این صفحه آمده است.</p>
        </aside>
      </div>
    </section>

    <section id="rules-content" class="section rules-section">
      <div class="container rules-layout">
        <aside class="rules-toc" aria-label="فهرست قوانین">
          <h2>فهرست مواد</h2>
          <nav>
            {rulesSections.map((section) => (
              <a href={`#${section.id}`}>{section.title}</a>
            ))}
          </nav>
        </aside>

        <article class="rules-article">
          {rulesSections.map((section) => (
            <section id={section.id} class="rule-section-card">
              <h2>{section.title}</h2>

              {section.terms && (
                <div class="rule-terms">
                  {section.terms.map((term) => (
                    <section class="rule-term">
                      <h3>{term.title}</h3>
                      <p>{term.body}</p>
                    </section>
                  ))}
                </div>
              )}

              {section.items && (
                <ul class="rule-list">
                  {section.items.map((item) => (
                    <li>{item}</li>
                  ))}
                </ul>
              )}
            </section>
          ))}
        </article>
      </div>
    </section>
  </main>
</BaseLayout>
