---
import ProjectListCard from "@/components/ProjectListCard.astro";
import { growthStageRoutes, type GrowthStageRoute } from "@/content/growthSilos";
import { site } from "@/content/home";
import Layout from "@/layouts/Layout.astro";

export function getStaticPaths() {
  return growthStageRoutes.map((route) => ({
    params: { stage: route.stage },
    props: { route },
  }));
}

const { route } = Astro.props as { route: GrowthStageRoute };
const canonicalPath = `/stages/${route.stage}/`;
const canonicalURL = new URL(canonicalPath, Astro.site).toString();
const title = `${route.headline} | پرشین‌سازه`;
const description = `${route.headline}: ${route.description}`;
const structuredData = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: title,
  description,
  url: canonicalURL,
  inLanguage: "fa-IR",
  isPartOf: { "@id": `${site.url}/#website` },
  about: [
    { "@type": "Thing", name: "Construction Stages" },
    { "@type": "Thing", name: "Construction Intelligence" },
    { "@type": "Thing", name: route.stageName },
  ],
  mainEntity: {
    "@type": "ItemList",
    itemListElement: route.projects.map((project, index) => ({
      "@type": "ListItem",
      position: index + 1,
      item: {
        "@type": "Project",
        name: project.title,
        location: project.location,
        description: `${project.title} در مرحله ${project.stage}`,
      },
    })),
  },
};
---

<Layout title={title} description={description} canonicalURL={canonicalURL} structuredData={structuredData}>
  <main>
    <section class="content-hero stage-page-hero stage-window-hero">
      <div class="container content-hero-grid stage-page-hero-grid">
        <div class="stage-page-intro">
          <nav class="breadcrumb" aria-label="مسیر صفحه">
            <a href="/">پرشین‌سازه</a>
            <span aria-hidden="true">›</span>
            <span>مراحل ساخت</span>
            <span aria-hidden="true">›</span>
            <span>{route.stageName}</span>
          </nav>
          <p class="content-eyebrow">پروژه‌ها بر اساس مرحله ساخت</p>
          <h1>{route.headline}</h1>
          <p>{route.description}</p>
          <div class="action-row">
            <a class="button button-primary" href="/#demo">درخواست دمو</a>
            <a class="button button-secondary" href="/construction-stages/">مراحل ساخت اصلی</a>
          </div>
        </div>
        <aside class="content-summary-card stage-summary-card" aria-label="خلاصه مرحله">
          <span>مرحله هدف</span>
          <dl class="compact-facts">
            <div>
              <dt>{route.stageName}</dt>
              <dd>مرحله ساخت</dd>
            </div>
            <div>
              <dt>{route.projects.length}</dt>
              <dd>نمونه پروژه</dd>
            </div>
          </dl>
        </aside>
      </div>
    </section>

    <section class="section">
      <div class="container detail-layout">
        <aside class="detail-sidebar">
          <h2>کاربرد فروش</h2>
          <p>این نمای مرحله‌ای کمک می‌کند پیام فروش، محصول پیشنهادی و زمان تماس با وضعیت واقعی پروژه هماهنگ شود.</p>
          <a class="text-link" href="/#demo">دریافت پروژه‌های کامل →</a>
        </aside>

        <article class="detail-main">
          <section>
            <h2>پروژه‌های نمونه در مرحله {route.stageName}</h2>
            <p>
              این فهرست نمونه‌ای از فرصت‌هایی است که می‌توانند بر اساس مرحله ساخت اولویت‌بندی شوند.
            </p>
            <div class="related-grid">
              {route.projects.map((project) => <ProjectListCard {...project} />)}
            </div>
          </section>
        </article>
      </div>
    </section>
  </main>
</Layout>
