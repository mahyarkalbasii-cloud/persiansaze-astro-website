---
import BaseLayout from "@/layouts/BaseLayout.astro";
import BreadcrumbSchema from "@/components/BreadcrumbSchema.astro";
import { cityProfiles, type CityProfile } from "@/content/cities";
import { constructionStages, workFields } from "@/content/construction";
import { site } from "@/content/home";
import { getProjectHubCitySlug, getProjectNeighborhoodsByCoverageCity, projectHubCityBySlug } from "@/content/neighborhoods";

export function getStaticPaths() {
  return cityProfiles.map((city) => ({
    params: { slug: city.slug },
    props: { city },
  }));
}

const { city } = Astro.props as { city: CityProfile };
const relatedStages = constructionStages.filter((stage) => city.relatedStageIds.includes(stage.id));
const relatedFields = workFields.filter((field) => city.relatedWorkFieldSlugs.includes(field.slug));
const relatedStageIdSet = new Set(city.relatedStageIds);
const projectNeighborhoods = getProjectNeighborhoodsByCoverageCity(city.slug);
const projectCityGroups = Array.from(
  new Map(
    projectNeighborhoods.map((neighborhood) => {
      const hubCitySlug = getProjectHubCitySlug(neighborhood.projectCitySlug);
      const hubCity = projectHubCityBySlug.get(hubCitySlug);

      if (!hubCity) {
        throw new Error(`Missing project hub city for ${neighborhood.slug}`);
      }

      return [hubCity.slug, hubCity] as const;
    }),
  ).values(),
).map((projectCity) => ({
  ...projectCity,
  neighborhoods: projectNeighborhoods.filter(
    (neighborhood) => getProjectHubCitySlug(neighborhood.projectCitySlug) === projectCity.slug,
  ),
}));
const title = `ساخت‌وساز ${city.title} | آمار، پروانه ساخت و فرصت فروش | پرشین‌سازه`;
const description = `${city.title}: تحلیل ساخت‌وساز، جمعیت، مسکن، پروانه‌های ساختمانی، ریسک زیرساختی، نکات فروش پروژه‌محور و لینک به مراحل ساخت و زمینه‌های کاری.`;
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: city.faqs.map((faq) => ({
    "@type": "Question",
    name: faq.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: faq.answer,
    },
  })),
};
const placeSchema = {
  "@context": "https://schema.org",
  "@type": "Place",
  name: city.title,
  address: {
    "@type": "PostalAddress",
    addressRegion: city.province,
    addressCountry: "IR",
  },
  description: city.summary,
  url: `${site.url}/cities/${city.slug}/`,
};
const neighborhoodItemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: `محله‌ها و محدوده‌های پروژه‌محور ${city.title}`,
  itemListElement: projectNeighborhoods.map((neighborhood, index) => ({
    "@type": "ListItem",
    position: index + 1,
    name: neighborhood.name,
    url: `${site.url}/projects/${getProjectHubCitySlug(neighborhood.projectCitySlug)}/${neighborhood.slug}/`,
    description: neighborhood.focus,
  })),
};
---

<BaseLayout title={title} description={description} canonicalPath={`/cities/${city.slug}/`}>
  <BreadcrumbSchema
    items={[
      { name: "شهرها", path: "/cities/" },
      { name: city.title, path: `/cities/${city.slug}/` },
    ]}
  />
  <main>
    <section class="content-hero city-file-hero">
      <div class="container content-hero-grid city-file-hero-grid">
        <div class="city-file-hero-copy">
          <nav class="breadcrumb" aria-label="مسیر صفحه">
            <a href="/cities/">شهرها</a>
            <span aria-hidden="true">›</span>
            <span>{city.title}</span>
          </nav>
          <p class="content-eyebrow">{city.province}</p>
          <h1>ساخت‌وساز {city.title}</h1>
          <p>{city.summary}</p>
          <div class="action-row">
            <a class="button button-primary" href="/#demo">درخواست دمو</a>
            <a class="button button-secondary" href="/cities/">همه شهرها</a>
          </div>
        </div>
        <aside class="content-summary-card city-pin-card">
          <span class="city-pin" aria-hidden="true">
            <span>{city.title}</span>
          </span>
          <strong>{city.title}</strong>
          <span>{city.province}</span>
          <p>{city.headline}</p>
        </aside>
      </div>
    </section>

    <section class="city-metric-band" aria-label={`شاخص‌های سریع ${city.title}`}>
      <div class="container">
        <div class="city-metric-grid">
          {city.keyMetrics.map((metric) => (
            <article>
              <strong>{metric.value}</strong>
              <span>{metric.label}</span>
              <p>{metric.note}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container detail-layout">
        <aside class="detail-sidebar city-file-sidebar">
          <h2>پرونده سریع {city.title}</h2>
          <dl class="compact-facts">
            {city.keyMetrics.slice(0, 4).map((metric) => (
              <div>
                <dt>{metric.label}</dt>
                <dd><strong>{metric.value}</strong> - {metric.note}</dd>
              </div>
            ))}
          </dl>

          <h2>مراحل ساخت مرتبط</h2>
          <ul class="link-list">
            {relatedStages.map((stage) => (
              <li><a href={`/construction-stages/${stage.slug}/`}>{stage.title}</a></li>
            ))}
          </ul>
        </aside>

        <article class="detail-main city-file-main">
          <section>
            <h2>نقش {city.title} در فروش پروژه‌محور</h2>
            <p>{city.role}</p>
          </section>

          {projectCityGroups.length > 0 && (
            <section>
              <h2>محله‌ها و محدوده‌های پروژه‌محور {city.title}</h2>
              <p>
                این خوشه‌ها مسیر ورود تامین‌کننده به بازار محلی را روشن می‌کنند: شهر یا کریدور، محله هدف، تیپ ساخت‌وساز و سیگنال‌های خرید هر پروژه.
              </p>
              <div class="project-city-grid city-project-cluster-grid">
                {projectCityGroups.map((projectCity) => (
                  <article class="project-city-card is-compact">
                    <p class="content-eyebrow">{projectCity.province}</p>
                    <h2>{projectCity.name}</h2>
                    <p>{projectCity.summary}</p>
                    <ul class="project-city-preview-list">
                      {projectCity.neighborhoods.slice(0, 8).map((neighborhood) => (
                        <li>
                          <a href={`/projects/${projectCity.slug}/${neighborhood.slug}/`}>{neighborhood.name}</a>
                        </li>
                      ))}
                    </ul>
                    <a class="text-link" href={`/projects/${projectCity.slug}/`}>
                      همه محدوده‌های {projectCity.name} →
                    </a>
                  </article>
                ))}
              </div>
            </section>
          )}

          {city.sections.map((section, index) => (
            <section class={index % 2 === 0 ? "city-narrative-panel" : "city-narrative-panel is-soft"}>
              <h2>{section.title}</h2>
              <p>{section.body}</p>
            </section>
          ))}

          <section>
            <h2>روند پروانه ساخت و سیگنال بازار</h2>
            <div class="city-timeline">
              {city.permitTimeline.map((item) => (
                <article>
                  <span>{item.period}</span>
                  <h3>{item.status}</h3>
                  <p>{item.interpretation}</p>
                </article>
              ))}
            </div>
          </section>

          <section>
            <h2>نکات مهم برای سازنده و تأمین‌کننده</h2>
            <div class="city-note-grid">
              {city.builderNotes.map((note) => (
                <blockquote>{note}</blockquote>
              ))}
            </div>
          </section>

          <section>
            <h2>اتصال {city.title} به مراحل و زمینه‌های کاری</h2>
            <div class="stage-fit-rail city-stage-rail" aria-label="مراحل ساخت مرتبط">
              {constructionStages.map((stage, index) => (
                <a
                  class={relatedStageIdSet.has(stage.id) ? "stage-fit-tile is-active" : "stage-fit-tile"}
                  href={`/construction-stages/${stage.slug}/`}
                >
                  <span>{String(index + 1).padStart(2, "0")}</span>
                  <strong>{stage.title}</strong>
                </a>
              ))}
            </div>
            <ul class="template-chip-list">
              {relatedFields.map((field) => (
                <li><a href={`/work-fields/${field.slug}/`}>{field.title}</a></li>
              ))}
            </ul>
          </section>

          <section>
            <h2>پرسش‌های رایج درباره ساخت‌وساز {city.title}</h2>
            <div class="faq-list">
              {city.faqs.map((faq) => (
                <details>
                  <summary>{faq.question}</summary>
                  <p>{faq.answer}</p>
                </details>
              ))}
            </div>
          </section>

          <section class="city-file-cta">
            <h2>پروژه‌های فعال {city.title} را زودتر ببینید</h2>
            <p>
              اگر فروش شما به مرحله ساخت، منطقه و زمان صدور پروانه وابسته است، پرونده شهری فقط گزارش نیست؛ نقشه اولویت تماس است.
            </p>
            <div class="action-row">
              <a class="button button-primary" href="/#demo">درخواست دمو</a>
              <a class="button button-secondary" href="/work-fields/">زمینه‌های کاری مرتبط</a>
            </div>
          </section>
        </article>
      </div>
    </section>
  </main>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(placeSchema)} />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(neighborhoodItemListSchema)} />
</BaseLayout>
