---
import BaseLayout from "@/layouts/BaseLayout.astro";
import BreadcrumbSchema from "@/components/BreadcrumbSchema.astro";
import { absoluteUrl, site } from "@/content/home";
import { cityProfiles } from "@/content/cities";
import { getProjectNeighborhoodsByCoverageCity } from "@/content/neighborhoods";

const title = "شهرهای پوشش پرشین‌سازه | تهران، کرج و لواسان";
const description =
  "صفحات شهری پرشین‌سازه برای تحلیل ساخت‌وساز تهران، کرج و لواسان: جمعیت، مسکن، پروانه ساخت، زیرساخت، ریسک شهری و فرصت فروش پروژه‌محور.";
const cityCards = cityProfiles.map((city) => ({
  ...city,
  projectNeighborhoods: getProjectNeighborhoodsByCoverageCity(city.slug),
}));
const projectNeighborhoodCount = cityCards.reduce((total, city) => total + city.projectNeighborhoods.length, 0);
const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: title,
    description,
    url: absoluteUrl("/cities/"),
    inLanguage: "fa-IR",
    isPartOf: { "@type": "WebSite", name: site.name, url: site.url },
  },
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    name: "فهرست شهرهای پوشش پرشین‌سازه",
    itemListElement: cityCards.map((city, index) => ({
      "@type": "ListItem",
      position: index + 1,
      name: city.title,
      url: absoluteUrl(`/cities/${city.slug}/`),
      description: city.summary,
    })),
  },
];
---

<BaseLayout title={title} description={description} canonicalPath="/cities/" structuredData={structuredData}>
  <BreadcrumbSchema items={[{ name: "شهرها", path: "/cities/" }]} />
  <main>
    <section class="content-hero city-index-hero">
      <div class="container content-hero-grid">
        <div>
          <p class="content-eyebrow">شهرها</p>
          <h1>ساخت‌وساز را شهر به شهر بخوانید</h1>
          <p>
            تهران، کرج و لواسان یک شبکه واحد اما سه بازار متفاوت‌اند. این صفحات برای SEO و AEO، داده‌های جمعیتی،
            مسکن، پروانه ساخت، ریسک زیرساختی و فرصت فروش پروژه‌محور هر شهر را جدا می‌کنند.
          </p>
          <div class="action-row">
            <a class="button button-primary" href="/#demo">درخواست دمو</a>
            <a class="button button-secondary" href="/construction-stages/">مشاهده مراحل ساخت</a>
          </div>
        </div>
        <aside class="content-summary-card city-index-summary">
          <strong>{projectNeighborhoodCount}</strong>
          <span>محله و محدوده پروژه‌محور</span>
          <p>تهران، کرج و لواسان با اتصال مستقیم به خوشه‌های محله‌ای و صفحه‌های پروژه</p>
        </aside>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="content-card-grid city-file-card-grid">
          {cityCards.map((city) => (
            <article class="content-card city-file-card">
              <span class="city-card-pin" aria-hidden="true"></span>
              <p class="content-eyebrow">{city.province}</p>
              <h2>{city.title}</h2>
              <p><strong>{city.headline}</strong></p>
              <p>{city.summary}</p>
              <dl class="compact-facts city-card-metrics">
                {city.keyMetrics.slice(0, 3).map((metric) => (
                  <div>
                    <dt>{metric.label}</dt>
                    <dd><strong>{metric.value}</strong><span>{metric.note}</span></dd>
                  </div>
                ))}
                <div>
                  <dt>خوشه محله‌ای</dt>
                  <dd><strong>{city.projectNeighborhoods.length}</strong><span>صفحه پروژه‌محور متصل به این شهر</span></dd>
                </div>
              </dl>
              <a class="text-link" href={`/cities/${city.slug}/`}>مشاهده صفحه شهر ←</a>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
