---
import BaseLayout from "@/layouts/BaseLayout.astro";
import BreadcrumbSchema from "@/components/BreadcrumbSchema.astro";
import ProductHeroFlow from "@/components/ProductHeroFlow.astro";
import ProductFlowLive from "@/components/ProductFlowLive.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import { absoluteUrl, site } from "@/content/home";

const title = "محصول پرشین‌سازه | زیرساخت فروش پروژه‌محور ساختمان";
const description =
  "پرشین‌سازه داده زنده پروژه‌های ساختمانی، نقشه، فیلتر، CRM، پیامک هدفمند، آموزش و تصمیم‌یار فروش را برای تامین‌کنندگان صنعت ساختمان در یک سیستم واحد ترکیب می‌کند.";

const productPillars = [
  {
    title: "داده زنده",
    body: "پروژه فقط یک شماره تماس نیست؛ موقعیت، مرحله ساخت، تصویر، مسیر ارتباطی، تاریخ به‌روزرسانی و وضعیت اقدام فروش کنار هم دیده می‌شوند.",
  },
  {
    title: "ابزار اجرایی",
    body: "نقشه، فیلتر، صفحه پروژه، CRM، پیامک هدفمند، یادداشت و یادآور کمک می‌کنند داده به اقدام فروش تبدیل شود.",
  },
  {
    title: "آموزش استفاده",
    body: "کاربر باید بداند کدام مرحله برای محصولش مهم است، چه زمانی تماس بگیرد و چطور فرصت را پیگیری کند.",
  },
  {
    title: "تصمیم‌یار",
    body: "لایه هوشمند باید فاصله میان داده پروژه و تصمیم فروش را کوتاه کند؛ نه اینکه جای قضاوت تیم فروش را بگیرد.",
  },
];

const marketProblems = [
  "پروژه‌های در حال ساخت در سطح شهر پخش‌اند و دید زنده و متمرکز از آن‌ها وجود ندارد.",
  "بسیاری از اطلاعات بازار ناقص، قدیمی، عمومی یا فاقد مرحله ساخت و مسیر اقدام‌اند.",
  "هر محصول ساختمانی پنجره فروش محدود دارد؛ تماس دیر یا زود می‌تواند فرصت را بسوزاند.",
];

const workflow = [
  "پروژه مناسب بر اساس شهر، مرحله، مقیاس و تناسب محصول پیدا می‌شود.",
  "تیم فروش تشخیص می‌دهد الان زمان معرفی، تماس، پیامک یا رصد است.",
  "مسیر ارتباطی مناسب انتخاب می‌شود و تماس کور جای خود را به اقدام زمینه‌دار می‌دهد.",
  "نتیجه تماس، یادداشت، وضعیت فرصت و پیگیری بعدی کنار همان پروژه ثبت می‌شود.",
];

const executionTools = [
  {
    title: "نقشه",
    body: "بازار پراکنده ساختمان را به تصویر قابل تصمیم تبدیل می‌کند؛ منطقه هدف، تراکم فرصت و مسیر بازدید روشن‌تر می‌شود.",
  },
  {
    title: "فیلترها",
    body: "اطلاعات زیاد را بر اساس مرحله ساخت، محدوده جغرافیایی، متراژ، وضعیت و تازگی به فرصت‌های مرتبط تبدیل می‌کنند.",
  },
  {
    title: "صفحه پروژه",
    body: "تصمیم سریع را ممکن می‌کند: آیا این پروژه فعال، مرتبط، قابل پیگیری و ارزشمند است یا نه.",
  },
  {
    title: "CRM و پیگیری",
    body: "پروژه را از یک رکورد قابل مشاهده به فرصت فروش قابل مدیریت تبدیل می‌کند.",
  },
  {
    title: "پیامک هدفمند",
    body: "مکمل تماس و پیگیری است؛ ارزش آن در تناسب پیام با مرحله، منطقه و زمینه پروژه است.",
  },
];

const goldenWindow = [
  {
    label: "مرحله ساخت",
    body: "پروژه از نظر فیزیکی کجای چرخه ساخت است.",
  },
  {
    label: "زمان اجرا",
    body: "محصول یا خدمت چه زمانی وارد پروژه می‌شود.",
  },
  {
    label: "زمان فروش",
    body: "تامین‌کننده چه زمانی باید وارد معرفی، مذاکره یا پیگیری شود.",
  },
];

const moatItems = [
  "داده میدانی زنده و به‌روزرسانی مستمر",
  "تصویر و اعتبارسنجی پروژه",
  "طبقه‌بندی مرحله ساخت و تناسب با محصول",
  "ابزارهای اجرایی متصل به فروش",
  "آموزش، CRM، پیامک و رفتار استفاده مداوم",
  "لایه هوشمند مبتنی بر داده اختصاصی",
];

const persianStepNumbers = ["۰۱", "۰۲", "۰۳", "۰۴", "۰۵", "۰۶"];
const productPillarIcons = [
  '<ellipse cx="12" cy="5" rx="7" ry="3"></ellipse><path d="M5 5v6c0 1.66 3.13 3 7 3s7-1.34 7-3V5"></path><path d="M5 11v6c0 1.66 3.13 3 7 3s7-1.34 7-3v-6"></path>',
  '<rect x="4" y="5" width="6" height="6" rx="1.5"></rect><rect x="14" y="13" width="6" height="6" rx="1.5"></rect><path d="M10 8h3.2c1.55 0 2.8 1.25 2.8 2.8V13"></path><path d="M14 16h-3.2A2.8 2.8 0 0 1 8 13.2V11"></path>',
  '<path d="M4 6.5A2.5 2.5 0 0 1 6.5 4H11v15H6.5A2.5 2.5 0 0 0 4 21.5z"></path><path d="M20 6.5A2.5 2.5 0 0 0 17.5 4H13v15h4.5A2.5 2.5 0 0 1 20 21.5z"></path><path d="m15.3 10.8 1.2 1.2 2.2-2.5"></path>',
  '<path d="M4 14a8 8 0 0 1 16 0"></path><path d="M7 14a5 5 0 0 1 10 0"></path><path d="M12 14l4-5"></path><path d="M9 20h6"></path>',
];

const structuredData = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "پرشین‌سازه",
  applicationCategory: "BusinessApplication",
  operatingSystem: "Web",
  url: absoluteUrl("/product/"),
  inLanguage: "fa-IR",
  description,
  publisher: { "@type": "Organization", name: site.name, url: site.url },
  featureList: executionTools.map((item) => item.title),
};
---

<BaseLayout title={title} description={description} canonicalPath="/product/" structuredData={structuredData}>
  <BreadcrumbSchema items={[{ name: "محصول", path: "/product/" }]} />
  <main class="product-system-page">
    <section class="content-hero product-system-hero">
      <div class="container product-system-hero-grid">
        <h1>زیرساخت فروش پروژه‌محور برای تامین‌کنندگان صنعت ساختمان</h1>
        <div class="product-hero-stage">
          <ProductHeroFlow />
        </div>
        <p>
          پرشین‌سازه پروژه‌های ساختمانی زنده را به فرصت‌های فروش قابل شناسایی، قابل ارزیابی، قابل ارتباط و قابل
          پیگیری تبدیل می‌کند.
        </p>
        <div class="action-row">
          <a class="button button-primary" href="/#demo">درخواست دمو</a>
          <a class="button button-secondary" href="#workflow">دیدن جریان محصول</a>
        </div>
      </div>
    </section>

    <section class="section product-problem-section">
      <div class="container product-two-column">
        <SectionHeader
          kicker="چرا پرشین‌سازه"
          title="مسئله محصول، پیدا کردن مشتری نیست؛ پیدا کردن زمان درست اقدام است."
          lede="فروش در بازار ساختمان به کیفیت محصول و مهارت مذاکره محدود نیست. تامین‌کننده باید پروژه مناسب را قبل از بسته شدن فرصت ببیند، مرحله ساخت را بفهمد، مسیر ارتباطی درست را پیدا کند و پیگیری را از حافظه فردی خارج کند."
        />
        <ul class="business-friction-list">
          {
            marketProblems.map((item) => (
              <li>
                <p>{item}</p>
              </li>
            ))
          }
        </ul>
      </div>
    </section>

    <section class="section product-architecture-section">
      <div class="container">
        <SectionHeader
          kicker="معماری محصول"
          title="چهار لایه محصول"
          lede="ارزش پرشین‌سازه از ترکیب این لایه‌ها ساخته می‌شود؛ نه از یک فایل شماره تماس یا CRM عمومی."
        />
        <div class="product-pillar-track">
          {productPillars.map((item, index) => (
            <article class="product-pillar-node">
              <div class="product-pillar-heading">
                <svg class="product-pillar-icon" viewBox="0 0 24 24" aria-hidden="true" set:html={productPillarIcons[index]}></svg>
                <h3>{item.title}</h3>
              </div>
              <p>{item.body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="workflow" class="section product-flow-section">
      <div class="container product-workflow-panel">
        <div class="section-heading">
          <h2>جریان عملیاتی محصول</h2>
          <p>workflow واقعی کاربر باید از جست‌وجو شروع شود و به ثبت نتیجه و پیگیری بعدی برسد.</p>
        </div>
        <div class="product-flow-frame">
          <ProductFlowLive />
        </div>
        <ol class="product-workflow-list">
          {workflow.map((item, index) => (
            <li>
              <span>{String(index + 1).padStart(2, "0")}</span>
              <p>{item}</p>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <section class="section product-window-section">
      <div class="container">
        <SectionHeader
          kicker="زمان‌بندی فروش"
          title="پنجره طلایی فروش"
          lede="مرحله ساخت مهم است، اما کافی نیست. محصول باید بین وضعیت فیزیکی پروژه، زمان اجرا و زمان درست ورود فروشنده تفاوت بگذارد."
          align="center"
        />
        <div class="golden-window-grid">
          {
            goldenWindow.map((item, index) => (
              <article>
                <span class="golden-window-step-index" aria-hidden="true">
                  {persianStepNumbers[index]}
                </span>
                <strong>{item.label}</strong>
                <p>{item.body}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section id="features" class="section product-tools-section">
      <div class="container">
        <SectionHeader
          kicker="جعبه‌ابزار اجرایی"
          title="ابزارهای اجرایی فروش"
          lede="داده بدون ابزار اجرایی فقط اطلاعات است. این ابزارها پروژه را به فرصت قابل اقدام تبدیل می‌کنند."
        />
        <div class="execution-tool-grid">
          {executionTools.map((item) => (
            <article class="execution-tool-card">
              <h3>{item.title}</h3>
              <p>{item.body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section product-moat-section">
      <div class="container">
        <SectionHeader
          kicker="خندق دفاعی"
          title="مزیت قابل دفاع پرشین‌سازه"
          lede="رقیب می‌تواند سایت، چند فیلتر یا CRM ساده بسازد؛ اما ساختن ماشین زنده تولید، کنترل، به‌روزرسانی و تبدیل داده به رفتار فروش بسیار سخت‌تر است."
        />
        <ul class="moat-list">
          {
            moatItems.map((item) => (
              <li>
                <span class="moat-check" aria-hidden="true"></span>
                <p>{item}</p>
              </li>
            ))
          }
        </ul>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="product-final-cta">
          <SectionHeader
            kicker="قدم بعدی"
            title="محصول را در مسیر واقعی فروش ببینید"
            lede="در دمو، از پیدا کردن پروژه تا ثبت پیگیری بعدی را روی یک سناریوی واقعی فروش پروژه‌محور مرور می‌کنیم."
            align="center"
          />
          <div class="action-row centered-actions">
            <a class="button button-primary" href="/#demo">ثبت درخواست دمو</a>
            <a class="button button-secondary" href="/education/">نقش آموزش در محصول</a>
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  /* جزیره تیره ۱ — زمینه #1A1714 لازم است: لایه نور کامپوننت mix-blend-mode:screen دارد و فقط روی تیره می‌درخشد */
  .product-flow-section.section {
    background: #1a1714;
    border-top-color: rgba(232, 168, 124, 0.18);
  }

  .product-flow-section .product-workflow-panel {
    max-width: 70rem;
    border-color: rgba(232, 168, 124, 0.28);
    background: linear-gradient(145deg, rgba(192, 87, 59, 0.14), rgba(26, 23, 20, 0));
    padding: clamp(1rem, 2vw, 1.6rem);
    box-shadow: none;
  }

  .product-flow-section .section-heading {
    margin-block-end: var(--space-4);
  }

  .product-flow-section .section-heading h2 {
    font-size: clamp(var(--text-2xl), 3vw, var(--text-3xl));
    color: #f7ede2;
  }

  .product-flow-section .section-heading p {
    color: rgba(247, 237, 226, 0.72);
  }

  /* ظرف بیرونی: فقط اندازه و گوشه‌گرد — کامپوننت خودش border-radius:inherit دارد */
  .product-flow-frame {
    max-width: 64rem;
    margin-inline: auto;
    border-radius: var(--radius-lg);
  }

  @media (min-width: 768px) {
    .product-flow-frame {
      position: relative;
      overflow: hidden;
      aspect-ratio: auto;
    }

    .product-flow-frame::before {
      display: block;
      padding-block-start: calc(650 / 1672 * 100%);
      content: "";
    }

    .product-flow-frame :global(.pf-root) {
      position: absolute;
      inset: 0;
    }

    .product-flow-frame :global(.pf-desktop) {
      position: absolute;
      inset: 0;
      overflow: hidden;
    }

    .product-flow-frame :global(.pf-desktop img),
    .product-flow-frame :global(.pf-desktop .fx) {
      position: absolute;
      inset-block-start: 50%;
      inset-block-end: auto;
      inset-inline: 0;
      inline-size: 100%;
      block-size: auto;
      aspect-ratio: 1672 / 941;
      transform: translateY(-50%);
    }
  }

  .product-flow-section .product-workflow-list {
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: var(--space-3);
    max-width: 64rem;
    margin: var(--space-4) auto 0;
  }

  .product-flow-section .product-workflow-list li {
    min-height: 0;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-4);
  }

  .product-flow-section .product-workflow-list span {
    font-size: var(--text-md);
  }

  .product-flow-section .product-workflow-list p {
    font-size: var(--text-sm);
    line-height: var(--leading-normal);
  }

  @media (max-width: 900px) {
    .product-flow-section .product-workflow-list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 720px) {
    .product-flow-section .product-workflow-panel {
      max-width: none;
      padding: var(--space-4);
    }

    .product-flow-frame {
      max-width: 100%;
    }

    .product-flow-section .product-workflow-list {
      grid-template-columns: 1fr;
    }
  }
</style>
