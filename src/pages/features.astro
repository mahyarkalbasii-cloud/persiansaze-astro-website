---
import { absoluteUrl, site } from "@/content/home";

const targetPath = "/product/#features";
const targetUrl = absoluteUrl(targetPath);
---

<!doctype html>
<html lang="fa-IR" dir="rtl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta http-equiv="refresh" content={`0; url=${targetPath}`} />
    <link rel="canonical" href={absoluteUrl("/product/")} />
    <title>ویژگی‌های پرشین‌سازه | انتقال به محصول</title>
    <meta
      name="description"
      content="صفحه ویژگی‌ها با صفحه محصول پرشین‌سازه ادغام شده است."
    />
    <script is:inline>
      window.location.replace("/product/#features");
    </script>
  </head>
  <body>
    <main style="font-family: sans-serif; padding: 2rem; text-align: center;">
      <p>صفحه ویژگی‌ها با صفحه محصول {site.name} ادغام شده است.</p>
      <a href={targetUrl}>مشاهده محصول و ویژگی‌ها</a>
    </main>
  </body>
</html>
