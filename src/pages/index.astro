---
import "../styles/global.css";
import SiteFooter from "@/components/SiteFooter.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import PersianDigitsScript from "@/components/PersianDigitsScript.astro";
import HeroRouteMap from "@/components/HeroRouteMap.astro";
import {
  audiences,
  demo,
  faqSection,
  faqs,
  hero,
  ids,
  metadata,
  pricing,
  problem,
  salesFlow,
  site,
  solution,
} from "@/content/home";
import { constructionStages, workFields } from "@/content/construction";
import { saleTypes } from "@/content/sales";

const primaryContact = site.contacts[0];
const defaultDuration = "3" as const;
const homeConstructionStages = constructionStages.filter((stage) => stage.id !== "permit-design");
const toPersianDigits = (value: string | number) => String(value).replace(/\d/g, (digit) => "۰۱۲۳۴۵۶۷۸۹"[Number(digit)]);
const homeStageCards = homeConstructionStages.map((stage, index) => ({
  title: stage.title,
  indexLabel: toPersianDigits(index + 1),
  sourcePhase: toPersianDigits(stage.sourcePhase),
  summary: toPersianDigits(stage.summary),
  href: `/construction-stages/${stage.slug}/`,
}));
const initialHomeStage = homeStageCards[0];
const audienceIconPaths: Record<string, string[]> = {
  "transactional-selling": [
    "M5 12h14",
    "m14 12-4-4",
    "m19 12-4 4",
    "M8 5h8",
    "M8 19h8",
  ],
  "consultative-selling": [
    "M6.5 15.5h-.9a2.6 2.6 0 0 1-2.6-2.6V7.6A2.6 2.6 0 0 1 5.6 5h8.8A2.6 2.6 0 0 1 17 7.6v5.3a2.6 2.6 0 0 1-2.6 2.6h-4.1L6.5 19v-3.5Z",
    "M17.5 9h.9a2.6 2.6 0 0 1 2.6 2.6v4.8a2.6 2.6 0 0 1-2.6 2.6h-.9v2.5L15 19h-3.5",
  ],
  "hybrid-sales": [
    "M5 7.5h5.5v5.5H5z",
    "M13.5 11 19 5.5",
    "M15.2 5.5H19v3.8",
    "M13.5 16.5H19V22h-5.5z",
    "M8 13v3.5h5.5",
  ],
  "barter-materials-services": [
    "M7 8h10",
    "m17 8-3-3",
    "m17 8-3 3",
    "M17 16H7",
    "m7 16 3-3",
    "m7 16 3 3",
    "M4.5 12a7.5 7.5 0 0 1 13-5",
    "M19.5 12a7.5 7.5 0 0 1-13 5",
  ],
};
const demoWorkFieldOptions = workFields.map((field) => field.title);
const coverageDots = Array.from({ length: 4 }, (_, index) => index);
const toNumericPrice = (value: string) =>
  Number(
    String(value)
      .replace(/[۰-۹]/g, (digit) => String("۰۱۲۳۴۵۶۷۸۹".indexOf(digit)))
      .replace(/[٠-٩]/g, (digit) => String("٠١٢٣٤٥٦٧٨٩".indexOf(digit)))
      .replace(/[^\d]/g, ""),
  );
const getPlanPrice = (prices: Record<string, string>, durationId: string) => prices[durationId] ?? "";
const durationSavings = pricing.durations.reduce<Record<string, number | null>>((acc, duration) => {
  if (duration.id === defaultDuration) {
    acc[duration.id] = null;
    return acc;
  }

  const months = Number(duration.id);
  const baseMonths = Number(defaultDuration);
  const savings = pricing.plans
    .map((plan) => {
      const basePrice = toNumericPrice(getPlanPrice(plan.prices, defaultDuration)) * (months / baseMonths);
      const durationPrice = toNumericPrice(getPlanPrice(plan.prices, duration.id));

      if (!basePrice || !durationPrice || durationPrice >= basePrice) return null;
      return Math.round((1 - durationPrice / basePrice) * 100);
    })
    .filter((saving): saving is number => saving !== null);
  const uniqueSavings = [...new Set(savings)];

  acc[duration.id] = savings.length === pricing.plans.length && uniqueSavings.length === 1 ? uniqueSavings[0] : null;
  return acc;
}, {});
const orderedFaqs = [faqs[0], faqs[1], faqs[3], faqs[2], faqs[4], faqs[7], faqs[8], faqs[9], faqs[10], faqs[11], faqs[12], faqs[6], faqs[5]].filter(
  (item): item is (typeof faqs)[number] => Boolean(item),
);
const cfBeaconToken = import.meta.env.PUBLIC_CF_BEACON_TOKEN;
const canonicalOrigin = new URL(site.url).origin;
const homeOgImageUrl = new URL("/assets/company/og-home.jpg", canonicalOrigin).href;
const salesPipelineCardSets = [
  {
    count: "ورودی خام",
    cards: [
      { title: "پروژه‌های هم‌خوان", detail: "جست‌وجو بر اساس موقعیت، مرحله ساخت و نیاز" },
      { title: "نیاز نزدیک", detail: "تشخیص ارتباط پروژه با محصول یا خدمت شما" },
      { title: "داده تازه", detail: "بررسی وضعیت فعال بودن و زمان مناسب اقدام" },
      { title: "دسترسی تماس", detail: "آماده‌سازی مسیر شروع ارتباط با پروژه" },
    ],
  },
  {
    count: "فرصت‌های منتخب",
    cards: [
      { title: "کوتاه‌لیست اولیه", detail: "تفکیک پروژه‌های مرتبط از داده‌های پراکنده" },
      { title: "آمادگی اقدام", detail: "مرتب‌سازی بر اساس زمان، مرحله و تناسب" },
      { title: "اولویت فروش", detail: "تمرکز روی فرصت‌هایی که ارزش پیگیری دارند" },
    ],
  },
  {
    count: "مذاکره‌های فعال",
    cards: [
      { title: "تماس هدفمند", detail: "شروع ارتباط در زمان درست و با زمینه روشن" },
      { title: "پیگیری زمان‌دار", detail: "ثبت قدم بعدی فروش و نگه داشتن ریتم مذاکره" },
    ],
  },
  {
    count: "تبدیل نهایی",
    cards: [{ title: "قرارداد پایدار", detail: "فرصت تبدیل‌شده به رابطه قابل ادامه" }],
  },
];
const salesPipelineStages = salesFlow.stages.map((stage, index) => ({
  ...stage,
  count: salesPipelineCardSets[index]?.count ?? "",
  cards: salesPipelineCardSets[index]?.cards ?? [],
}));
const schemaGraph = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "@id": ids.organization,
    name: site.name,
    legalName: site.legalName,
    alternateName: site.alternateName,
    url: site.url,
    description: site.description,
    foundingDate: site.foundingDate,
    email: site.email,
    telephone: primaryContact.telephone,
    address: {
      "@type": "PostalAddress",
      ...site.postalAddress,
    },
    contactPoint: site.contacts.map((contact) => ({
      "@type": "ContactPoint",
      name: contact.label,
      telephone: contact.telephone,
      contactType: contact.contactType,
      areaServed: "IR",
      availableLanguage: ["fa-IR", "Persian"],
    })),
    sameAs: site.sameAs,
  },
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "@id": ids.localBusiness,
    additionalType: "https://schema.org/ProfessionalService",
    name: site.name,
    legalName: site.legalName,
    alternateName: site.alternateName,
    description: site.description,
    url: site.url,
    telephone: primaryContact.telephone,
    email: site.email,
    priceRange: "$$",
    address: {
      "@type": "PostalAddress",
      ...site.postalAddress,
    },
    openingHours: site.openingHours,
    openingHoursSpecification: site.openingHoursSpecification.map((item) => ({
      "@type": "OpeningHoursSpecification",
      ...item,
    })),
    areaServed: site.areaServed.map((name) => ({
      "@type": "City",
      name,
    })),
    parentOrganization: { "@id": ids.organization },
    sameAs: site.sameAs,
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "@id": ids.website,
    name: site.name,
    url: site.url,
    inLanguage: "fa-IR",
    publisher: { "@id": ids.organization },
  },
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    name: metadata.pageName,
    url: site.url,
    inLanguage: "fa-IR",
    isPartOf: { "@id": ids.website },
    publisher: { "@id": ids.organization },
    description: metadata.pageDescription,
    about: ["پروژه‌های ساختمانی", "نقشه پروژه‌ها", "مرحله ساخت", "فروش پروژه‌محور", "پیگیری فروش"].map((name) => ({
      "@type": "Thing",
      name,
    })),
  },
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "@id": ids.software,
    name: site.name,
    applicationCategory: "BusinessApplication",
    operatingSystem: "Web",
    url: site.url,
    inLanguage: "fa-IR",
    description: site.description,
    publisher: { "@id": ids.organization },
    offers: {
      "@type": "Offer",
      priceCurrency: "IRR",
      availability: "https://schema.org/InStock",
      url: `${site.url}/subscriptions/`,
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: orderedFaqs.map((item) => ({
      "@type": "Question",
      name: item.question,
      acceptedAnswer: {
        "@type": "Answer",
        text: item.answer,
      },
    })),
  },
];
---

<!doctype html>
<html lang="fa-IR" dir="rtl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{metadata.title}</title>
    <meta name="description" content={metadata.description} />
    <meta name="keywords" content={metadata.keywords.join(", ")} />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <link rel="canonical" href={site.url} />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="64x64" href="/favicon-64.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="fa_IR" />
    <meta property="og:url" content={site.url} />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={metadata.title} />
    <meta property="og:description" content={metadata.description} />
    <meta property="og:image" content={homeOgImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="پرشین‌سازه - زیرساخت فروش پروژه‌محور" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={homeOgImageUrl} />
    <meta name="twitter:title" content={metadata.title} />
    <meta name="twitter:description" content={metadata.description} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(schemaGraph)} />
  </head>
  <body class="home-color-anthropic">
    <SiteHeader home />

    <main class="home-page">
      <section id="hero" class="hero">
        <div class="container hero-grid">
          <div class="hero-title-block">
            <h1>
              <span>{hero.titleLines[0]}</span>
              <span>{hero.titleLines[1]}</span>
            </h1>
          </div>

          <div class="hero-detail-block">
            <p>{hero.body}</p>
            <div class="action-row hero-action-row">
              <a class="button button-primary hero-demo-cta" href="#demo">{hero.demoCta}</a>
              <a class="button button-secondary hero-projects-cta" href="/cities/">{hero.secondaryCta}</a>
            </div>
            <p class="hero-trust-line">
              <span class="hero-trust-dot" aria-hidden="true"></span>
              پوشش میدانی تهران، کرج و لواسان
            </p>
          </div>

          <div class="media-placeholder hero-placeholder hero-bento">
            <div class="hero-bento-scene" data-anim-scope>
              <HeroRouteMap alt={hero.placeholder} />
            </div>
          </div>
        </div>
      </section>

      <section id="problem" class="section problem-section">
        <div class="container two-column">
          <div class="section-copy problem-copy">
            <h2 aria-label={problem.title}>
              {problem.titleLines.map((line) => (
                <span>{line}</span>
              ))}
            </h2>
            <p>{problem.body}</p>
            <div class="action-row">
              <a class="button button-secondary" href="#solution">{problem.cta}</a>
            </div>
          </div>
        </div>
      </section>

      <section id="solution" class="section">
        <div class="container">
          <div class="section-heading">
            <h2>{solution.title}</h2>
            <p>{solution.body}</p>
          </div>

          <div class="solution-showcase">
            <div class="solution-main-row">
              <figure class="solution-visual-card">
                <iframe
                  class="home-interactive-visual solution-dashboard-visual"
                  src="/assets/company/interactive/dashboard-animated.html"
                  title={solution.visualAlt}
                  width="1254"
                  height="1254"
                  loading="lazy"
                  referrerpolicy="no-referrer"
                  sandbox=""
                ></iframe>
              </figure>

              <section class="solution-data-panel" aria-labelledby="solution-data-title">
                <h3 id="solution-data-title">{solution.dataTitle}</h3>
                <div class="solution-data-grid">
                  {solution.dataCards.map((card) => (
                    <article>
                      <h4>{card.title}</h4>
                      <p>{card.body}</p>
                    </article>
                  ))}
                </div>
              </section>
            </div>

            <section class="solution-stack-panel" aria-labelledby="solution-stack-title">
              <h3 id="solution-stack-title">{solution.stackTitle}</h3>
              <div class="feature-strip solution-feature-strip">
                {solution.features.map((feature) => (
                  <article>
                    <span>{feature.label}</span>
                    <h4>{feature.title}</h4>
                    <p>{feature.body}</p>
                  </article>
                ))}
              </div>
            </section>
          </div>
        </div>
      </section>

      <section id="audiences" class="section">
        <div class="container">
          <div class="section-heading">
            <h2>{audiences.title}</h2>
            <p>{audiences.body}</p>
          </div>

          <div class="audience-grid">
            {saleTypes.map((item) => (
              <a class="audience-card" href={`/sale-types/${item.slug}/`} aria-label={`مشاهده جزئیات ${item.title}`}>
                <span class="audience-card-icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none">
                    {(audienceIconPaths[item.slug] ?? audienceIconPaths["hybrid-sales"]).map((path) => (
                      <path d={path} />
                    ))}
                  </svg>
                </span>
                <h3>{item.title}</h3>
                <p>{item.summary}</p>
                <span class="text-link">مشاهده جزئیات ←</span>
              </a>
            ))}
          </div>
        </div>
      </section>

      <section id="stages" class="section" aria-label="مراحل ساخت" data-stage-rotation data-anim-scope>
        <div class="container">
          <div class="section-heading stages-heading">
            <h2>هر محصول، در یک مرحله از ساخت فروش می‌رود</h2>
            <p>هشت مرحله ساخت را بشناسید و بدانید مشتری شما در کدام مرحله تصمیم می‌گیرد.</p>
          </div>

          <div class="stage-rail-wrap">
            <div class="stage-rail" role="tablist" aria-label="مراحل ساخت">
              {homeStageCards.map((stage, index) => (
                <button
                  class={index === 0 ? "stage-tile active" : "stage-tile"}
                  type="button"
                  role="tab"
                  aria-selected={index === 0 ? "true" : "false"}
                  aria-controls="stage-info-panel"
                  data-stage-index={index}
                >
                  <span class="stage-tile-number">{stage.indexLabel}</span>
                  <strong>{stage.title}</strong>
                </button>
              ))}
            </div>
          </div>

          <article class="stage-info-card" id="stage-info-panel" aria-live="polite" data-stage-panel>
            <div class="stage-info-copy">
              <h3 data-stage-title>{initialHomeStage.title}</h3>
              <p data-stage-summary>{initialHomeStage.summary}</p>
            </div>
            <div class="stage-info-side">
              <span>زمان تصمیم‌گیری سازنده</span>
              <p data-stage-source>{initialHomeStage.sourcePhase}</p>
              <a class="button button-primary" data-stage-link href={initialHomeStage.href}>مشاهده اطلاعات بیشتر</a>
            </div>
          </article>
        </div>
        <script is:inline type="application/json" id="home-stage-data" set:html={JSON.stringify(homeStageCards)} />
        <script is:inline>
          (() => {
            const root = document.querySelector("[data-stage-rotation]");
            const dataNode = document.getElementById("home-stage-data");
            if (!root || !dataNode) return;

            const stages = JSON.parse(dataNode.textContent || "[]");
            const buttons = [...root.querySelectorAll("[data-stage-index]")];
            const panel = root.querySelector("[data-stage-panel]");
            const title = root.querySelector("[data-stage-title]");
            const summary = root.querySelector("[data-stage-summary]");
            const source = root.querySelector("[data-stage-source]");
            const link = root.querySelector("[data-stage-link]");
            const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
            let activeIndex = 0;
            let timerId = null;
            let changeTimeoutId = null;
            let resizeTimeoutId = null;

            const renderStage = (stage) => {
              if (title) title.textContent = stage.title;
              if (summary) summary.textContent = stage.summary;
              if (source) source.textContent = stage.sourcePhase;
              if (link) link.setAttribute("href", stage.href);
            };

            const syncPanelHeight = () => {
              if (!panel || stages.length === 0) return;

              const currentStage = stages[activeIndex] ?? stages[0];
              const previousTransition = panel.style.transition;
              panel.style.transition = "none";
              panel.style.minHeight = "";

              const maxHeight = stages.reduce((height, stage) => {
                renderStage(stage);
                return Math.max(height, Math.ceil(panel.getBoundingClientRect().height));
              }, 0);

              renderStage(currentStage);
              panel.style.minHeight = `${maxHeight}px`;
              window.requestAnimationFrame(() => {
                panel.style.transition = previousTransition;
              });
            };

            const selectStage = (index, animate = true) => {
              const stage = stages[index];
              if (!stage) return;

              activeIndex = index;
              buttons.forEach((button, buttonIndex) => {
                const isActive = buttonIndex === index;
                button.classList.toggle("active", isActive);
                button.setAttribute("aria-selected", isActive ? "true" : "false");
              });

              if (!panel || !animate || reduceMotion) {
                if (changeTimeoutId) window.clearTimeout(changeTimeoutId);
                panel?.classList.remove("is-changing");
                renderStage(stage);
                return;
              }

              if (changeTimeoutId) window.clearTimeout(changeTimeoutId);
              panel.classList.add("is-changing");
              changeTimeoutId = window.setTimeout(() => {
                renderStage(stage);
                panel.classList.remove("is-changing");
                changeTimeoutId = null;
              }, 100);
            };

            const startRotation = () => {
              if (timerId) window.clearInterval(timerId);
              if (stages.length > 1) {
                /* sync: stage rotation 10s */
                timerId = window.setInterval(() => {
                  selectStage((activeIndex + 1) % stages.length);
                }, 10000);
              }
            };

            root.addEventListener("anim:pause", () => {
              if (timerId) {
                window.clearInterval(timerId);
                timerId = null;
              }
            });
            root.addEventListener("anim:resume", startRotation);

            buttons.forEach((button) => {
              button.addEventListener("click", () => {
                selectStage(Number(button.dataset.stageIndex));
                startRotation();
              });
            });

            if ("fonts" in document && document.fonts.ready) {
              document.fonts.ready.then(syncPanelHeight);
            } else {
              syncPanelHeight();
            }

            window.addEventListener(
              "resize",
              () => {
                if (resizeTimeoutId) window.clearTimeout(resizeTimeoutId);
                resizeTimeoutId = window.setTimeout(syncPanelHeight, 140);
              },
              { passive: true },
            );

            startRotation();
          })();
        </script>
      </section>

      <section id="sales-flow" class="section">
        <div class="container">
          <div class="section-heading">
            <h2>{salesFlow.title}</h2>
            <p>{salesFlow.subtitle}</p>
          </div>

          <div class="sales-pipeline" role="list" aria-label={salesFlow.ariaLabel} data-anim-scope>
            <div class="pipeline-route-layer" aria-hidden="true">
              <span class="pipeline-route-line"></span>
              <span class="pipeline-route-signal"></span>
              {salesPipelineStages.map((_, index) => (
                <span class="pipeline-route-node" style={`--node-index: ${index}`}></span>
              ))}
            </div>
            {salesPipelineStages.map((stage, index) => (
              <article class="pipeline-stage-card" role="listitem">
                <header class="pipeline-stage-head">
                  <span class="pipeline-stage-number" aria-hidden="true">{toPersianDigits(index + 1)}</span>
                  <div>
                    <h3>{stage.title}</h3>
                    <p>{stage.count}</p>
                  </div>
                </header>
                <p class="pipeline-stage-body">{stage.body}</p>
                <ul class="pipeline-card-list">
                  {stage.cards.map((card) => (
                    <li>
                      <strong>{card.title}</strong>
                      <span>{card.detail}</span>
                    </li>
                  ))}
                </ul>
                <p class="pipeline-stage-outcome"><strong>خروجی:</strong> {stage.outcome}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section id="plans" class="section">
        <div class="container">
          <div class="section-heading centered">
            <h2>{pricing.title}</h2>
            <p>{pricing.description}</p>
          </div>

          <div class="duration-tabs" role="tablist" aria-label="مدت اشتراک" data-active-duration={defaultDuration}>
            {pricing.durations.map((duration) => (
              <button
                class={duration.id === defaultDuration ? "active" : ""}
                type="button"
                role="tab"
                aria-selected={duration.id === defaultDuration ? "true" : "false"}
                aria-pressed={duration.id === defaultDuration ? "true" : "false"}
                data-plan-duration={duration.id}
              >
                <span class="duration-number">{duration.id}</span>
                {durationSavings[duration.id] && (
                  <span class="duration-saving">٪{toPersianDigits(durationSavings[duration.id] ?? 0)} صرفه‌جویی</span>
                )}
                <span class="duration-unit">ماهه</span>
              </button>
            ))}
          </div>

          <div class="pricing-grid">
            {pricing.plans.map((plan) => (
              <article class={`pricing-card plan-${plan.slug} ${plan.slug === "taban" ? "featured" : ""}`}>
                {plan.slug === "taban" && <span class="plan-badge">پیشنهاد اصلی</span>}
                <header class="plan-card-head">
                  <div class="plan-icon-shell">
                    <img src={plan.iconSrc} alt={plan.iconAlt} loading="lazy" decoding="async" />
                  </div>
                  <h3>{plan.name}</h3>
                </header>
                <strong class="price">
                  <span
                    class="price-number"
                    data-plan-price
                    data-prices={JSON.stringify(plan.prices)}
                  >
                    {plan.prices[defaultDuration]}
                  </span>
                  <span class="price-currency">{pricing.currency}</span>
                </strong>
                <p class="plan-scope">
                  <span>{plan.landLine}</span>
                  <span class="plan-scope-separator" aria-hidden="true">-</span>
                  <span>{pricing.stagesIncluded}</span>
                </p>
                <ul class="plan-highlights">
                  {plan.highlights.map((item) => <li>{item}</li>)}
                </ul>
                <div class="market-coverage" aria-label={pricing.coverage}>
                  <div class="coverage-label-row">
                    <strong>{pricing.coverage}</strong>
                  </div>
                  <div class="coverage-meter" aria-hidden="true">
                    {coverageDots.map((dot) => <i class={dot < plan.coverageLevel ? "filled" : ""}></i>)}
                  </div>
                  <span class="coverage-caption">پوشش {plan.coverageLabel} سطح بازار</span>
                </div>
                <p class="plan-addon">
                  <span>هر مرحله اضافه:</span>
                  <span class="addon-price">
                    <span>{plan.addonPrice}</span>
                    <span>{pricing.currency}</span>
                  </span>
                </p>
                <a class={`button ${plan.slug === "taban" ? "button-primary" : "button-secondary"}`} href={`/subscriptions/${plan.slug}/`}>{plan.cta}</a>
              </article>
            ))}
          </div>
        </div>
      </section>

      <script is:inline>
        (() => {
          const plansSection = document.getElementById("plans");
          if (!plansSection) return;

          const durationTabs = plansSection.querySelector(".duration-tabs");
          const buttons = Array.from(plansSection.querySelectorAll("[data-plan-duration]"));
          const priceNodes = Array.from(plansSection.querySelectorAll("[data-plan-price]"));
          const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

          const setDuration = (duration) => {
            durationTabs?.setAttribute("data-active-duration", duration);

            buttons.forEach((button) => {
              const isActive = button.getAttribute("data-plan-duration") === duration;
              button.classList.toggle("active", isActive);
              button.setAttribute("aria-selected", String(isActive));
              button.setAttribute("aria-pressed", String(isActive));
            });

            priceNodes.forEach((node) => {
              const prices = JSON.parse(node.getAttribute("data-prices") || "{}");
              if (prices[duration]) {
                if (reduceMotion) {
                  node.textContent = prices[duration];
                  return;
                }

                node.classList.add("is-updating");
                window.setTimeout(() => {
                  node.textContent = prices[duration];
                  node.classList.remove("is-updating");
                }, 100);
              }
            });
          };

          buttons.forEach((button) => {
            button.addEventListener("click", () => {
              const duration = button.getAttribute("data-plan-duration");
              if (duration) setDuration(duration);
            });
          });
        })();
      </script>

      <section id="faq" class="section">
        <div class="container">
          <div class="section-heading centered">
