---
import "../styles/global.css";
import {
  audiences,
  demo,
  faqSection,
  faqs,
  footer,
  hero,
  ids,
  metadata,
  navigation,
  pricing,
  problem,
  salesFlow,
  site,
  solution,
} from "@/content/home";

const primaryContact = site.contacts[0];
const reversedContacts = [...site.contacts].reverse();
const featuredPlan = pricing.plans.find((plan) => plan.featured) ?? pricing.plans[0];
const socialLinks = [
  { label: "اینستاگرام", href: "https://instagram.com/persiansaze" },
  { label: "لینکدین", href: "https://ir.linkedin.com/company/persiansaze" },
  { label: "یوتیوب", href: "https://www.youtube.com/channel/UCpOEQfUAF-xA04c_NmRVg9Q" },
  { label: "مدیوم", href: "https://persiansaze.medium.com/" },
];
const schemaGraph = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "@id": ids.organization,
    name: site.name,
    legalName: site.legalName,
    alternateName: site.alternateName,
    url: site.url,
    description: site.description,
    foundingDate: site.foundingDate,
    email: site.email,
    telephone: primaryContact.telephone,
    address: {
      "@type": "PostalAddress",
      ...site.postalAddress,
    },
    contactPoint: site.contacts.map((contact) => ({
      "@type": "ContactPoint",
      name: contact.label,
      telephone: contact.telephone,
      contactType: contact.contactType,
      areaServed: "IR",
      availableLanguage: ["fa-IR", "Persian"],
    })),
    sameAs: site.sameAs,
  },
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "@id": ids.localBusiness,
    additionalType: "https://schema.org/ProfessionalService",
    name: site.name,
    legalName: site.legalName,
    alternateName: site.alternateName,
    description: site.description,
    url: site.url,
    telephone: primaryContact.telephone,
    email: site.email,
    priceRange: "$$",
    address: {
      "@type": "PostalAddress",
      ...site.postalAddress,
    },
    openingHours: site.openingHours,
    openingHoursSpecification: site.openingHoursSpecification.map((item) => ({
      "@type": "OpeningHoursSpecification",
      ...item,
    })),
    areaServed: site.areaServed.map((name) => ({
      "@type": "City",
      name,
    })),
    parentOrganization: { "@id": ids.organization },
    sameAs: site.sameAs,
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "@id": ids.website,
    name: site.name,
    url: site.url,
    inLanguage: "fa-IR",
    publisher: { "@id": ids.organization },
  },
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    name: metadata.pageName,
    url: site.url,
    inLanguage: "fa-IR",
    isPartOf: { "@id": ids.website },
    publisher: { "@id": ids.organization },
    description: metadata.pageDescription,
    about: ["پروژه‌های ساختمانی", "نقشه پروژه‌ها", "مرحله ساخت", "فروش پروژه‌محور", "پیگیری فروش"].map((name) => ({
      "@type": "Thing",
      name,
    })),
  },
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "@id": ids.software,
    name: site.name,
    applicationCategory: "BusinessApplication",
    operatingSystem: "Web",
    url: site.url,
    inLanguage: "fa-IR",
    description: site.description,
    publisher: { "@id": ids.organization },
    offers: {
      "@type": "Offer",
      priceCurrency: "IRR",
      availability: "https://schema.org/InStock",
      url: `${site.url}/#plans`,
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqs.map((item) => ({
      "@type": "Question",
      name: item.question,
      acceptedAnswer: {
        "@type": "Answer",
        text: item.answer,
      },
    })),
  },
];
---

<!doctype html>
<html lang="fa-IR" dir="rtl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{metadata.title}</title>
    <meta name="description" content={metadata.description} />
    <meta name="keywords" content={metadata.keywords.join(", ")} />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <link rel="canonical" href={site.url} />
    <link rel="icon" href="data:," />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="fa_IR" />
    <meta property="og:url" content={site.url} />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={metadata.title} />
    <meta property="og:description" content={metadata.description} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={metadata.title} />
    <meta name="twitter:description" content={metadata.description} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(schemaGraph)} />
  </head>
  <body>
    <header class="site-header">
      <div class="container site-header-inner">
        <a class="brand" href="/">
          <span class="brand-mark" aria-hidden="true"></span>
          <span class="brand-copy">
            <strong>{site.name}</strong>
            <span>{footer.tagline}</span>
          </span>
        </a>

        <nav class="nav" aria-label="ناوبری اصلی">
          {navigation.map((item) => (
            <a href={item.href}>{item.label}</a>
          ))}
        </nav>

        <div class="header-actions">
          <a class="button button-secondary phone-button" href={primaryContact.href} dir="ltr">{primaryContact.phone}</a>
          <a class="button button-secondary" href="#demo">ورود</a>
          <a class="button button-primary" href="#demo">درخواست دمو</a>
        </div>
      </div>
    </header>

    <main>
      <section id="hero" class="hero">
        <div class="container hero-grid">
          <div class="hero-copy">
            <h1>
              <span>{hero.titleLines[0]}</span>
              <br />
              <span>{hero.titleLines[1]}</span>
            </h1>
            <p>{hero.body}</p>
            <div class="hero-actions">
              <a class="button button-primary" href="#demo">{hero.primaryCta}</a>
              <a class="button button-secondary" href="#solution">{hero.secondaryCta}</a>
            </div>
          </div>
          <div class="hero-visual" aria-label="جایگاه تصویر هیرو">
            <div class="visual-shell">
              <div class="visual-topline">
                <span>نقشه پروژه‌ها</span>
                <span>{solution.dashboardMarket}</span>
              </div>
              <div class="visual-map" aria-hidden="true">
                <span class="map-line map-line-a"></span>
                <span class="map-line map-line-b"></span>
                <span class="map-line map-line-c"></span>
                <span class="project-pin pin-a"></span>
                <span class="project-pin pin-b"></span>
                <span class="project-pin pin-c"></span>
              </div>
              <p>{hero.placeholder}</p>
            </div>
          </div>
        </div>
      </section>

      <section id="problem" class="section">
        <div class="container problem-layout">
          <div class="problem-visual" aria-label="جایگاه تصویر مسئله بازار">
            <div class="problem-frame">
              <span></span>
              <span></span>
              <span></span>
              <p>{problem.placeholder}</p>
            </div>
          </div>
          <div class="section-heading">
            <h2>{problem.title}</h2>
            <p>{problem.body}</p>
            <a class="button button-secondary" href="#solution">{problem.cta}</a>
          </div>
        </div>
      </section>

      <section id="solution" class="section">
        <div class="container">
          <div class="section-heading center-heading">
            <h2>{solution.title}</h2>
            <p>{solution.body}</p>
          </div>

          <div class="solution-showcase">
            <div class="dashboard-placeholder" aria-label={solution.dashboardTitle}>
              <div class="browser-bar">
                <span></span>
                <span></span>
                <span></span>
                <strong>{solution.dashboardTitle}</strong>
              </div>
              <div class="dashboard-frame">
                <div>
                  <p class="mini-label">{solution.dashboardTitle}</p>
                  <h3>{solution.dashboardMarket}</h3>
                </div>
                <div class="dashboard-grid" aria-hidden="true">
                  <span></span>
                  <span></span>
                  <span></span>
                  <span></span>
                  <span></span>
                </div>
                <p>{solution.dashboardPlaceholder}</p>
              </div>
            </div>

            <div class="solution-features">
              {solution.features.map((feature) => (
                <article class="feature-panel">
                  <p class="mini-label">{feature.label}</p>
                  <h3>{feature.title}</h3>
                  <p>{feature.body}</p>
                </article>
              ))}
            </div>
          </div>
        </div>
      </section>

      <section id="audiences" class="section">
        <div class="container">
          <div class="section-heading center-heading">
            <h2>{audiences.title}</h2>
            <p>{audiences.body}</p>
          </div>

          <div class="grid-2 audience-cards">
            {audiences.saleTypes.map((item) => (
              <article class="card">
                <h3>{item.title} - {item.countLine}</h3>
                <p>{item.description}</p>
                <p class="mini-label">{audiences.saleTypeSampleTitle}</p>
                <ul>
                  {item.sampleFields.map((field) => <li>{field}</li>)}
                </ul>
                <a class="button button-secondary" href="#audiences">{audiences.moreDetails}</a>
              </article>
            ))}
          </div>

          <div class="placeholder construction-placeholder" aria-label={audiences.stagesPlaceholderTitle}>
            <div>
              <p class="mini-label">{audiences.stagesPlaceholderTitle}</p>
              <h3>{audiences.stagesPlaceholderBody}</h3>
            </div>
            <div class="construction-steps" aria-hidden="true">
              <span></span>
              <span></span>
              <span></span>
              <span></span>
            </div>
          </div>
        </div>
      </section>

      <section id="sales-flow" class="section">
        <div class="container">
          <div class="section-heading center-heading sales-heading">
            <h2>{salesFlow.title}</h2>
            <a class="button button-primary" href="#demo">{salesFlow.cta}</a>
          </div>
          <div class="sales-path" role="list" aria-label={salesFlow.ariaLabel}>
            {salesFlow.stages.map((stage, index) => (
              <article class={`sales-step sales-step-${index + 1}`} role="listitem">
                <span class="step-number">{stage.number}</span>
                <h3>{stage.title}</h3>
                <p>{stage.body}</p>
                <p class="step-outcome">{stage.outcome}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section id="plans" class="section">
        <div class="container">
          <div class="section-heading center-heading">
            <span class="eyebrow">پلن‌ها</span>
            <h2>{pricing.title}</h2>
            <p>{pricing.description}</p>
          </div>

          <div class="plans-shell">
            <div class="plan-selector" aria-label={pricing.axisLabel}>
              {pricing.plans.map((plan) => (
                <a class={`plan-chip ${plan.featured ? "plan-chip-active" : ""}`} href="#plans">
                  <span>{plan.name}</span>
                  <small>{plan.landLine}</small>
                </a>
              ))}
            </div>

            <div class="plan-board">
              <div class="plan-board-head">
                <div>
                  <p class="mini-label">{pricing.axisLabel}</p>
                  <h3>{featuredPlan.name}</h3>
                  <p>{featuredPlan.selectorMotto}</p>
                </div>
                <div class="coverage-meter" aria-label={`${pricing.coverage}: ${featuredPlan.coverage}`}>
                  <span>{pricing.coverage}</span>
                  <strong>{featuredPlan.coverage}</strong>
                </div>
              </div>

              <div class="plan-board-grid">
                <article class="plan-primary-card">
                  <p class="mini-label">{pricing.recommended}</p>
                  <h3>{featuredPlan.landLine}</h3>
                  <p>{featuredPlan.sliderInsight}</p>
                  <ul>
                    {featuredPlan.highlights.map((item) => <li>{item}</li>)}
                  </ul>
                  <div class="plan-price-row">
                    {pricing.durations.map((duration) => (
                      <div>
                        <span>{duration.label}</span>
                        <strong>{featuredPlan.prices[duration.id as "3" | "6" | "12"]}</strong>
                        <small>{pricing.currency}</small>
                      </div>
                    ))}
                  </div>
                  <p class="mini-label">{featuredPlan.addon}</p>
                  <a class="button button-primary" href="#demo">{featuredPlan.cta}</a>
                </article>

                <aside class="plan-side-list" aria-label="سایر اشتراک‌ها">
                  {pricing.plans.filter((plan) => plan.id !== featuredPlan.id).map((plan) => (
                    <article>
                      <div>
                        <h4>{plan.name}</h4>
                        <p>{plan.landLine}</p>
                      </div>
                      <span>{plan.coverage}</span>
                    </article>
                  ))}
                </aside>
              </div>

              <div class="plan-table">
                {pricing.plans.map((plan) => (
                  <article>
                    <strong>{plan.name}</strong>
                    {pricing.durations.map((duration) => (
                      <span>{duration.label}: {plan.prices[duration.id as "3" | "6" | "12"]} {pricing.currency}</span>
                    ))}
                  </article>
                ))}
              </div>
            </div>
          </div>
        </div>
      </section>

      <section id="faq" class="section">
        <div class="container">
          <div class="section-heading center-heading">
            <span class="eyebrow">{faqSection.eyebrow}</span>
            <h2>{faqSection.title}</h2>
            <p>{faqSection.description}</p>
          </div>
          {faqs.map((item) => (
            <details>
              <summary>{item.question}</summary>
              <p>{item.answer}</p>
            </details>
          ))}
        </div>
      </section>

      <section id="demo" class="section demo-section">
        <div class="container grid-2">
          <div class="demo-copy">
            <h2>{demo.title}</h2>
            <p>{demo.body}</p>
            <div class="card">
              <p class="mini-label">{demo.pathLabel}</p>
              <h3>{demo.pathTitle}</h3>
              <ol>
                {demo.steps.map((step) => <li>{step}</li>)}
              </ol>
            </div>
          </div>

          <form class="card demo-form" action={`mailto:${site.email}`} method="post" enctype="text/plain">
            <div class="grid-2">
              <label class="field">
                <span>{demo.form.name}</span>
                <input name="name" autocomplete="name" />
              </label>
              <label class="field">
                <span>{demo.form.phone}</span>
                <input name="phone" autocomplete="tel" inputmode="tel" dir="ltr" />
              </label>
            </div>
            <div class="grid-2">
              <label class="field">
                <span>{demo.form.company}</span>
                <input name="company" autocomplete="organization" />
              </label>
              <label class="field">
                <span>{demo.form.referralSource}</span>
                <select name="referralSource">
                  <option value="">{demo.form.choose}</option>
                  {demo.form.referralSourceOptions.map((option) => (
                    <option value={option}>{option}</option>
                  ))}
                </select>
              </label>
            </div>
            <label class="field">
              <span>{demo.form.supplier}</span>
              <select name="supplier">
                <option value="">{demo.form.choose}</option>
                {demo.form.supplierOptions.map((option) => (
                  <option value={option}>{option}</option>
                ))}
              </select>
            </label>
            <button class="button button-primary" type="submit">{demo.form.submit}</button>
            <p class="mini-label">{demo.form.success}</p>
            <p class="mini-label">{demo.form.error}</p>
            <p>{demo.form.submitError}</p>
            <a class="button button-secondary" href={primaryContact.href} dir="ltr">{primaryContact.phone}</a>
            <a class="button button-secondary" href={`mailto:${site.email}`}>{site.email}</a>
          </form>
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <div class="container footer-grid">
        <section class="footer-brand">
          <a class="brand footer-logo" href="/">
            <span class="brand-mark" aria-hidden="true"></span>
            <span class="brand-copy">
              <strong>{site.name}</strong>
              <span>{footer.tagline}</span>
            </span>
          </a>
          <p>{footer.description}</p>
        </section>

        <section class="footer-col">
          <h2>{footer.mainPagesTitle}</h2>
          <ul>
            {navigation.map((item) => (
              <li><a href={item.href}>{item.label}</a></li>
            ))}
          </ul>
        </section>

        <section class="footer-col">
          <h2>{footer.contactTitle}</h2>
          <ul>
            {reversedContacts.map((contact) => (
              <li><a href={contact.href} dir="ltr">{contact.phone}</a> <span>{contact.label}</span></li>
            ))}
            <li><a href={`mailto:${site.email}`}>{site.email}</a></li>
            <li>{site.openingHoursText}</li>
          </ul>
        </section>

        <section class="footer-col">
          <h2>{footer.socialTitle}</h2>
          <ul>
            {socialLinks.map((item) => (
              <li><a href={item.href} rel="noreferrer">{item.label}</a></li>
            ))}
          </ul>
        </section>
      </div>
      <div class="container footer-bottom">
        <p>© {new Date().getFullYear()} {site.name}</p>
        <p>{site.address}</p>
      </div>
    </footer>
  </body>
</html>
