                  <circle cx="48" cy="48" r="28" stroke="rgba(149,167,232,0.3)" stroke-width="1.5" stroke-dasharray="4 6" />
                  <circle cx="48" cy="48" r="4" fill="#f7b32b" />
                  <g class="pg-radar-sweep">
                    <path d="M48 48L48 6A42 42 0 0 1 77 17Z" fill="rgba(247,179,43,0.25)" />
                  </g>
                  <circle class="pg-ping" cx="70" cy="34" r="5" stroke="#6fd3df" stroke-width="2" />
                  <circle cx="70" cy="34" r="2.5" fill="#6fd3df" />
                </svg>
              </div>
              <div class="pg-demo-path-copy">
                <strong>{demo.pathTitle}</strong>
                <ol>
                  {demo.steps.map((step) => (
                    <li>{step}</li>
                  ))}
                </ol>
              </div>
            </div>
          </div>

          <form class="pg-demo-form" action={`mailto:${site.email}`} method="post" enctype="text/plain">
            <h3>{demo.form.submit}</h3>
            <div class="pg-form-grid">
              <label class="pg-field">
                <span>{demo.form.name}</span>
                <input name="name" autocomplete="name" />
              </label>
              <label class="pg-field">
                <span>{demo.form.phone}</span>
                <input name="phone" autocomplete="tel" inputmode="tel" dir="ltr" />
              </label>
              <label class="pg-field">
