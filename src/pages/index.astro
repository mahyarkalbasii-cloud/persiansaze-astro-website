---
import "../styles/global.css";
import SiteFooter from "@/components/SiteFooter.astro";
import {
  audiences,
  demo,
  faqSection,
  faqs,
  footer,
  hero,
  ids,
  metadata,
  navigation,
  pricing,
  problem,
  salesFlow,
  site,
  solution,
} from "@/content/home";
import { constructionStages, getWorkFieldsForStage } from "@/content/construction";
import { saleTypes } from "@/content/sales";

const primaryContact = site.contacts[0];
const defaultDuration = "12" as const;
const featuredStage = constructionStages.find((stage) => stage.id === "finishing-facade") ?? constructionStages[0];
const featuredStageFields = getWorkFieldsForStage(featuredStage.id).slice(0, 4);
const schemaGraph = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "@id": ids.organization,
    name: site.name,
    legalName: site.legalName,
    alternateName: site.alternateName,
    url: site.url,
    description: site.description,
    foundingDate: site.foundingDate,
    email: site.email,
    telephone: primaryContact.telephone,
    address: {
      "@type": "PostalAddress",
      ...site.postalAddress,
    },
    contactPoint: site.contacts.map((contact) => ({
      "@type": "ContactPoint",
      name: contact.label,
      telephone: contact.telephone,
      contactType: contact.contactType,
      areaServed: "IR",
      availableLanguage: ["fa-IR", "Persian"],
    })),
    sameAs: site.sameAs,
  },
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "@id": ids.localBusiness,
    additionalType: "https://schema.org/ProfessionalService",
    name: site.name,
    legalName: site.legalName,
    alternateName: site.alternateName,
    description: site.description,
    url: site.url,
    telephone: primaryContact.telephone,
    email: site.email,
    priceRange: "$$",
    address: {
      "@type": "PostalAddress",
      ...site.postalAddress,
    },
    openingHours: site.openingHours,
    openingHoursSpecification: site.openingHoursSpecification.map((item) => ({
      "@type": "OpeningHoursSpecification",
      ...item,
    })),
    areaServed: site.areaServed.map((name) => ({
      "@type": "City",
      name,
    })),
    parentOrganization: { "@id": ids.organization },
    sameAs: site.sameAs,
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "@id": ids.website,
    name: site.name,
    url: site.url,
    inLanguage: "fa-IR",
    publisher: { "@id": ids.organization },
  },
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    name: metadata.pageName,
    url: site.url,
    inLanguage: "fa-IR",
    isPartOf: { "@id": ids.website },
    publisher: { "@id": ids.organization },
    description: metadata.pageDescription,
    about: ["پروژه‌های ساختمانی", "نقشه پروژه‌ها", "مرحله ساخت", "فروش پروژه‌محور", "پیگیری فروش"].map((name) => ({
      "@type": "Thing",
      name,
    })),
  },
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "@id": ids.software,
    name: site.name,
    applicationCategory: "BusinessApplication",
    operatingSystem: "Web",
    url: site.url,
    inLanguage: "fa-IR",
    description: site.description,
    publisher: { "@id": ids.organization },
    offers: {
      "@type": "Offer",
      priceCurrency: "IRR",
      availability: "https://schema.org/InStock",
      url: `${site.url}/#plans`,
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqs.map((item) => ({
      "@type": "Question",
      name: item.question,
      acceptedAnswer: {
        "@type": "Answer",
        text: item.answer,
      },
    })),
  },
];
---

<!doctype html>
<html lang="fa-IR" dir="rtl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{metadata.title}</title>
    <meta name="description" content={metadata.description} />
    <meta name="keywords" content={metadata.keywords.join(", ")} />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <link rel="canonical" href={site.url} />
    <link rel="icon" href="data:," />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="fa_IR" />
    <meta property="og:url" content={site.url} />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={metadata.title} />
    <meta property="og:description" content={metadata.description} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={metadata.title} />
    <meta name="twitter:description" content={metadata.description} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(schemaGraph)} />
  </head>
  <body>
    <header class="site-header">
      <div class="container site-header-inner">
        <a class="brand" href="/">
          <span class="brand-mark" aria-hidden="true">PS</span>
          <span class="brand-copy">
            <strong>{site.name}</strong>
            <span>{footer.tagline}</span>
          </span>
        </a>

        <nav class="nav" aria-label="ناوبری اصلی">
          {navigation.map((item) => (
            <a href={item.href}>{item.label}</a>
          ))}
        </nav>

        <div class="header-actions">
          <a class="header-phone" href={primaryContact.href} dir="ltr">{primaryContact.phone}</a>
          <a class="button button-secondary" href="#demo">ورود</a>
          <a class="button button-primary" href="#demo">درخواست دمو</a>
        </div>
      </div>
    </header>

    <main>
      <section id="hero" class="hero">
        <div class="container hero-grid">
          <div class="hero-copy">
            <h1>
              <span>{hero.titleLines[0]}</span>
              <span>{hero.titleLines[1]}</span>
            </h1>
            <p>{hero.body}</p>
            <div class="action-row">
              <a class="button button-primary" href="#demo">{hero.primaryCta}</a>
              <a class="button button-secondary" href="#problem">{hero.secondaryCta}</a>
            </div>
          </div>

          <div class="media-placeholder hero-placeholder" aria-label={hero.placeholder}>
            <span class="placeholder-label">جایگاه تصویر هیرو</span>
            <strong>{hero.placeholder}</strong>
            <div class="wire-map" aria-hidden="true">
              <span></span>
              <span></span>
              <span></span>
              <span></span>
              <span></span>
            </div>
          </div>
        </div>
      </section>

      <section id="problem" class="section problem-section">
        <div class="container two-column">
          <div class="media-placeholder problem-placeholder" aria-label={problem.placeholder}>
            <span class="placeholder-label">جایگاه روایت مسئله</span>
            <strong>{problem.placeholder}</strong>
          </div>
          <div class="section-copy">
            <h2>{problem.title}</h2>
            <p>{problem.body}</p>
            <a class="button button-secondary" href="#solution">{problem.cta}</a>
          </div>
        </div>
      </section>

      <section id="solution" class="section">
        <div class="container">
          <div class="section-heading">
            <h2>{solution.title}</h2>
            <p>{solution.body}</p>
          </div>

          <div class="dashboard-wireframe">
            <div class="dashboard-main">
              <div class="dashboard-head">
                <span>{solution.dashboardTitle}</span>
                <strong>{solution.dashboardMarket}</strong>
              </div>
              <div class="dashboard-body">
                <div class="map-placeholder media-placeholder">
                  <span class="placeholder-label">جایگاه نقشه و لوکیشن پروژه‌ها</span>
                </div>
                <div class="project-card-wire">
                  <p class="placeholder-label">اطلاعات / تصاویر / لوکیشن / پیگیری‌ها</p>
                  <dl class="facts">
                    <div><dt>تهران / منطقه ۲ / سعادت‌آباد</dt><dd>موقعیت</dd></div>
                    <div><dt>پرشین‌سازه</dt><dd>کارفرما</dd></div>
                    <div><dt>نازک‌کاری</dt><dd>مرحله</dd></div>
                    <div><dt>کمتر از یک ماه</dt><dd>آخرین تغییر مرحله</dd></div>
                    <div><dt>۱۰ طبقه / ۲۴ واحد</dt><dd>طبقه / واحد</dd></div>
                    <div><dt>متراژ ۱۰۶۰م / زیربنا ۶۳۸۵م</dt><dd>متراژ / زیربنا</dd></div>
                  </dl>
                </div>
              </div>
              <p>{solution.dashboardPlaceholder}</p>
            </div>

            <div class="feature-strip">
              {solution.features.map((feature) => (
                <article>
                  <span>{feature.label}</span>
                  <h3>{feature.title}</h3>
                  <p>{feature.body}</p>
                </article>
              ))}
            </div>
          </div>
        </div>
      </section>

      <section id="audiences" class="section">
        <div class="container">
          <div class="section-heading">
            <h2>{audiences.title}</h2>
            <p>{audiences.body}</p>
          </div>

          <div class="audience-grid">
            {saleTypes.map((item) => (
              <article class="audience-card">
                <span class="content-eyebrow">{item.englishTitle}</span>
                <h3>{item.title}</h3>
                <p>{item.summary}</p>
                <a class="text-link" href={`/sale-types/${item.slug}/`}>مطالعه مدل فروش ←</a>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section id="stages" class="section" aria-label="مراحل ساخت">
        <div class="container">
          <div class="stage-rail" aria-label="مراحل ساخت">
            {constructionStages.map((stage) => (
              <div class="stage-tile">
                <div class="stage-media media-placeholder" aria-hidden="true">
                  <span class="placeholder-label">جایگاه تصویر مرحله</span>
                </div>
                <strong>{stage.title}</strong>
              </div>
            ))}
          </div>

          <div class="stage-detail">
            <div>
              <p class="placeholder-label">مرحله منتخب</p>
              <h3>{featuredStage.title}</h3>
              <p>{featuredStage.summary}</p>
            </div>
            <div class="advice-grid">
              {featuredStageFields.map((field) => (
                <article>
                  <h4>{field.title}</h4>
                  <p>{field.definition}</p>
                  <a class="text-link" href={`/work-fields/${field.slug}/`}>جزئیات زمینه کاری ←</a>
                </article>
              ))}
            </div>
            <div class="action-row">
              <a class="button button-secondary" href="/work-fields/">مشاهده زمینه‌های کاری</a>
              <a class="button button-secondary" href={`/construction-stages/${featuredStage.slug}/`}>مشاهده صفحه کامل مرحله</a>
            </div>
          </div>
        </div>
      </section>

      <section id="sales-flow" class="section">
        <div class="container">
          <div class="section-heading">
            <h2>{salesFlow.title}</h2>
          </div>

          <div class="flow-board" role="list" aria-label={salesFlow.ariaLabel}>
            {salesFlow.stages.map((stage) => (
              <article class="flow-step" role="listitem">
                <span class="step-number">{stage.number}</span>
                <h3>{stage.title}</h3>
                <p>{stage.body}</p>
                <p><strong>نتیجه:</strong> {stage.outcome}</p>
                <div class="decision-box">
                  <span>؟</span>
                  <strong>{stage.question}</strong>
                  <p>بلی: {stage.yes}</p>
                  <p>خیر: {stage.no}</p>
                </div>
              </article>
            ))}
          </div>

          <div class="flow-footer">
            <span>قرارداد و رابطه پایدار</span>
            <span>پایان فرآیند</span>
            <a class="button button-primary" href="#demo">{salesFlow.cta} ←</a>
          </div>
        </div>
      </section>

      <section id="plans" class="section">
        <div class="container">
          <div class="section-heading centered">
            <h2>{pricing.title}</h2>
            <p>{pricing.description}</p>
          </div>

          <div class="pricing-axis">
            <p class="placeholder-label">{pricing.axisLabel}</p>
            <div class="meter-grid">
              {pricing.plans.map((plan) => (
                <a class={plan.featured ? "meter-chip active" : "meter-chip"} href="#plans">
                  <strong>{plan.name}</strong>
                  <span>{plan.landLine}</span>
                </a>
              ))}
            </div>
          </div>

          <div class="duration-tabs" aria-label="مدت اشتراک">
            {pricing.durations.map((duration) => (
              <span class={duration.id === defaultDuration ? "active" : ""}>{duration.label}</span>
            ))}
          </div>

          <div class="pricing-grid">
            {pricing.plans.map((plan) => (
              <article class={plan.featured ? "pricing-card featured" : "pricing-card"}>
                <div class="plan-media media-placeholder" aria-hidden="true">
                  <span class="placeholder-label">جایگاه آیکن پلن</span>
                </div>
                <div class="plan-title-row">
                  <h3>{plan.name}</h3>
                  {plan.featured && <span>{pricing.recommended}</span>}
                </div>
                <strong class="price">{plan.prices[defaultDuration]} {pricing.currency}</strong>
                <p>{plan.landLine} - {pricing.stagesIncluded}</p>
                <ul>
                  {plan.highlights.map((item) => <li>{item}</li>)}
                </ul>
                <p><strong>{pricing.coverage}</strong> {plan.coverage}</p>
                <p>{plan.addon}</p>
                <a class="button button-secondary" href="#demo">{plan.cta}</a>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section id="faq" class="section">
        <div class="container">
          <div class="section-heading centered">
            <span class="placeholder-label">{faqSection.eyebrow}</span>
            <h2>{faqSection.title}</h2>
            <p>{faqSection.description}</p>
          </div>
          <div class="faq-list">
            {faqs.map((item) => (
              <details>
                <summary>{item.question}</summary>
                <p>{item.answer}</p>
              </details>
            ))}
          </div>
        </div>
      </section>

      <section id="demo" class="section demo-section">
        <div class="container two-column">
          <div class="demo-copy">
            <h2>{demo.title}</h2>
            <p>{demo.body}</p>
            <div class="demo-path">
              <p class="placeholder-label">{demo.pathLabel}</p>
              <h3>{demo.pathTitle}</h3>
              <ol>
                {demo.steps.map((step) => <li>{step}</li>)}
              </ol>
            </div>
          </div>

          <form class="demo-form" action={`mailto:${site.email}`} method="post" enctype="text/plain">
            <div class="form-grid">
              <label class="field">
                <span>{demo.form.name}</span>
                <input name="name" autocomplete="name" />
              </label>
              <label class="field">
                <span>{demo.form.phone}</span>
                <input name="phone" autocomplete="tel" inputmode="tel" dir="ltr" />
              </label>
              <label class="field">
                <span>{demo.form.company}</span>
                <input name="company" autocomplete="organization" />
              </label>
              <label class="field">
                <span>{demo.form.referralSource}</span>
                <select name="referralSource">
                  <option value="">{demo.form.choose}</option>
                  {demo.form.referralSourceOptions.map((option) => (
                    <option value={option}>{option}</option>
                  ))}
                </select>
              </label>
            </div>
            <label class="field">
              <span>{demo.form.supplier}</span>
              <select name="supplier">
                <option value="">{demo.form.choose}</option>
                {demo.form.supplierOptions.map((option) => (
                  <option value={option}>{option}</option>
                ))}
              </select>
            </label>
            <button class="button button-primary" type="submit">{demo.form.submit}</button>
            <p>{demo.form.success}</p>
            <p>{demo.form.error}</p>
            <p>{demo.form.submitError}</p>
            <div class="contact-actions">
              <a class="button button-secondary" href={primaryContact.href} dir="ltr">{primaryContact.phone}</a>
              <a class="button button-secondary" href={`mailto:${site.email}`}>{site.email}</a>
            </div>
          </form>
        </div>
      </section>
    </main>

    <SiteFooter />
  </body>
</html>
