      <section id="demo" class="section demo-section">
        <div class="container">
          <div class="demo-shell">
            <div class="demo-copy">
              <h2>{demo.title}</h2>
              <p>{demo.body}</p>
            </div>

            <div class="demo-cards">
              <section class="demo-signup-notes" aria-labelledby="demo-signup-notes-title">
                <h3 id="demo-signup-notes-title">نکاتی که قبل از ثبت‌نام باید بدانید</h3>
                <p>
                  برای اینکه زمان شما و تیم پرشین‌سازه بهتر مدیریت شود، لطفاً پیش از ثبت‌نام به نکات زیر توجه کنید:
                </p>
                <ul>
                  <li>
                    پایگاه داده پرشین‌سازه در حال حاضر فقط شامل اطلاعات پروژه‌های ساختمانی <strong>تهران، کرج و لواسان</strong> است.
                  </li>
                  <li>
                    این خدمت فقط برای <strong>تأمین‌کنندگان محصولات و خدمات ساختمانی</strong> کاربرد دارد.
                  </li>
                  <li>
                    پرشین‌سازه برای <strong>مالکین، مصرف‌کنندگان نهایی یا افراد خارج از حوزه تأمین صنعت ساختمان</strong> طراحی نشده است.
                  </li>
                  <li>
                    شروع قیمت اشتراک پرشین‌سازه از <strong>۹,۰۰۰,۰۰۰ تومان</strong> است.
                  </li>
                  <li>
                    امکان ارائه سرویس فقط به <strong>تأمین‌کنندگان معتبر و فعال در صنعت ساختمان</strong> وجود دارد.
                  </li>
                  <li>تکمیل فرم ثبت‌نام به معنای پذیرش قطعی نیست و درخواست‌ها پیش از ارائه سرویس بررسی می‌شوند.</li>
                </ul>
                <p>در صورتی که موارد بالا با شرایط کسب‌وکار شما همخوانی دارد، فرم ثبت‌نام را تکمیل کنید.</p>
              </section>

              <form class="demo-form" action="/api/demo-request" method="post" novalidate data-demo-form data-state="idle">
                <h3>{demo.form.submit}</h3>
                <p class="demo-form-status demo-form-status-success" data-demo-success role="status" hidden>
                  درخواست شما ثبت شد، تا یک روز کاری تماس می‌گیریم.
                </p>
                <div class="demo-form-status demo-form-status-error" data-demo-error role="alert" hidden>
                  <span>ارسال درخواست با خطا روبه‌رو شد. لطفاً دوباره تلاش کنید.</span>
                  <button class="button button-secondary demo-retry-button" type="button" data-demo-retry>تلاش مجدد</button>
                </div>
                <div class="form-grid">
                  <label class="field" data-required>
                    <span class="field-label">{demo.form.name}<span class="required-star" aria-hidden="true">*</span></span>
                    <input name="name" autocomplete="name" required aria-describedby="demo-name-error" />
                    <small class="field-error" id="demo-name-error" data-field-error></small>
                  </label>
                  <label class="field" data-required>
                    <span class="field-label">{demo.form.phone}<span class="required-star" aria-hidden="true">*</span></span>
                    <input name="phone" autocomplete="tel" inputmode="tel" dir="ltr" required aria-describedby="demo-phone-error" />
                    <small class="field-error" id="demo-phone-error" data-field-error></small>
                  </label>
                  <label class="field" data-required>
                    <span class="field-label">{demo.form.company}<span class="required-star" aria-hidden="true">*</span></span>
                    <input name="company" autocomplete="organization" required aria-describedby="demo-company-error" />
                    <small class="field-error" id="demo-company-error" data-field-error></small>
                  </label>
                  <label class="field" data-required>
                    <span class="field-label">{demo.form.supplier}<span class="required-star" aria-hidden="true">*</span></span>
                    <select name="supplier" required aria-describedby="demo-supplier-error">
                      <option value="">{demo.form.choose}</option>
                      {demoWorkFieldOptions.map((option) => (
                        <option value={option}>{option}</option>
                      ))}
                    </select>
                    <small class="field-error" id="demo-supplier-error" data-field-error></small>
                  </label>
                </div>
                <label class="field" data-required>
                  <span class="field-label">{demo.form.referralSource}<span class="required-star" aria-hidden="true">*</span></span>
                  <select name="referralSource" required aria-describedby="demo-referral-source-error">
                    <option value="">{demo.form.choose}</option>
                    {demo.form.referralSourceOptions.map((option) => (
                      <option value={option}>{option}</option>
                    ))}
                  </select>
                  <small class="field-error" id="demo-referral-source-error" data-field-error></small>
                </label>
                <button class="button button-primary" type="submit" data-demo-submit>{demo.form.submit}</button>
              </form>
            </div>
          </div>
        </div>
      </section>

      <script is:inline>
        (() => {
          const form = document.querySelector("[data-demo-form]");
          if (!form) return;

          const submitButton = form.querySelector("[data-demo-submit]");
          const successMessage = form.querySelector("[data-demo-success]");
          const errorMessage = form.querySelector("[data-demo-error]");
          const retryButton = form.querySelector("[data-demo-retry]");
          const initialSubmitText = submitButton?.textContent?.trim() || "";
          const requiredMessage = "این فیلد اجباری است.";
          const selectRequiredMessage = "لطفاً یک گزینه را انتخاب کنید.";
          const phoneMessage = "شماره تماس را با ۱۱ رقم و کد صفر وارد کنید.";

          const toEnglishDigits = (value) => String(value)
            .replace(/[\u06F0-\u06F9]/g, (digit) => String(digit.charCodeAt(0) - 0x06F0))
            .replace(/[\u0660-\u0669]/g, (digit) => String(digit.charCodeAt(0) - 0x0660));

          const normalizePhone = (value) => {
            let phone = toEnglishDigits(value).replace(/[^\d+]/g, "");
            if (phone.startsWith("0098")) phone = `0${phone.slice(4)}`;
            if (phone.startsWith("+98")) phone = `0${phone.slice(3)}`;
            if (phone.startsWith("98")) phone = `0${phone.slice(2)}`;
            if (/^9\d{9}$/.test(phone)) phone = `0${phone}`;
            return phone.replace(/\D/g, "");
          };

          const setStatus = (type) => {
            form.dataset.state = type;
            if (successMessage) successMessage.hidden = type !== "success";
            if (errorMessage) errorMessage.hidden = type !== "error";
          };

          const setSubmitting = (isSubmitting) => {
            form.classList.toggle("is-submitting", isSubmitting);
            if (isSubmitting) form.dataset.state = "submitting";
            if (!submitButton) return;
            submitButton.disabled = isSubmitting;
            submitButton.textContent = isSubmitting ? "در حال ارسال..." : initialSubmitText;
          };

          const getControl = (field) => field.querySelector("input, select, textarea");

          const setFieldError = (field, message = "") => {
            const control = getControl(field);
            const error = field.querySelector("[data-field-error]");
            const hasError = Boolean(message);
            field.dataset.invalid = hasError ? "true" : "false";
            if (control) control.setAttribute("aria-invalid", hasError ? "true" : "false");
            if (error) error.textContent = message;
          };

          const validateField = (field) => {
            const control = getControl(field);
            if (!control) return true;

            if (control.required && !control.value.trim()) {
              setFieldError(field, control.tagName === "SELECT" ? selectRequiredMessage : requiredMessage);
              return false;
            }

            if (control.name === "phone" && control.value.trim()) {
              const normalizedPhone = normalizePhone(control.value);
              if (!/^0\d{10}$/.test(normalizedPhone)) {
                setFieldError(field, phoneMessage);
                return false;
              }
              control.value = normalizedPhone;
            }

            setFieldError(field);
            return true;
          };

          const validateForm = () => {
            const fields = Array.from(form.querySelectorAll(".field"));
            let firstInvalidField = null;
            fields.forEach((field) => {
              const isValid = validateField(field);
              if (!isValid && !firstInvalidField) firstInvalidField = field;
            });
            if (firstInvalidField) {
              getControl(firstInvalidField)?.focus();
              return false;
            }
            return true;
          };

          form.addEventListener("input", (event) => {
            const field = event.target.closest?.(".field");
            if (field) validateField(field);
          });

          form.addEventListener("change", (event) => {
            const field = event.target.closest?.(".field");
            if (field) validateField(field);
          });

          form.addEventListener("submit", async (event) => {
            event.preventDefault();
            setStatus("idle");
            if (!validateForm()) return;

            const formData = new FormData(form);
            const payload = {
              name: String(formData.get("name") || "").trim(),
              phone: String(formData.get("phone") || "").trim(),
              company: String(formData.get("company") || "").trim(),
              referralSource: String(formData.get("referralSource") || "").trim(),
              workField: String(formData.get("supplier") || "").trim(),
              page: location.pathname,
              referrer: document.referrer || "",
            };

            setSubmitting(true);
            try {
              const response = await fetch("/api/demo-request", {
                method: "POST",
                headers: {
                  "content-type": "application/json",
                },
                body: JSON.stringify(payload),
              });

              if (!response.ok) {
                setStatus("error");
                return;
              }

              setStatus("success");
              form.reset();
            } catch {
              setStatus("error");
            } finally {
              setSubmitting(false);
            }
          });

          retryButton?.addEventListener("click", () => {
            form.requestSubmit();
          });
        })();
      </script>
    </main>

    <button class="back-to-top-button" type="button" aria-label="بازگشت به بالای صفحه" data-back-to-top>
      <svg aria-hidden="true" viewBox="0 0 24 24" fill="none">
        <path d="M12 19V5" />
        <path d="m6 11 6-6 6 6" />
      </svg>
    </button>
    <script is:inline>
      (() => {
        const backToTop = document.querySelector("[data-back-to-top]");
        if (!backToTop) return;

        const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
        let ticking = false;

        const syncVisibility = () => {
          backToTop.classList.toggle("is-visible", window.scrollY > 600);
          ticking = false;
        };

        const requestVisibilitySync = () => {
          if (ticking) return;
          ticking = true;
          window.requestAnimationFrame(syncVisibility);
        };

        backToTop.addEventListener("click", () => {
          window.scrollTo({ top: 0, behavior: reduceMotion ? "auto" : "smooth" });
        });

        window.addEventListener("scroll", requestVisibilitySync, { passive: true });
        syncVisibility();
      })();
    </script>

    <script is:inline>
      (() => {
        if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
        const targets = document.querySelectorAll("[data-anim-scope]");
        if (!targets.length || !("IntersectionObserver" in window)) return;
        const io = new IntersectionObserver((entries) => {
          for (const entry of entries) {
            const el = entry.target;
            el.toggleAttribute("data-paused", !entry.isIntersecting);
            el.querySelectorAll("svg").forEach((svg) => {
              if (typeof svg.pauseAnimations !== "function") return;
              entry.isIntersecting ? svg.unpauseAnimations() : svg.pauseAnimations();
            });
            el.dispatchEvent(new CustomEvent(entry.isIntersecting ? "anim:resume" : "anim:pause"));
          }
        }, { rootMargin: "160px 0px", threshold: 0.01 });
        targets.forEach((target) => io.observe(target));
      })();
    </script>

    <SiteFooter />
    <PersianDigitsScript />
    {cfBeaconToken && (
      <script
        is:inline
        defer
        src="https://static.cloudflareinsights.com/beacon.min.js"
