---
import "../styles/global.css";
import SiteFooter from "@/components/SiteFooter.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import PersianDigitsScript from "@/components/PersianDigitsScript.astro";
import {
  audiences,
  demo,
  faqSection,
  faqs,
  hero,
  ids,
  metadata,
  pricing,
  problem,
  salesFlow,
  site,
  solution,
} from "@/content/home";
import { constructionStages, workFields } from "@/content/construction";
import { saleTypes } from "@/content/sales";

const primaryContact = site.contacts[0];
const defaultDuration = "3" as const;
const homeConstructionStages = constructionStages.filter((stage) => stage.id !== "permit-design");
const toPersianDigits = (value: string | number) => String(value).replace(/\d/g, (digit) => "۰۱۲۳۴۵۶۷۸۹"[Number(digit)]);
const homeStageCards = homeConstructionStages.map((stage) => ({
  title: stage.title,
  sourcePhase: toPersianDigits(stage.sourcePhase),
  summary: toPersianDigits(stage.summary),
  href: `/construction-stages/${stage.slug}/`,
}));
const initialHomeStage = homeStageCards[0];
const demoWorkFieldOptions = workFields.map((field) => field.title);
const coverageDots = Array.from({ length: 4 }, (_, index) => index);
const schemaGraph = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "@id": ids.organization,
    name: site.name,
    legalName: site.legalName,
    alternateName: site.alternateName,
    url: site.url,
    description: site.description,
    foundingDate: site.foundingDate,
    email: site.email,
    telephone: primaryContact.telephone,
    address: {
      "@type": "PostalAddress",
      ...site.postalAddress,
    },
    contactPoint: site.contacts.map((contact) => ({
      "@type": "ContactPoint",
      name: contact.label,
      telephone: contact.telephone,
      contactType: contact.contactType,
      areaServed: "IR",
      availableLanguage: ["fa-IR", "Persian"],
    })),
    sameAs: site.sameAs,
  },
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "@id": ids.localBusiness,
    additionalType: "https://schema.org/ProfessionalService",
    name: site.name,
    legalName: site.legalName,
    alternateName: site.alternateName,
    description: site.description,
    url: site.url,
    telephone: primaryContact.telephone,
    email: site.email,
    priceRange: "$$",
    address: {
      "@type": "PostalAddress",
      ...site.postalAddress,
    },
    openingHours: site.openingHours,
    openingHoursSpecification: site.openingHoursSpecification.map((item) => ({
      "@type": "OpeningHoursSpecification",
      ...item,
    })),
    areaServed: site.areaServed.map((name) => ({
      "@type": "City",
      name,
    })),
    parentOrganization: { "@id": ids.organization },
    sameAs: site.sameAs,
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "@id": ids.website,
    name: site.name,
    url: site.url,
    inLanguage: "fa-IR",
    publisher: { "@id": ids.organization },
  },
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    name: metadata.pageName,
    url: site.url,
    inLanguage: "fa-IR",
    isPartOf: { "@id": ids.website },
    publisher: { "@id": ids.organization },
    description: metadata.pageDescription,
    about: ["پروژه‌های ساختمانی", "نقشه پروژه‌ها", "مرحله ساخت", "فروش پروژه‌محور", "پیگیری فروش"].map((name) => ({
      "@type": "Thing",
      name,
    })),
  },
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "@id": ids.software,
    name: site.name,
    applicationCategory: "BusinessApplication",
    operatingSystem: "Web",
    url: site.url,
    inLanguage: "fa-IR",
    description: site.description,
    publisher: { "@id": ids.organization },
    offers: {
      "@type": "Offer",
      priceCurrency: "IRR",
      availability: "https://schema.org/InStock",
      url: `${site.url}/subscriptions/`,
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqs.map((item) => ({
      "@type": "Question",
      name: item.question,
      acceptedAnswer: {
        "@type": "Answer",
        text: item.answer,
      },
    })),
  },
];
---

<!doctype html>
<html lang="fa-IR" dir="rtl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{metadata.title}</title>
    <meta name="description" content={metadata.description} />
    <meta name="keywords" content={metadata.keywords.join(", ")} />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <link rel="canonical" href={site.url} />
    <link rel="icon" href="data:," />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="fa_IR" />
    <meta property="og:url" content={site.url} />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={metadata.title} />
    <meta property="og:description" content={metadata.description} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={metadata.title} />
    <meta name="twitter:description" content={metadata.description} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(schemaGraph)} />
  </head>
  <body class="home-color-anthropic">
    <SiteHeader home />

    <main class="sl-home">
      <section id="hero" class="sl-hero">
        <div class="container sl-hero-grid">
          <div class="sl-hero-copy">
            <h1>
              <span>{hero.titleLines[0]}</span>
              <span>{hero.titleLines[1]}</span>
            </h1>
            <p>{hero.body}</p>
            <div class="sl-actions">
              <a class="sl-btn sl-btn-primary" href="#demo">{hero.primaryCta}</a>
              <a class="sl-btn sl-btn-ghost" href="#problem">{hero.secondaryCta}</a>
            </div>
          </div>

          <div class="sl-visual sl-hero-visual">
            <div class="sl-placeholder">
              <svg class="sl-placeholder-mark" viewBox="0 0 48 48" fill="none" aria-hidden="true">
                <rect x="4" y="4" width="40" height="40" rx="8" stroke="currentColor" stroke-width="2" stroke-dasharray="5 5" />
                <circle cx="18" cy="20" r="5" stroke="currentColor" stroke-width="2" />
                <path d="M10 36L20 27L28 32L38 22" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
              <span class="sl-placeholder-label">{hero.placeholder}</span>
            </div>
          </div>
        </div>
      </section>

      <section id="problem" class="sl-section">
        <div class="container">
          <h2 class="sl-statement">{problem.title}</h2>

          <div class="sl-row">
            <div class="sl-row-copy">
              <p>{problem.body}</p>
              <a class="sl-btn sl-btn-primary" href="#solution">{problem.cta}</a>
            </div>

            <article class="sl-visual sl-problem-visual">
              <header class="sl-problem-head">
                <span>روایت مسئله بازار</span>
                <strong>فرصت ساختمانی وقتی ارزش دارد که به‌موقع دیده شود.</strong>
              </header>

              <div class="sl-placeholder sl-placeholder-flat">
                <svg class="sl-placeholder-mark" viewBox="0 0 48 48" fill="none" aria-hidden="true">
                  <rect x="4" y="4" width="40" height="40" rx="8" stroke="currentColor" stroke-width="2" stroke-dasharray="5 5" />
                  <circle cx="16" cy="30" r="4" stroke="currentColor" stroke-width="2" />
                  <circle cx="32" cy="18" r="4" stroke="currentColor" stroke-width="2" />
                  <path d="M19 27L29 21" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-dasharray="3 4" />
                </svg>
                <span class="sl-placeholder-label">{problem.placeholder}</span>
              </div>

              <div class="sl-chip">
                <span>پنجره تماس</span>
                <strong>زودتر از رقبا، نه زودتر از نیاز</strong>
              </div>

              <div class="sl-mini-grid">
                <article>
                  <span>پراکندگی</span>
                  <strong>پروژه‌ها روی چند مسیر پخش‌اند</strong>
                </article>
                <article>
                  <span>زمان تماس</span>
                  <strong>زود یا دیر، هر دو فرصت را می‌سوزاند</strong>
                </article>
                <article>
                  <span>پیگیری</span>
                  <strong>بدون نظم، فرصت‌ها در صف می‌مانند</strong>
                </article>
              </div>
            </article>
          </div>
        </div>
      </section>

      <section id="solution" class="sl-section">
        <div class="container">
          <div class="sl-statement-block">
            <h2>{solution.title}</h2>
            <p>{solution.body}</p>
          </div>

          <div class="sl-row sl-row-flip">
            <div class="sl-row-copy" aria-labelledby="solution-data-title">
              <h3 id="solution-data-title">{solution.dataTitle}</h3>
              <div class="sl-data-list">
                {solution.dataCards.map((card) => (
                  <article>
                    <h4>{card.title}</h4>
                    <p>{card.body}</p>
                  </article>
                ))}
              </div>
            </div>

            <figure class="sl-visual sl-solution-visual" aria-label={solution.visualAlt}>
              <div class="sl-placeholder">
                <svg class="sl-placeholder-mark" viewBox="0 0 48 48" fill="none" aria-hidden="true">
                  <rect x="4" y="4" width="40" height="40" rx="8" stroke="currentColor" stroke-width="2" stroke-dasharray="5 5" />
                  <path d="M14 14H26" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                  <path d="M14 22H34" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                  <path d="M14 30H22" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                  <circle cx="32" cy="32" r="4" stroke="currentColor" stroke-width="2" />
                </svg>
                <span class="sl-placeholder-label">{solution.dashboardPlaceholder}</span>
              </div>
            </figure>
          </div>

          <h3 class="sl-substatement" id="solution-stack-title">{solution.stackTitle}</h3>

          {solution.features.map((feature, index) => (
            <div class={index % 2 === 0 ? "sl-row sl-row-feature" : "sl-row sl-row-feature sl-row-flip"}>
              <div class="sl-row-copy">
                <span class="sl-badge">{feature.label}</span>
                <h4>{feature.title}</h4>
                <p>{feature.body}</p>
              </div>
              <div class="sl-visual sl-feature-visual">
                <div class="sl-placeholder">
                  <svg class="sl-placeholder-mark" viewBox="0 0 48 48" fill="none" aria-hidden="true">
                    <rect x="4" y="4" width="40" height="40" rx="8" stroke="currentColor" stroke-width="2" stroke-dasharray="5 5" />
                    <circle cx="24" cy="24" r="8" stroke="currentColor" stroke-width="2" />
                    <path d="M24 16V12M24 36V32M16 24H12M36 24H32" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                  </svg>
                </div>
              </div>
            </div>
          ))}
        </div>
      </section>

      <section id="audiences" class="sl-section">
        <div class="container">
          <div class="sl-statement-block">
            <h2>{audiences.title}</h2>
            <p>{audiences.body}</p>
          </div>

          <div class="sl-audience-grid">
            {saleTypes.map((item) => (
              <article class="sl-card sl-audience-card">
                <h3>{item.title}</h3>
                <p>{item.summary}</p>
                <a class="sl-link" href={`/sale-types/${item.slug}/`}>مشاهده جزئیات ←</a>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section id="stages" class="sl-section" aria-label="مراحل ساخت" data-stage-rotation>
        <div class="container">
          <div class="sl-tabs" role="tablist" aria-label="مراحل ساخت">
            {homeStageCards.map((stage, index) => (
              <button
                class={index === 0 ? "sl-tab active" : "sl-tab"}
                type="button"
                role="tab"
                aria-selected={index === 0 ? "true" : "false"}
                aria-controls="stage-info-panel"
                data-stage-index={index}
              >
                {stage.title}
              </button>
            ))}
          </div>

          <article class="sl-card sl-stage-card" id="stage-info-panel" aria-live="polite">
            <div class="sl-stage-copy">
              <h3 data-stage-title>{initialHomeStage.title}</h3>
              <p data-stage-summary>{initialHomeStage.summary}</p>
            </div>
            <div class="sl-stage-side">
              <span>زمان تصمیم‌گیری سازنده</span>
              <p data-stage-source>{initialHomeStage.sourcePhase}</p>
              <a class="sl-btn sl-btn-primary" data-stage-link href={initialHomeStage.href}>مشاهده اطلاعات بیشتر</a>
            </div>
          </article>
        </div>
        <script is:inline type="application/json" id="home-stage-data" set:html={JSON.stringify(homeStageCards)} />
        <script is:inline>
          (() => {
            const root = document.querySelector("[data-stage-rotation]");
            const dataNode = document.getElementById("home-stage-data");
            if (!root || !dataNode) return;

            const stages = JSON.parse(dataNode.textContent || "[]");
            const buttons = [...root.querySelectorAll("[data-stage-index]")];
            const title = root.querySelector("[data-stage-title]");
            const summary = root.querySelector("[data-stage-summary]");
            const source = root.querySelector("[data-stage-source]");
            const link = root.querySelector("[data-stage-link]");
            let activeIndex = 0;
            let userLocked = false;
            let timerId = null;

            const selectStage = (index, lock = false) => {
              const stage = stages[index];
              if (!stage) return;

              activeIndex = index;
              buttons.forEach((button, buttonIndex) => {
                const isActive = buttonIndex === index;
                button.classList.toggle("active", isActive);
                button.setAttribute("aria-selected", isActive ? "true" : "false");
              });

              if (title) title.textContent = stage.title;
              if (summary) summary.textContent = stage.summary;
              if (source) source.textContent = stage.sourcePhase;
              if (link) link.setAttribute("href", stage.href);

              if (lock && !userLocked) {
                userLocked = true;
                if (timerId) window.clearInterval(timerId);
              }
            };

            buttons.forEach((button) => {
              button.addEventListener("click", () => {
                selectStage(Number(button.dataset.stageIndex), true);
              });
            });

            if (stages.length > 1) {
              timerId = window.setInterval(() => {
                if (!userLocked) selectStage((activeIndex + 1) % stages.length);
              }, 10000);
            }
          })();
        </script>
      </section>

      <section id="sales-flow" class="sl-section">
        <div class="container">
          <h2 class="sl-statement">{salesFlow.title}</h2>

          <div class="sl-flow-grid" role="list" aria-label={salesFlow.ariaLabel}>
            {salesFlow.stages.map((stage) => (
              <article class="sl-card sl-flow-step" role="listitem">
                <span class="sl-step-number">{stage.number}</span>
                <p class="sl-flow-summary"><strong>{stage.title} یعنی</strong> {stage.body}</p>
                <p class="sl-flow-outcome"><strong>نتیجه:</strong> {stage.outcome}</p>
              </article>
            ))}
          </div>

          <div class="sl-center-cta">
            <a class="sl-btn sl-btn-primary" href="#demo">{salesFlow.cta} ←</a>
          </div>
        </div>
      </section>

      <section id="plans" class="sl-section">
        <div class="container">
          <div class="sl-statement-block">
            <h2>{pricing.title}</h2>
            <p>{pricing.description}</p>
          </div>

          <div class="sl-tabs sl-duration-tabs" role="tablist" aria-label="مدت اشتراک" data-active-duration={defaultDuration}>
            {pricing.durations.map((duration) => (
              <button
                class={duration.id === defaultDuration ? "sl-tab active" : "sl-tab"}
                type="button"
                role="tab"
                aria-selected={duration.id === defaultDuration ? "true" : "false"}
                aria-pressed={duration.id === defaultDuration ? "true" : "false"}
                data-plan-duration={duration.id}
              >
                <span class="sl-duration-number">{duration.id}</span>
                <span class="sl-duration-unit">ماهه</span>
              </button>
            ))}
          </div>

          <div class="sl-pricing-grid">
            {pricing.plans.map((plan) => (
              <article class="sl-card sl-price-card">
                <header class="sl-price-head">
                  <span class="sl-plan-mark" role="img" aria-label={plan.iconAlt}>
                    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                      <rect x="3" y="3" width="18" height="18" rx="5" stroke="currentColor" stroke-width="1.5" stroke-dasharray="3 3" />
                      <circle cx="12" cy="12" r="3.5" stroke="currentColor" stroke-width="1.5" />
                    </svg>
                  </span>
                  <h3>{plan.name}</h3>
                </header>
                <strong class="sl-price">
                  <span
                    class="sl-price-number"
                    data-plan-price
                    data-prices={JSON.stringify(plan.prices)}
                  >
                    {plan.prices[defaultDuration]}
                  </span>
                  <span class="sl-price-currency">{pricing.currency}</span>
                </strong>
                <p class="sl-plan-scope">
                  <span>{plan.landLine}</span>
                  <span class="sl-plan-scope-separator" aria-hidden="true">-</span>
                  <span>{pricing.stagesIncluded}</span>
                </p>
                <ul class="sl-plan-highlights">
                  {plan.highlights.map((item) => <li>{item}</li>)}
                </ul>
                <div class="sl-coverage" aria-label={`${pricing.coverage} ${plan.coverageLabel}`}>
                  <strong>{pricing.coverage}</strong>
                  <div class="sl-coverage-meter" aria-hidden="true">
                    {coverageDots.map((dot) => <i class={dot < plan.coverageLevel ? "filled" : ""}></i>)}
                  </div>
                </div>
                <p class="sl-plan-addon">
                  <span>هر مرحله اضافه:</span>
                  <span class="sl-addon-price">
                    <span>{plan.addonPrice}</span>
                    <span>{pricing.currency}</span>
                  </span>
                </p>
                <a class="sl-btn sl-btn-ghost" href={`/subscriptions/${plan.slug}/`}>{plan.cta}</a>
              </article>
            ))}
          </div>
        </div>
      </section>

      <script is:inline>
        (() => {
          const plansSection = document.getElementById("plans");
          if (!plansSection) return;

          const durationTabs = plansSection.querySelector(".sl-duration-tabs");
          const buttons = Array.from(plansSection.querySelectorAll("[data-plan-duration]"));
          const priceNodes = Array.from(plansSection.querySelectorAll("[data-plan-price]"));

          const setDuration = (duration) => {
            durationTabs?.setAttribute("data-active-duration", duration);

            buttons.forEach((button) => {
              const isActive = button.getAttribute("data-plan-duration") === duration;
              button.classList.toggle("active", isActive);
              button.setAttribute("aria-selected", String(isActive));
              button.setAttribute("aria-pressed", String(isActive));
            });

            priceNodes.forEach((node) => {
              const prices = JSON.parse(node.getAttribute("data-prices") || "{}");
              if (prices[duration]) {
                node.textContent = prices[duration];
              }
            });
          };

          buttons.forEach((button) => {
            button.addEventListener("click", () => {
              const duration = button.getAttribute("data-plan-duration");
              if (duration) setDuration(duration);
            });
          });
        })();
      </script>

      <section id="faq" class="sl-section">
        <div class="container">
          <div class="sl-statement-block">
            <span class="sl-eyebrow">{faqSection.eyebrow}</span>
            <h2>{faqSection.title}</h2>
            <p>{faqSection.description}</p>
          </div>
          <div class="sl-faq">
            {faqs.map((item) => (
              <details class="sl-faq-item">
                <summary>
                  {item.question}
                  <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path d="M6 9L12 15L18 9" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </summary>
                <p>{item.answer}</p>
              </details>
            ))}
          </div>
        </div>
      </section>

      <section id="demo" class="sl-section sl-demo">
        <div class="container sl-demo-grid">
          <div class="sl-demo-copy">
            <h2>{demo.title}</h2>
            <p>{demo.body}</p>

            <div class="sl-card sl-demo-path">
              <strong>{demo.pathTitle}</strong>
              <ol>
                {demo.steps.map((step) => (
                  <li>{step}</li>
                ))}
              </ol>
            </div>
          </div>

          <form class="sl-card sl-demo-form" action={`mailto:${site.email}`} method="post" enctype="text/plain">
            <h3>{demo.form.submit}</h3>
            <div class="sl-form-grid">
              <label class="sl-field">
                <span>{demo.form.name}</span>
                <input name="name" autocomplete="name" />
              </label>
              <label class="sl-field">
                <span>{demo.form.phone}</span>
                <input name="phone" autocomplete="tel" inputmode="tel" dir="ltr" />
              </label>
              <label class="sl-field">
                <span>{demo.form.company}</span>
                <input name="company" autocomplete="organization" />
              </label>
              <label class="sl-field">
                <span>{demo.form.referralSource}</span>
                <select name="referralSource">
                  <option value="">{demo.form.choose}</option>
                  {demo.form.referralSourceOptions.map((option) => (
                    <option value={option}>{option}</option>
                  ))}
                </select>
              </label>
            </div>
            <label class="sl-field">
              <span>{demo.form.supplier}</span>
              <select name="supplier">
                <option value="">{demo.form.choose}</option>
                {demoWorkFieldOptions.map((option) => (
                  <option value={option}>{option}</option>
                ))}
              </select>
            </label>
            <button class="sl-btn sl-btn-primary" type="submit">{demo.form.submit}</button>
          </form>
        </div>
      </section>
    </main>

    <SiteFooter />
    <PersianDigitsScript />
  </body>
</html>

<style is:global>
  /* Slite-style palette for the shared header/footer; this body class is used only on the homepage. */
  body.home-color-anthropic {
    --background: #f7f0e9;
    --surface: #ffffff;
    --surface-muted: #f1e8df;
    --surface-subtle: #fbf6f0;
    --foreground: #1e1d35;
    --muted-foreground: #4a4865;
    --faint-foreground: #76748e;
    --border: #e6dccf;
    --border-strong: #d6c9b8;
    --primary: #2545d3;
    --primary-hover: #1c37ad;
    --primary-foreground: #ffffff;
    --secondary: #ffffff;
    --secondary-foreground: #1e1d35;
    --accent: #e9e0d4;
    --accent-foreground: #1e1d35;
    --ring: #2545d3;
    --inverted: #1e1d35;
    --inverted-foreground: #f7f0e9;
  }
</style>

<style>
  main.sl-home {
    --sl-bg: #f7f0e9;
    --sl-ink: #1e1d35;
    --sl-body: #4a4865;
    --sl-faint: #76748e;
    --sl-blue: #2545d3;
    --sl-blue-dark: #1c37ad;
    --sl-blue-soft: rgba(37, 69, 211, 0.1);
    --sl-card: #ffffff;
    --sl-border: rgba(30, 29, 53, 0.08);
    --sl-shadow: 0 14px 36px rgba(30, 29, 53, 0.09);
    --sl-shadow-sm: 0 6px 18px rgba(30, 29, 53, 0.07);
    --sl-radius: 0.875rem;
    --sl-radius-sm: 0.625rem;
    background: var(--sl-bg);
    color: var(--sl-ink);
  }

  /* ---------- Primitives ---------- */

  .sl-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    border: 1px solid transparent;
    border-radius: 9999px;
    padding: 0.55rem 1.4rem;
    font-size: 0.88rem;
    font-weight: 700;
    line-height: 1.5;
    cursor: pointer;
    white-space: nowrap;
    transition: background-color 160ms ease, color 160ms ease, border-color 160ms ease, transform 160ms ease, box-shadow 160ms ease;
  }

  .sl-btn-primary {
    background: var(--sl-blue);
    color: #ffffff;
    box-shadow: 0 6px 16px rgba(37, 69, 211, 0.28);
  }

  .sl-btn-primary:hover {
    background: var(--sl-blue-dark);
    transform: translateY(-1px);
    box-shadow: 0 8px 20px rgba(37, 69, 211, 0.32);
  }

  .sl-btn-ghost {
    background: var(--sl-card);
    border-color: rgba(30, 29, 53, 0.14);
    color: var(--sl-ink);
    box-shadow: var(--sl-shadow-sm);
  }

  .sl-btn-ghost:hover {
    border-color: var(--sl-blue);
    color: var(--sl-blue);
    transform: translateY(-1px);
  }

  .sl-card {
    background: var(--sl-card);
    border: 1px solid var(--sl-border);
    border-radius: var(--sl-radius);
    box-shadow: var(--sl-shadow-sm);
    padding: clamp(1.4rem, 1.1rem + 0.8vw, 2rem);
  }

  .sl-visual {
    background: var(--sl-card);
    border: 1px solid var(--sl-border);
    border-radius: var(--sl-radius);
    box-shadow: var(--sl-shadow);
    padding: 1.1rem;
    margin: 0;
  }

  .sl-placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.9rem;
    height: 100%;
    min-height: 11rem;
    padding: 1.75rem;
    text-align: center;
    border: 1.5px dashed rgba(30, 29, 53, 0.18);
    border-radius: var(--sl-radius-sm);
    background: #fbf7f1;
  }

  .sl-placeholder-flat {
    min-height: 9rem;
  }

  .sl-placeholder-mark {
    width: 48px;
    height: 48px;
    color: var(--sl-blue);
    opacity: 0.85;
  }

  .sl-placeholder-label {
    max-width: 36ch;
    font-size: 0.82rem;
    font-weight: 500;
    line-height: 1.9;
    color: var(--sl-faint);
  }

  .sl-eyebrow {
    display: inline-flex;
    width: fit-content;
    border-radius: 9999px;
    background: var(--sl-blue-soft);
    color: var(--sl-blue);
    padding: 0.25rem 0.9rem;
    font-size: 0.78rem;
    font-weight: 700;
  }

  .sl-badge {
    display: inline-flex;
    width: fit-content;
    border-radius: 9999px;
    background: var(--sl-blue-soft);
    color: var(--sl-blue);
    padding: 0.2rem 0.8rem;
    font-size: 0.75rem;
    font-weight: 700;
  }

  .sl-link {
    width: fit-content;
    font-size: 0.88rem;
    font-weight: 700;
    color: var(--sl-blue);
    transition: color 160ms ease;
  }

  .sl-link:hover {
    color: var(--sl-blue-dark);
  }

  /* ---------- Layout ---------- */

  .sl-section {
    padding-block: clamp(3.5rem, 2.5rem + 3vw, 6rem);
  }

  .sl-statement {
    max-width: 42rem;
    margin-inline: auto;
    margin-bottom: clamp(2.5rem, 2rem + 1.5vw, 4rem);
    text-align: center;
    font-size: clamp(1.5rem, 1.15rem + 1.3vw, 2.25rem);
    font-weight: 800;
    line-height: 1.5;
  }

  .sl-statement-block {
    max-width: 42rem;
    margin-inline: auto;
    margin-bottom: clamp(2.5rem, 2rem + 1.5vw, 4rem);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    text-align: center;
  }

  .sl-statement-block h2 {
    font-size: clamp(1.5rem, 1.15rem + 1.3vw, 2.25rem);
    font-weight: 800;
    line-height: 1.5;
  }

  .sl-statement-block p {
    color: var(--sl-body);
    line-height: 2.1;
  }

  .sl-substatement {
    max-width: 42rem;
    margin-inline: auto;
    margin-block: clamp(3rem, 2.5rem + 1.5vw, 4.5rem) clamp(2rem, 1.5rem + 1.5vw, 3rem);
    text-align: center;
    font-size: clamp(1.25rem, 1rem + 1vw, 1.7rem);
    font-weight: 800;
    line-height: 1.6;
  }

  .sl-row {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    align-items: center;
    gap: clamp(2.5rem, 2rem + 2.5vw, 5rem);
  }

  .sl-row + .sl-row {
    margin-top: clamp(3rem, 2.5rem + 2vw, 5rem);
  }

  .sl-row-flip > .sl-row-copy {
    order: 2;
  }

  .sl-row-flip > .sl-visual {
    order: 1;
  }

  .sl-row-copy {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1rem;
  }

  .sl-row-copy h3,
  .sl-row-copy h4 {
    font-size: 1.25rem;
    font-weight: 800;
    line-height: 1.7;
  }

  .sl-row-copy > p {
    color: var(--sl-body);
    font-size: 0.96rem;
    line-height: 2.1;
  }

  .sl-row-copy .sl-btn {
    margin-top: 0.5rem;
  }

  .sl-row-feature {
    grid-template-columns: 1fr 1fr;
  }

  .sl-row-feature .sl-row-copy p {
    font-size: 0.92rem;
  }

  .sl-feature-visual .sl-placeholder {
    min-height: 12rem;
  }

  /* ---------- Hero ---------- */

  .sl-hero {
    padding-block: clamp(3.5rem, 2.5rem + 3.5vw, 6.5rem);
  }

  .sl-hero-grid {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    align-items: center;
    gap: clamp(2.5rem, 2rem + 2.5vw, 5rem);
  }

  .sl-hero-copy {
    display: flex;
    flex-direction: column;
    gap: 1.4rem;
  }

  .sl-hero h1 {
    font-size: clamp(2rem, 1.4rem + 2.6vw, 3.2rem);
    font-weight: 800;
    line-height: 1.35;
  }

  .sl-hero h1 span {
    display: block;
  }

  .sl-hero h1 span:last-child {
    color: var(--sl-blue);
  }

  .sl-hero-copy > p {
    max-width: 36rem;
    color: var(--sl-body);
    font-size: 1rem;
    line-height: 2.15;
  }

  .sl-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 0.4rem;
  }

  .sl-hero-visual {
    min-height: clamp(17rem, 13rem + 12vw, 24rem);
    display: flex;
  }

  .sl-hero-visual .sl-placeholder {
    flex: 1;
  }

  /* ---------- Problem ---------- */

  .sl-problem-visual {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: clamp(1.4rem, 1.1rem + 0.8vw, 2rem);
  }

  .sl-problem-head {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .sl-problem-head span {
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--sl-blue);
  }

  .sl-problem-head strong {
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.9;
  }

  .sl-chip {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.3rem 0.7rem;
    width: fit-content;
    border-radius: 9999px;
    background: var(--sl-blue-soft);
    padding: 0.4rem 1rem;
    font-size: 0.82rem;
  }

  .sl-chip span {
    color: var(--sl-blue);
    font-weight: 700;
  }

  .sl-chip strong {
    color: var(--sl-ink);
    font-weight: 700;
  }

  .sl-mini-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.7rem;
  }

  .sl-mini-grid article {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    border: 1px solid var(--sl-border);
    border-radius: var(--sl-radius-sm);
    background: #fbf7f1;
    padding: 0.85rem 0.95rem;
  }

  .sl-mini-grid span {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--sl-blue);
  }

  .sl-mini-grid strong {
    font-size: 0.85rem;
    font-weight: 600;
    line-height: 1.85;
    color: var(--sl-body);
  }

  /* ---------- Solution ---------- */

  .sl-data-list {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    width: 100%;
  }

  .sl-data-list article {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    border: 1px solid var(--sl-border);
    border-radius: var(--sl-radius-sm);
    background: var(--sl-card);
    box-shadow: var(--sl-shadow-sm);
    padding: 1.1rem 1.25rem;
  }

  .sl-data-list h4 {
    font-size: 0.96rem;
    font-weight: 700;
    line-height: 1.9;
  }

  .sl-data-list p {
    font-size: 0.88rem;
    line-height: 2;
    color: var(--sl-body);
  }

  .sl-solution-visual {
    align-self: stretch;
    display: flex;
  }

  .sl-solution-visual .sl-placeholder {
    flex: 1;
    min-height: 16rem;
  }

  /* ---------- Audiences ---------- */

  .sl-audience-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr));
    gap: 1.1rem;
  }

  .sl-audience-card {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    transition: transform 160ms ease, box-shadow 160ms ease;
  }

  .sl-audience-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--sl-shadow);
  }

  .sl-audience-card h3 {
    font-size: 1.02rem;
    font-weight: 800;
    line-height: 1.8;
  }

  .sl-audience-card p {
    flex: 1;
    font-size: 0.88rem;
    line-height: 2;
    color: var(--sl-body);
  }

  /* ---------- Tabs (stages + durations) ---------- */

  .sl-tabs {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.3rem;
    width: fit-content;
    max-width: 100%;
    margin-inline: auto;
    margin-bottom: 2rem;
    border: 1px solid var(--sl-border);
    border-radius: 1.4rem;
    background: var(--sl-card);
    box-shadow: var(--sl-shadow-sm);
    padding: 0.35rem;
  }

  .sl-tab {
    border: 0;
    border-radius: 9999px;
    background: transparent;
    color: var(--sl-faint);
    padding: 0.45rem 1.05rem;
    font-size: 0.86rem;
    font-weight: 700;
    cursor: pointer;
    transition: background-color 160ms ease, color 160ms ease, box-shadow 160ms ease;
  }

  .sl-tab:hover {
    color: var(--sl-ink);
  }

  .sl-tab.active {
    background: var(--sl-blue);
    color: #ffffff;
    box-shadow: 0 4px 12px rgba(37, 69, 211, 0.3);
  }

  .sl-stage-card {
    display: grid;
    grid-template-columns: 1.4fr 0.6fr;
    gap: clamp(1.5rem, 1.2rem + 1vw, 2.5rem);
    align-items: center;
  }

  .sl-stage-copy {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }

  .sl-stage-copy h3 {
    font-size: 1.25rem;
    font-weight: 800;
  }

  .sl-stage-copy p {
    color: var(--sl-body);
    font-size: 0.94rem;
    line-height: 2.05;
  }

  .sl-stage-side {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    border-inline-start: 1px solid var(--sl-border);
    padding-inline-start: clamp(1.25rem, 1rem + 1vw, 2rem);
  }

  .sl-stage-side span {
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--sl-blue);
  }

  .sl-stage-side p {
    font-size: 0.88rem;
    color: var(--sl-body);
    line-height: 2;
  }

  .sl-stage-side .sl-btn {
    margin-top: 0.4rem;
    width: fit-content;
  }

  /* ---------- Sales flow ---------- */

  .sl-flow-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.1rem;
  }

  .sl-flow-step {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    transition: transform 160ms ease, box-shadow 160ms ease;
  }

  .sl-flow-step:hover {
    transform: translateY(-3px);
    box-shadow: var(--sl-shadow);
  }

  .sl-step-number {
    font-size: 1.4rem;
    font-weight: 800;
    color: var(--sl-blue);
    line-height: 1;
  }

  .sl-flow-summary {
    flex: 1;
    font-size: 0.9rem;
    line-height: 2.05;
    color: var(--sl-body);
  }

  .sl-flow-summary strong {
    color: var(--sl-ink);
  }

  .sl-flow-outcome {
    border-top: 1px solid var(--sl-border);
    padding-top: 0.8rem;
    font-size: 0.83rem;
    line-height: 1.95;
    color: var(--sl-faint);
  }

  .sl-flow-outcome strong {
    color: var(--sl-blue);
  }

  .sl-center-cta {
    display: flex;
    justify-content: center;
    margin-top: 2.5rem;
  }

  /* ---------- Pricing ---------- */

  .sl-duration-tabs .sl-tab {
    display: inline-flex;
    align-items: baseline;
    gap: 0.3rem;
  }

  .sl-duration-number {
    font-size: 1rem;
    font-weight: 800;
  }

  .sl-duration-unit {
    font-size: 0.78rem;
  }

  .sl-pricing-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(15.5rem, 1fr));
    gap: 1.1rem;
    align-items: stretch;
  }

  .sl-price-card {
    display: flex;
    flex-direction: column;
    gap: 0.95rem;
    transition: transform 160ms ease, box-shadow 160ms ease;
  }

  .sl-price-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--sl-shadow);
  }

  .sl-price-head {
    display: flex;
    align-items: center;
    gap: 0.7rem;
  }

  .sl-price-head h3 {
    font-size: 1.1rem;
    font-weight: 800;
  }

  .sl-plan-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.6rem;
    height: 2.6rem;
    flex-shrink: 0;
    border: 1.5px dashed rgba(30, 29, 53, 0.2);
    border-radius: var(--sl-radius-sm);
    background: #fbf7f1;
    color: var(--sl-blue);
  }

  .sl-plan-mark svg {
    width: 1.35rem;
    height: 1.35rem;
  }

  .sl-price {
    display: flex;
    align-items: baseline;
    gap: 0.4rem;
  }

  .sl-price-number {
    font-size: 1.55rem;
    font-weight: 800;
  }

  .sl-price-currency {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--sl-faint);
  }

  .sl-plan-scope {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    font-size: 0.83rem;
    color: var(--sl-body);
  }

  .sl-plan-scope-separator {
    color: var(--sl-faint);
  }

  .sl-plan-highlights {
    flex: 1;
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .sl-plan-highlights li {
    position: relative;
    margin: 0;
    padding-inline-start: 1.35rem;
    font-size: 0.86rem;
    line-height: 1.95;
    color: var(--sl-body);
  }

  .sl-plan-highlights li::before {
    content: "";
    position: absolute;
    inset-inline-start: 0;
    top: 0.62em;
    width: 0.48rem;
    height: 0.48rem;
    border-radius: 9999px;
    background: var(--sl-blue-soft);
    border: 1.5px solid var(--sl-blue);
  }

  .sl-coverage {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.7rem;
    border-top: 1px solid var(--sl-border);
    padding-top: 0.95rem;
  }

  .sl-coverage strong {
    font-size: 0.83rem;
    font-weight: 700;
    color: var(--sl-body);
  }

  .sl-coverage-meter {
    display: flex;
    gap: 0.3rem;
  }

  .sl-coverage-meter i {
    width: 1.3rem;
    height: 0.42rem;
    border-radius: 9999px;
    background: #efe7dc;
    border: 1px solid var(--sl-border);
  }

  .sl-coverage-meter i.filled {
    background: var(--sl-blue);
    border-color: var(--sl-blue);
  }

  .sl-plan-addon {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    font-size: 0.83rem;
    color: var(--sl-faint);
  }

  .sl-addon-price {
    display: inline-flex;
    gap: 0.3rem;
    font-weight: 700;
    color: var(--sl-ink);
  }

  .sl-price-card .sl-btn {
    width: 100%;
  }

  /* ---------- FAQ ---------- */

  .sl-faq {
    max-width: 46rem;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }

  .sl-faq-item {
    background: var(--sl-card);
    border: 1px solid var(--sl-border);
    border-radius: var(--sl-radius-sm);
    box-shadow: var(--sl-shadow-sm);
    padding-inline: 1.25rem;
    transition: box-shadow 160ms ease;
  }

  .sl-faq-item:hover {
    box-shadow: var(--sl-shadow);
  }

  .sl-faq-item summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-block: 1rem;
    font-weight: 700;
    font-size: 0.95rem;
    line-height: 1.95;
    cursor: pointer;
    list-style: none;
  }

  .sl-faq-item summary::-webkit-details-marker {
    display: none;
  }

  .sl-faq-item summary svg {
    width: 1.1rem;
    height: 1.1rem;
    flex-shrink: 0;
    color: var(--sl-blue);
    transition: transform 200ms ease;
  }

  .sl-faq-item[open] summary svg {
    transform: rotate(180deg);
  }

  .sl-faq-item p {
    padding-block: 0 1.15rem;
    font-size: 0.9rem;
    line-height: 2.1;
    color: var(--sl-body);
  }

  /* ---------- Demo ---------- */

  .sl-demo-grid {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: clamp(2.5rem, 2rem + 2.5vw, 5rem);
    align-items: center;
  }

  .sl-demo-copy {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }

  .sl-demo-copy h2 {
    font-size: clamp(1.5rem, 1.15rem + 1.3vw, 2.2rem);
    font-weight: 800;
    line-height: 1.55;
  }

  .sl-demo-copy > p {
    color: var(--sl-body);
    line-height: 2.1;
  }

  .sl-demo-path {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    margin-top: 0.4rem;
  }

  .sl-demo-path strong {
    font-size: 0.92rem;
    font-weight: 800;
    color: var(--sl-blue);
  }

  .sl-demo-path ol {
    margin: 0;
    padding-inline-start: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .sl-demo-path li {
    margin: 0;
    font-size: 0.88rem;
    line-height: 2;
    color: var(--sl-body);
  }

  .sl-demo-path li::marker {
    color: var(--sl-blue);
    font-weight: 800;
  }

  .sl-demo-form {
    display: flex;
    flex-direction: column;
    gap: 1.05rem;
    box-shadow: var(--sl-shadow);
  }

  .sl-demo-form h3 {
    font-size: 1.08rem;
    font-weight: 800;
  }

  .sl-form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.95rem;
  }

  .sl-field {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .sl-field span {
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--sl-body);
  }

  .sl-field input,
  .sl-field select {
    border: 1px solid rgba(30, 29, 53, 0.16);
    border-radius: var(--sl-radius-sm);
    background: #fdfbf8;
    color: var(--sl-ink);
    padding: 0.55rem 0.85rem;
    font-size: 0.9rem;
    transition: border-color 160ms ease, box-shadow 160ms ease;
  }

  .sl-field input:focus-visible,
  .sl-field select:focus-visible {
    outline: 0;
    border-color: var(--sl-blue);
    box-shadow: 0 0 0 3px var(--sl-blue-soft);
  }

  .sl-demo-form .sl-btn {
    margin-top: 0.25rem;
  }

  /* ---------- Responsive ---------- */

