---
import "../styles/global.css";
import SiteFooter from "@/components/SiteFooter.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import PersianDigitsScript from "@/components/PersianDigitsScript.astro";
import {
  audiences,
  demo,
  faqSection,
  faqs,
  hero,
  ids,
  metadata,
  pricing,
  problem,
  salesFlow,
  site,
  solution,
} from "@/content/home";
import { constructionStages, workFields } from "@/content/construction";
import { saleTypes } from "@/content/sales";

const primaryContact = site.contacts[0];
const defaultDuration = "3" as const;
const homeConstructionStages = constructionStages.filter((stage) => stage.id !== "permit-design");
const toPersianDigits = (value: string | number) => String(value).replace(/\d/g, (digit) => "۰۱۲۳۴۵۶۷۸۹"[Number(digit)]);
const homeStageCards = homeConstructionStages.map((stage) => ({
  title: stage.title,
  sourcePhase: toPersianDigits(stage.sourcePhase),
  summary: toPersianDigits(stage.summary),
  href: `/construction-stages/${stage.slug}/`,
}));
const initialHomeStage = homeStageCards[0];
const demoWorkFieldOptions = workFields.map((field) => field.title);
const coverageDots = Array.from({ length: 4 }, (_, index) => index);
const schemaGraph = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "@id": ids.organization,
    name: site.name,
    legalName: site.legalName,
    alternateName: site.alternateName,
    url: site.url,
    description: site.description,
    foundingDate: site.foundingDate,
    email: site.email,
    telephone: primaryContact.telephone,
    address: {
      "@type": "PostalAddress",
      ...site.postalAddress,
    },
    contactPoint: site.contacts.map((contact) => ({
      "@type": "ContactPoint",
      name: contact.label,
      telephone: contact.telephone,
      contactType: contact.contactType,
      areaServed: "IR",
      availableLanguage: ["fa-IR", "Persian"],
    })),
    sameAs: site.sameAs,
  },
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "@id": ids.localBusiness,
    additionalType: "https://schema.org/ProfessionalService",
    name: site.name,
    legalName: site.legalName,
    alternateName: site.alternateName,
    description: site.description,
    url: site.url,
    telephone: primaryContact.telephone,
    email: site.email,
    priceRange: "$$",
    address: {
      "@type": "PostalAddress",
      ...site.postalAddress,
    },
    openingHours: site.openingHours,
    openingHoursSpecification: site.openingHoursSpecification.map((item) => ({
      "@type": "OpeningHoursSpecification",
      ...item,
    })),
    areaServed: site.areaServed.map((name) => ({
      "@type": "City",
      name,
    })),
    parentOrganization: { "@id": ids.organization },
    sameAs: site.sameAs,
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "@id": ids.website,
    name: site.name,
    url: site.url,
    inLanguage: "fa-IR",
    publisher: { "@id": ids.organization },
  },
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    name: metadata.pageName,
    url: site.url,
    inLanguage: "fa-IR",
    isPartOf: { "@id": ids.website },
    publisher: { "@id": ids.organization },
    description: metadata.pageDescription,
    about: ["پروژه‌های ساختمانی", "نقشه پروژه‌ها", "مرحله ساخت", "فروش پروژه‌محور", "پیگیری فروش"].map((name) => ({
      "@type": "Thing",
      name,
    })),
  },
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "@id": ids.software,
    name: site.name,
    applicationCategory: "BusinessApplication",
    operatingSystem: "Web",
    url: site.url,
    inLanguage: "fa-IR",
    description: site.description,
    publisher: { "@id": ids.organization },
    offers: {
      "@type": "Offer",
      priceCurrency: "IRR",
      availability: "https://schema.org/InStock",
      url: `${site.url}/subscriptions/`,
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqs.map((item) => ({
      "@type": "Question",
      name: item.question,
      acceptedAnswer: {
        "@type": "Answer",
        text: item.answer,
      },
    })),
  },
];
---

<!doctype html>
<html lang="fa-IR" dir="rtl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{metadata.title}</title>
    <meta name="description" content={metadata.description} />
    <meta name="keywords" content={metadata.keywords.join(", ")} />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <link rel="canonical" href={site.url} />
    <link rel="icon" href="data:," />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="fa_IR" />
    <meta property="og:url" content={site.url} />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={metadata.title} />
    <meta property="og:description" content={metadata.description} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={metadata.title} />
    <meta name="twitter:description" content={metadata.description} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(schemaGraph)} />
  </head>
  <body class="home-color-anthropic">
    <SiteHeader home />

    <main class="pg-home">
      <!-- ================= HERO ================= -->
      <section id="hero" class="pg-hero">
        <div class="container pg-hero-grid">
          <div class="pg-hero-copy">
            <h1>
              <span>{hero.titleLines[0]}</span>
              <span class="pg-hl">{hero.titleLines[1]}</span>
            </h1>
            <p>{hero.body}</p>
            <div class="pg-actions">
              <a class="pg-btn pg-btn-amber" href="#demo">{hero.primaryCta}</a>
              <a class="pg-btn pg-btn-ghost" href="#problem">{hero.secondaryCta}</a>
            </div>
            <ul class="pg-city-chips" aria-label="شهرها">
              {site.areaServed.map((city) => (
                <li><i aria-hidden="true"></i>{city}</li>
              ))}
            </ul>
          </div>

          <div class="pg-hero-scene" aria-hidden="true">
            <svg viewBox="0 0 560 420" fill="none">
              <!-- glow -->
              <ellipse cx="280" cy="372" rx="250" ry="36" fill="url(#pgGlow)" />
              <defs>
                <radialGradient id="pgGlow" cx="0.5" cy="0.5" r="0.5">
                  <stop offset="0" stop-color="#f7b32b" stop-opacity="0.16" />
                  <stop offset="1" stop-color="#f7b32b" stop-opacity="0" />
                </radialGradient>
              </defs>

              <!-- skyline -->
              <g class="pg-skyline" stroke="#95a7e8" stroke-width="2">
                <rect class="pg-b pg-b1" x="42" y="232" width="70" height="140" rx="3" fill="rgba(149,167,232,0.06)" />
                <rect class="pg-b pg-b2" x="122" y="172" width="60" height="200" rx="3" fill="rgba(149,167,232,0.06)" />
                <rect class="pg-b pg-b3" x="192" y="112" width="80" height="260" rx="3" fill="rgba(149,167,232,0.08)" />
                <rect class="pg-b pg-b4" x="282" y="192" width="64" height="180" rx="3" fill="rgba(149,167,232,0.06)" />
                <rect class="pg-b pg-b5" x="356" y="142" width="74" height="230" rx="3" fill="rgba(149,167,232,0.08)" />
                <rect class="pg-b pg-b6" x="440" y="252" width="58" height="120" rx="3" fill="rgba(247,179,43,0.05)" stroke-dasharray="7 5" />
              </g>

              <!-- scaffold lines on the building under construction -->
              <g stroke="#95a7e8" stroke-width="1.5" stroke-dasharray="4 5" opacity="0.7">
                <path d="M440 282H498" />
                <path d="M440 312H498" />
                <path d="M440 342H498" />
              </g>

              <!-- windows -->
              <g class="pg-windows" fill="#ffd66b">
                <rect class="w1" x="204" y="132" width="12" height="14" rx="2" />
                <rect class="w2" x="228" y="162" width="12" height="14" rx="2" />
                <rect class="w3" x="252" y="132" width="12" height="14" rx="2" />
                <rect class="w4" x="204" y="222" width="12" height="14" rx="2" />
                <rect class="w5" x="252" y="192" width="12" height="14" rx="2" />
                <rect class="w6" x="228" y="252" width="12" height="14" rx="2" />
                <rect class="w7" x="368" y="162" width="12" height="14" rx="2" />
                <rect class="w8" x="394" y="192" width="12" height="14" rx="2" />
                <rect class="w9" x="368" y="252" width="12" height="14" rx="2" />
                <rect class="w10" x="134" y="192" width="12" height="14" rx="2" />
                <rect class="w11" x="158" y="232" width="12" height="14" rx="2" />
                <rect class="w12" x="294" y="212" width="12" height="14" rx="2" />
                <rect class="w13" x="318" y="252" width="12" height="14" rx="2" />
                <rect class="w14" x="64" y="252" width="12" height="14" rx="2" />
                <rect class="w15" x="88" y="292" width="12" height="14" rx="2" />
              </g>

              <!-- tower crane -->
              <g class="pg-crane" stroke="#f7b32b" stroke-width="3" stroke-linecap="round">
                <path d="M516 372V96" />
                <path d="M516 96H404" />
                <path d="M516 96H548" />
                <path d="M516 60V96" />
                <path d="M516 60L450 96" stroke-width="2" />
                <path d="M516 60L548 96" stroke-width="2" />
                <g class="pg-hook">
                  <path d="M430 96V150" stroke-width="2" />
                  <rect x="422" y="150" width="16" height="14" rx="2" fill="rgba(247,179,43,0.25)" stroke-width="2" />
                </g>
              </g>

              <!-- map pins -->
              <g class="pg-pins">
                <g transform="translate(232 84)">
                  <circle class="pg-ping" r="11" stroke="#f7b32b" stroke-width="2" />
                  <circle r="5.5" fill="#f7b32b" />
                </g>
                <g transform="translate(393 112)">
                  <circle class="pg-ping d2" r="11" stroke="#6fd3df" stroke-width="2" />
                  <circle r="5.5" fill="#6fd3df" />
                </g>
                <g transform="translate(77 204)">
                  <circle class="pg-ping d3" r="11" stroke="#f7b32b" stroke-width="2" />
                  <circle r="5.5" fill="#f7b32b" />
                </g>
              </g>

              <!-- ground + route -->
              <path d="M22 372H538" stroke="#95a7e8" stroke-width="2" opacity="0.8" />
              <path class="pg-route" d="M30 392C150 384 320 400 530 388" stroke="#6fd3df" stroke-width="2" stroke-dasharray="2 10" stroke-linecap="round" />
            </svg>
          </div>
        </div>
      </section>

      <div class="pg-sheet">
        <!-- ================= PROBLEM ================= -->
        <section id="problem" class="pg-section">
          <div class="container">
            <div class="pg-statement">
              <span class="pg-kicker">روایت مسئله بازار</span>
              <h2>{problem.title}</h2>
              <p>{problem.body}</p>
            </div>

            <div class="pg-problem-board">
              <div class="pg-window-card">
                <strong class="pg-window-title">فرصت ساختمانی وقتی ارزش دارد که به‌موقع دیده شود.</strong>

                <div class="pg-timeline" aria-hidden="true">
                  <svg viewBox="0 0 520 170" fill="none">
                    <g stroke="#c9c2b2" stroke-width="1.5">
                      <path d="M30 118H490" stroke-width="2" stroke="#8c8674" />
                      <path d="M95 110V126" />
                      <path d="M160 110V126" />
                      <path d="M225 110V126" />
                      <path d="M290 110V126" />
                      <path d="M355 110V126" />
                      <path d="M420 110V126" />
                    </g>
                    <rect class="pg-band" x="226" y="34" width="92" height="116" rx="14" fill="rgba(247,179,43,0.16)" stroke="#e3a31b" stroke-width="2" stroke-dasharray="6 6" />
                    <circle class="pg-probe p1" cy="118" r="7" fill="#9aa3b5" />
                    <circle class="pg-probe p2" cy="118" r="8" fill="#e3a31b" />
                    <circle class="pg-probe p3" cy="118" r="7" fill="#9aa3b5" />
                  </svg>
                </div>

                <div class="pg-window-chip">
                  <span>پنجره تماس</span>
                  <strong>زودتر از رقبا، نه زودتر از نیاز</strong>
                </div>
              </div>

              <div class="pg-friction-grid">
                <article>
                  <span>پراکندگی</span>
                  <strong>پروژه‌ها روی چند مسیر پخش‌اند</strong>
                </article>
                <article>
                  <span>زمان تماس</span>
                  <strong>زود یا دیر، هر دو فرصت را می‌سوزاند</strong>
                </article>
                <article>
                  <span>پیگیری</span>
                  <strong>بدون نظم، فرصت‌ها در صف می‌مانند</strong>
                </article>
              </div>

              <div class="pg-center-cta">
                <a class="pg-btn pg-btn-ink" href="#solution">{problem.cta}</a>
              </div>
            </div>
          </div>
        </section>

        <!-- ================= SOLUTION ================= -->
        <section id="solution" class="pg-section pg-section-tinted">
          <div class="container">
            <div class="pg-statement">
              <h2>{solution.title}</h2>
              <p>{solution.body}</p>
            </div>

            <div class="pg-solution-grid">
              <figure class="pg-dash" aria-label={solution.visualAlt}>
                <div class="pg-dash-top" aria-hidden="true">
                  <i></i><i></i><i></i>
                </div>
                <div class="pg-dash-body" aria-hidden="true">
                  <div class="pg-dash-map">
                    <svg viewBox="0 0 240 240" fill="none">
                      <path class="pg-route" d="M22 196C70 150 96 168 122 122C148 76 190 92 218 44" stroke="#6fd3df" stroke-width="2" stroke-dasharray="2 9" stroke-linecap="round" />
                      <g>
                        <g transform="translate(60 160)">
                          <circle class="pg-ping" r="12" stroke="#f7b32b" stroke-width="2" />
                          <circle r="6" fill="#f7b32b" />
                        </g>
                        <g transform="translate(126 118)">
                          <circle class="pg-ping d2" r="12" stroke="#6fd3df" stroke-width="2" />
                          <circle r="6" fill="#6fd3df" />
                        </g>
                        <g transform="translate(196 62)">
                          <circle class="pg-ping d3" r="12" stroke="#f7b32b" stroke-width="2" />
                          <circle r="6" fill="#f7b32b" />
                        </g>
                      </g>
                    </svg>
                  </div>
                  <div class="pg-dash-side">
                    <i class="pg-dash-row" style="width: 84%"></i>
                    <i class="pg-dash-row" style="width: 62%"></i>
                    <i class="pg-dash-row" style="width: 74%"></i>
                    <div class="pg-dash-chart">
                      <i style="--h: 42%"></i>
                      <i style="--h: 64%"></i>
                      <i class="hot" style="--h: 92%"></i>
                      <i style="--h: 55%"></i>
                      <i style="--h: 76%"></i>
                    </div>
                  </div>
                </div>
              </figure>

              <section class="pg-data-panel" aria-labelledby="solution-data-title">
                <h3 id="solution-data-title">{solution.dataTitle}</h3>
                {solution.dataCards.map((card) => (
                  <article>
                    <h4>{card.title}</h4>
                    <p>{card.body}</p>
                  </article>
                ))}
              </section>
            </div>

            <h3 class="pg-substatement" id="solution-stack-title">{solution.stackTitle}</h3>
            <div class="pg-feature-grid" aria-labelledby="solution-stack-title">
              {solution.features.map((feature) => (
                <article class="pg-card pg-feature-card">
                  <span class="pg-tag">{feature.label}</span>
                  <h4>{feature.title}</h4>
                  <p>{feature.body}</p>
                </article>
              ))}
            </div>
          </div>
        </section>

        <!-- ================= AUDIENCES ================= -->
        <section id="audiences" class="pg-section">
          <div class="container">
            <div class="pg-statement">
              <h2>{audiences.title}</h2>
              <p>{audiences.body}</p>
            </div>

            <div class="pg-audience-grid">
              {saleTypes.map((item) => (
                <article class="pg-card pg-audience-card">
                  <h3>{item.title}</h3>
                  <p>{item.summary}</p>
                  <a class="pg-link" href={`/sale-types/${item.slug}/`}>مشاهده جزئیات ←</a>
                </article>
              ))}
            </div>
          </div>
        </section>

        <!-- ================= STAGES ================= -->
        <section id="stages" class="pg-section pg-section-tinted" aria-label="مراحل ساخت" data-stage-rotation>
          <div class="container">
            <div class="pg-stage-rail" role="tablist" aria-label="مراحل ساخت">
              {homeStageCards.map((stage, index) => (
                <button
                  class={index === 0 ? "pg-stage-tab active" : "pg-stage-tab"}
                  type="button"
                  role="tab"
                  aria-selected={index === 0 ? "true" : "false"}
                  aria-controls="stage-info-panel"
                  data-stage-index={index}
                >
                  {stage.title}
                </button>
              ))}
            </div>

            <article class="pg-stage-card" id="stage-info-panel" aria-live="polite">
              <div class="pg-stage-copy">
                <h3 data-stage-title>{initialHomeStage.title}</h3>
                <p data-stage-summary>{initialHomeStage.summary}</p>
              </div>
              <div class="pg-stage-side">
                <span>زمان تصمیم‌گیری سازنده</span>
                <p data-stage-source>{initialHomeStage.sourcePhase}</p>
                <a class="pg-btn pg-btn-amber" data-stage-link href={initialHomeStage.href}>مشاهده اطلاعات بیشتر</a>
              </div>
            </article>
          </div>
          <script is:inline type="application/json" id="home-stage-data" set:html={JSON.stringify(homeStageCards)} />
          <script is:inline>
            (() => {
              const root = document.querySelector("[data-stage-rotation]");
              const dataNode = document.getElementById("home-stage-data");
              if (!root || !dataNode) return;

              const stages = JSON.parse(dataNode.textContent || "[]");
              const buttons = [...root.querySelectorAll("[data-stage-index]")];
              const title = root.querySelector("[data-stage-title]");
              const summary = root.querySelector("[data-stage-summary]");
              const source = root.querySelector("[data-stage-source]");
              const link = root.querySelector("[data-stage-link]");
              let activeIndex = 0;
              let userLocked = false;
              let timerId = null;

              const selectStage = (index, lock = false) => {
                const stage = stages[index];
                if (!stage) return;

                activeIndex = index;
                buttons.forEach((button, buttonIndex) => {
                  const isActive = buttonIndex === index;
                  button.classList.toggle("active", isActive);
                  button.setAttribute("aria-selected", isActive ? "true" : "false");
                });

                if (title) title.textContent = stage.title;
                if (summary) summary.textContent = stage.summary;
                if (source) source.textContent = stage.sourcePhase;
                if (link) link.setAttribute("href", stage.href);

                if (lock && !userLocked) {
                  userLocked = true;
                  if (timerId) window.clearInterval(timerId);
                }
              };

              buttons.forEach((button) => {
                button.addEventListener("click", () => {
                  selectStage(Number(button.dataset.stageIndex), true);
                });
              });

              if (stages.length > 1) {
                timerId = window.setInterval(() => {
                  if (!userLocked) selectStage((activeIndex + 1) % stages.length);
                }, 10000);
              }
            })();
          </script>
        </section>

        <!-- ================= SALES FLOW ================= -->
        <section id="sales-flow" class="pg-section">
          <div class="container">
            <div class="pg-statement">
              <h2>{salesFlow.title}</h2>
            </div>

            <div class="pg-flow-grid" role="list" aria-label={salesFlow.ariaLabel}>
              {salesFlow.stages.map((stage) => (
                <article class="pg-card pg-flow-step" role="listitem">
                  <span class="pg-flow-number">{stage.number}</span>
                  <p class="pg-flow-summary"><strong>{stage.title} یعنی</strong> {stage.body}</p>
                  <p class="pg-flow-outcome"><strong>نتیجه:</strong> {stage.outcome}</p>
                </article>
              ))}
            </div>

            <div class="pg-center-cta">
              <a class="pg-btn pg-btn-amber" href="#demo">{salesFlow.cta} ←</a>
            </div>
          </div>
        </section>

        <!-- ================= PLANS ================= -->
        <section id="plans" class="pg-section pg-section-tinted">
          <div class="container">
            <div class="pg-statement">
              <h2>{pricing.title}</h2>
              <p>{pricing.description}</p>
            </div>

            <div class="pg-duration-tabs" role="tablist" aria-label="مدت اشتراک" data-active-duration={defaultDuration}>
              {pricing.durations.map((duration) => (
                <button
                  class={duration.id === defaultDuration ? "pg-duration-tab active" : "pg-duration-tab"}
                  type="button"
                  role="tab"
                  aria-selected={duration.id === defaultDuration ? "true" : "false"}
                  aria-pressed={duration.id === defaultDuration ? "true" : "false"}
                  data-plan-duration={duration.id}
                >
                  <span class="pg-duration-number">{duration.id}</span>
                  <span class="pg-duration-unit">ماهه</span>
                </button>
              ))}
            </div>

            <div class="pg-pricing-grid">
              {pricing.plans.map((plan) => (
                <article class="pg-card pg-price-card">
                  <header class="pg-price-head">
                    <span class="pg-plan-mark" role="img" aria-label={plan.iconAlt}>
                      <i class="pg-plan-ring" aria-hidden="true"></i>
                      <i class="pg-plan-dot" aria-hidden="true"></i>
                    </span>
                    <h3>{plan.name}</h3>
                  </header>
                  <strong class="pg-price">
                    <span
                      class="pg-price-number"
                      data-plan-price
                      data-prices={JSON.stringify(plan.prices)}
                    >
                      {plan.prices[defaultDuration]}
                    </span>
                    <span class="pg-price-currency">{pricing.currency}</span>
                  </strong>
                  <p class="pg-plan-scope">
                    <span>{plan.landLine}</span>
                    <span class="pg-plan-scope-separator" aria-hidden="true">-</span>
                    <span>{pricing.stagesIncluded}</span>
                  </p>
                  <ul class="pg-plan-highlights">
                    {plan.highlights.map((item) => <li>{item}</li>)}
                  </ul>
                  <div class="pg-coverage" aria-label={`${pricing.coverage} ${plan.coverageLabel}`}>
                    <strong>{pricing.coverage}</strong>
                    <div class="pg-coverage-meter" aria-hidden="true">
                      {coverageDots.map((dot) => <i class={dot < plan.coverageLevel ? "filled" : ""}></i>)}
                    </div>
                  </div>
                  <p class="pg-plan-addon">
                    <span>هر مرحله اضافه:</span>
                    <span class="pg-addon-price">
                      <span>{plan.addonPrice}</span>
                      <span>{pricing.currency}</span>
                    </span>
                  </p>
                  <a class="pg-btn pg-btn-ink" href={`/subscriptions/${plan.slug}/`}>{plan.cta}</a>
                </article>
              ))}
            </div>
          </div>
        </section>

        <script is:inline>
          (() => {
            const plansSection = document.getElementById("plans");
            if (!plansSection) return;

            const durationTabs = plansSection.querySelector(".pg-duration-tabs");
            const buttons = Array.from(plansSection.querySelectorAll("[data-plan-duration]"));
            const priceNodes = Array.from(plansSection.querySelectorAll("[data-plan-price]"));

            const setDuration = (duration) => {
              durationTabs?.setAttribute("data-active-duration", duration);

              buttons.forEach((button) => {
                const isActive = button.getAttribute("data-plan-duration") === duration;
                button.classList.toggle("active", isActive);
                button.setAttribute("aria-selected", String(isActive));
                button.setAttribute("aria-pressed", String(isActive));
              });

              priceNodes.forEach((node) => {
                const prices = JSON.parse(node.getAttribute("data-prices") || "{}");
                if (prices[duration]) {
                  node.textContent = prices[duration];
                }
              });
            };

            buttons.forEach((button) => {
              button.addEventListener("click", () => {
                const duration = button.getAttribute("data-plan-duration");
                if (duration) setDuration(duration);
              });
            });
          })();
        </script>

