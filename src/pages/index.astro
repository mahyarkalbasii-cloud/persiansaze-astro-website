---
import "../styles/global.css";
import AudienceSection from "@/components/home/AudienceSection.astro";
import DemoSection from "@/components/home/DemoSection.astro";
import FaqSection from "@/components/home/FaqSection.astro";
import HeroSection from "@/components/home/HeroSection.astro";
import HomeFooter from "@/components/home/HomeFooter.astro";
import HomeHeader from "@/components/home/HomeHeader.astro";
import PricingSection from "@/components/home/PricingSection.astro";
import ProblemSection from "@/components/home/ProblemSection.astro";
import SalesFlowSection from "@/components/home/SalesFlowSection.astro";
import SolutionSection from "@/components/home/SolutionSection.astro";
import StagesSection from "@/components/home/StagesSection.astro";
import PersianDigitsScript from "@/components/PersianDigitsScript.astro";
import {
  audiences,
  demo,
  faqSection,
  faqs,
  hero,
  ids,
  metadata,
  pricing,
  problem,
  salesFlow,
  site,
  solution,
} from "@/content/home";
import { constructionStages, workFields } from "@/content/construction";
import { saleTypes } from "@/content/sales";

const primaryContact = site.contacts[0];
const defaultDuration = "3" as const;
const homeConstructionStages = constructionStages.filter((stage) => stage.id !== "permit-design");
const toPersianDigits = (value: string | number) => String(value).replace(/\d/g, (digit) => "Û°Û±Û²Û³Û´ÛµÛ¶Û·Û¸Û¹"[Number(digit)]);
const homeStageCards = homeConstructionStages.map((stage) => ({
  title: stage.title,
  sourcePhase: toPersianDigits(stage.sourcePhase),
  summary: toPersianDigits(stage.summary),
  href: `/construction-stages/${stage.slug}/`,
}));
const initialHomeStage = homeStageCards[0];
const demoWorkFieldOptions = workFields.map((field) => field.title);
const coverageDots = Array.from({ length: 4 }, (_, index) => index);
const schemaGraph = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "@id": ids.organization,
    name: site.name,
    legalName: site.legalName,
    alternateName: site.alternateName,
    url: site.url,
    description: site.description,
    foundingDate: site.foundingDate,
    email: site.email,
    telephone: primaryContact.telephone,
    address: {
      "@type": "PostalAddress",
      ...site.postalAddress,
    },
    contactPoint: site.contacts.map((contact) => ({
      "@type": "ContactPoint",
      name: contact.label,
      telephone: contact.telephone,
      contactType: contact.contactType,
      areaServed: "IR",
      availableLanguage: ["fa-IR", "Persian"],
    })),
    sameAs: site.sameAs,
  },
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "@id": ids.localBusiness,
    additionalType: "https://schema.org/ProfessionalService",
    name: site.name,
    legalName: site.legalName,
    alternateName: site.alternateName,
    description: site.description,
    url: site.url,
    telephone: primaryContact.telephone,
    email: site.email,
    priceRange: "$$",
    address: {
      "@type": "PostalAddress",
      ...site.postalAddress,
    },
    openingHours: site.openingHours,
    openingHoursSpecification: site.openingHoursSpecification.map((item) => ({
      "@type": "OpeningHoursSpecification",
      ...item,
    })),
    areaServed: site.areaServed.map((name) => ({
      "@type": "City",
      name,
    })),
    parentOrganization: { "@id": ids.organization },
    sameAs: site.sameAs,
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "@id": ids.website,
    name: site.name,
    url: site.url,
    inLanguage: "fa-IR",
    publisher: { "@id": ids.organization },
  },
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    name: metadata.pageName,
    url: site.url,
    inLanguage: "fa-IR",
    isPartOf: { "@id": ids.website },
    publisher: { "@id": ids.organization },
    description: metadata.pageDescription,
    about: ["Ù¾Ø±ÙˆÚ˜Ù‡â€ŒÙ‡Ø§ÛŒ Ø³Ø§Ø®ØªÙ…Ø§Ù†ÛŒ", "Ù†Ù‚Ø´Ù‡ Ù¾Ø±ÙˆÚ˜Ù‡â€ŒÙ‡Ø§", "Ù…Ø±Ø­Ù„Ù‡ Ø³Ø§Ø®Øª", "ÙØ±ÙˆØ´ Ù¾Ø±ÙˆÚ˜Ù‡â€ŒÙ…Ø­ÙˆØ±", "Ù¾ÛŒÚ¯ÛŒØ±ÛŒ ÙØ±ÙˆØ´"].map((name) => ({
      "@type": "Thing",
      name,
    })),
  },
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "@id": ids.software,
    name: site.name,
    applicationCategory: "BusinessApplication",
    operatingSystem: "Web",
    url: site.url,
    inLanguage: "fa-IR",
    description: site.description,
    publisher: { "@id": ids.organization },
    offers: {
      "@type": "Offer",
      priceCurrency: "IRR",
      availability: "https://schema.org/InStock",
      url: `${site.url}/subscriptions/`,
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqs.map((item) => ({
      "@type": "Question",
      name: item.question,
      acceptedAnswer: {
        "@type": "Answer",
        text: item.answer,
      },
    })),
  },
];
---

<!doctype html>
<html lang="fa-IR" dir="rtl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{metadata.title}</title>
    <meta name="description" content={metadata.description} />
    <meta name="keywords" content={metadata.keywords.join(", ")} />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <link rel="canonical" href={site.url} />
    <link rel="icon" href="data:," />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="fa_IR" />
    <meta property="og:url" content={site.url} />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={metadata.title} />
    <meta property="og:description" content={metadata.description} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={metadata.title} />
    <meta name="twitter:description" content={metadata.description} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(schemaGraph)} />
  </head>
  <body class="home-anthropic">
    <HomeHeader />

    <main class="home-page">
      <HeroSection hero={hero} />
      <ProblemSection problem={problem} />
      <SolutionSection solution={solution} />
      <AudienceSection audiences={audiences} saleTypes={saleTypes} />
      <StagesSection homeStageCards={homeStageCards} initialHomeStage={initialHomeStage} />
      <SalesFlowSection salesFlow={salesFlow} />
      <PricingSection pricing={pricing} defaultDuration={defaultDuration} coverageDots={coverageDots} />
      <FaqSection faqSection={faqSection} faqs={faqs} />
      <DemoSection demo={demo} site={site} demoWorkFieldOptions={demoWorkFieldOptions} />
    </main>

    <HomeFooter />
    <PersianDigitsScript />
  </body>
</html>
