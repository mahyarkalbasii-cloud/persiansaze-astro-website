---
import "../styles/global.css";
import SiteFooter from "@/components/SiteFooter.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import PersianDigitsScript from "@/components/PersianDigitsScript.astro";
import {
  audiences,
  demo,
  faqSection,
  faqs,
  hero,
  ids,
  metadata,
  pricing,
  problem,
  salesFlow,
  site,
  solution,
} from "@/content/home";
import { constructionStages, workFields } from "@/content/construction";
import { saleTypes } from "@/content/sales";

const primaryContact = site.contacts[0];
const defaultDuration = "3" as const;
const homeConstructionStages = constructionStages.filter((stage) => stage.id !== "permit-design");
const toPersianDigits = (value: string | number) => String(value).replace(/\d/g, (digit) => "۰۱۲۳۴۵۶۷۸۹"[Number(digit)]);
const homeStageCards = homeConstructionStages.map((stage) => ({
  title: stage.title,
  sourcePhase: toPersianDigits(stage.sourcePhase),
  summary: toPersianDigits(stage.summary),
  href: `/construction-stages/${stage.slug}/`,
}));
const initialHomeStage = homeStageCards[0];
const demoWorkFieldOptions = workFields.map((field) => field.title);
const coverageDots = Array.from({ length: 4 }, (_, index) => index);
const schemaGraph = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "@id": ids.organization,
    name: site.name,
    legalName: site.legalName,
    alternateName: site.alternateName,
    url: site.url,
    description: site.description,
    foundingDate: site.foundingDate,
    email: site.email,
    telephone: primaryContact.telephone,
    address: {
      "@type": "PostalAddress",
      ...site.postalAddress,
    },
    contactPoint: site.contacts.map((contact) => ({
      "@type": "ContactPoint",
      name: contact.label,
      telephone: contact.telephone,
      contactType: contact.contactType,
      areaServed: "IR",
      availableLanguage: ["fa-IR", "Persian"],
    })),
    sameAs: site.sameAs,
  },
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "@id": ids.localBusiness,
    additionalType: "https://schema.org/ProfessionalService",
    name: site.name,
    legalName: site.legalName,
    alternateName: site.alternateName,
    description: site.description,
    url: site.url,
    telephone: primaryContact.telephone,
    email: site.email,
    priceRange: "$$",
    address: {
      "@type": "PostalAddress",
      ...site.postalAddress,
    },
    openingHours: site.openingHours,
    openingHoursSpecification: site.openingHoursSpecification.map((item) => ({
      "@type": "OpeningHoursSpecification",
      ...item,
    })),
    areaServed: site.areaServed.map((name) => ({
      "@type": "City",
      name,
    })),
    parentOrganization: { "@id": ids.organization },
    sameAs: site.sameAs,
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "@id": ids.website,
    name: site.name,
    url: site.url,
    inLanguage: "fa-IR",
    publisher: { "@id": ids.organization },
  },
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    name: metadata.pageName,
    url: site.url,
    inLanguage: "fa-IR",
    isPartOf: { "@id": ids.website },
    publisher: { "@id": ids.organization },
    description: metadata.pageDescription,
    about: ["پروژه‌های ساختمانی", "نقشه پروژه‌ها", "مرحله ساخت", "فروش پروژه‌محور", "پیگیری فروش"].map((name) => ({
      "@type": "Thing",
      name,
    })),
  },
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "@id": ids.software,
    name: site.name,
    applicationCategory: "BusinessApplication",
    operatingSystem: "Web",
    url: site.url,
    inLanguage: "fa-IR",
    description: site.description,
    publisher: { "@id": ids.organization },
    offers: {
      "@type": "Offer",
      priceCurrency: "IRR",
      availability: "https://schema.org/InStock",
      url: `${site.url}/subscriptions/`,
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqs.map((item) => ({
      "@type": "Question",
      name: item.question,
      acceptedAnswer: {
        "@type": "Answer",
        text: item.answer,
      },
    })),
  },
];
---

<!doctype html>
<html lang="fa-IR" dir="rtl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{metadata.title}</title>
    <meta name="description" content={metadata.description} />
    <meta name="keywords" content={metadata.keywords.join(", ")} />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <link rel="canonical" href={site.url} />
    <link rel="icon" href="data:," />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="fa_IR" />
    <meta property="og:url" content={site.url} />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={metadata.title} />
    <meta property="og:description" content={metadata.description} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={metadata.title} />
    <meta name="twitter:description" content={metadata.description} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(schemaGraph)} />
  </head>
  <body class="home-color-anthropic">
    <SiteHeader home />

    <main class="ah-home">
      <section id="hero" class="ah-hero">
        <div class="container ah-hero-grid">
          <div class="ah-hero-copy">
            <h1>
              <span>{hero.titleLines[0]}</span>
              <span>{hero.titleLines[1]}</span>
            </h1>
            <p class="ah-lead">{hero.body}</p>
            <div class="ah-actions">
              <a class="ah-btn ah-btn-primary" href="#demo">{hero.primaryCta}</a>
              <a class="ah-btn ah-btn-outline" href="#problem">{hero.secondaryCta}</a>
            </div>
          </div>

          <div class="ah-placeholder ah-hero-art">
            <svg class="ah-placeholder-mark" viewBox="0 0 48 48" fill="none" aria-hidden="true">
              <rect x="4" y="4" width="40" height="40" rx="10" stroke="currentColor" stroke-width="2" stroke-dasharray="5 5" />
              <circle cx="18" cy="20" r="5" stroke="currentColor" stroke-width="2" />
              <path d="M10 36L20 27L28 32L38 22" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            <span class="ah-placeholder-label">{hero.placeholder}</span>
          </div>
        </div>
      </section>

      <section id="problem" class="ah-section">
        <div class="container ah-split">
          <article class="ah-card ah-problem-card">
            <header class="ah-problem-head">
              <span class="ah-eyebrow">روایت مسئله بازار</span>
              <strong>فرصت ساختمانی وقتی ارزش دارد که به‌موقع دیده شود.</strong>
            </header>

            <div class="ah-placeholder ah-problem-art">
              <svg class="ah-placeholder-mark" viewBox="0 0 48 48" fill="none" aria-hidden="true">
                <rect x="4" y="4" width="40" height="40" rx="10" stroke="currentColor" stroke-width="2" stroke-dasharray="5 5" />
                <circle cx="16" cy="30" r="4" stroke="currentColor" stroke-width="2" />
                <circle cx="32" cy="18" r="4" stroke="currentColor" stroke-width="2" />
                <path d="M19 27L29 21" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-dasharray="3 4" />
              </svg>
              <span class="ah-placeholder-label">{problem.placeholder}</span>
            </div>

            <div class="ah-chip">
              <span>پنجره تماس</span>
              <strong>زودتر از رقبا، نه زودتر از نیاز</strong>
            </div>

            <div class="ah-mini-grid">
              <article>
                <span>پراکندگی</span>
                <strong>پروژه‌ها روی چند مسیر پخش‌اند</strong>
              </article>
              <article>
                <span>زمان تماس</span>
                <strong>زود یا دیر، هر دو فرصت را می‌سوزاند</strong>
              </article>
              <article>
                <span>پیگیری</span>
                <strong>بدون نظم، فرصت‌ها در صف می‌مانند</strong>
              </article>
            </div>
          </article>

          <div class="ah-section-copy">
            <h2>{problem.title}</h2>
            <p>{problem.body}</p>
            <a class="ah-btn ah-btn-outline" href="#solution">{problem.cta}</a>
          </div>
        </div>
      </section>

      <section id="solution" class="ah-section ah-section-tinted">
        <div class="container">
          <div class="ah-heading">
            <h2>{solution.title}</h2>
            <p>{solution.body}</p>
          </div>

          <div class="ah-solution-grid">
            <figure class="ah-placeholder ah-solution-art" aria-label={solution.visualAlt}>
              <svg class="ah-placeholder-mark" viewBox="0 0 48 48" fill="none" aria-hidden="true">
                <rect x="4" y="4" width="40" height="40" rx="10" stroke="currentColor" stroke-width="2" stroke-dasharray="5 5" />
                <path d="M14 14H26" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                <path d="M14 22H34" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                <path d="M14 30H22" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                <circle cx="32" cy="32" r="4" stroke="currentColor" stroke-width="2" />
              </svg>
              <span class="ah-placeholder-label">{solution.dashboardPlaceholder}</span>
            </figure>

            <section class="ah-card ah-data-panel" aria-labelledby="solution-data-title">
              <h3 id="solution-data-title">{solution.dataTitle}</h3>
              <div class="ah-data-list">
                {solution.dataCards.map((card) => (
                  <article>
                    <h4>{card.title}</h4>
                    <p>{card.body}</p>
                  </article>
                ))}
              </div>
            </section>
          </div>

          <section class="ah-stack-panel" aria-labelledby="solution-stack-title">
            <h3 id="solution-stack-title">{solution.stackTitle}</h3>
            <div class="ah-feature-grid">
              {solution.features.map((feature) => (
                <article class="ah-card">
                  <span class="ah-badge">{feature.label}</span>
                  <h4>{feature.title}</h4>
                  <p>{feature.body}</p>
                </article>
              ))}
            </div>
          </section>
        </div>
      </section>

      <section id="audiences" class="ah-section">
        <div class="container">
          <div class="ah-heading">
            <h2>{audiences.title}</h2>
            <p>{audiences.body}</p>
          </div>

          <div class="ah-audience-grid">
            {saleTypes.map((item) => (
              <article class="ah-card ah-audience-card">
                <h3>{item.title}</h3>
                <p>{item.summary}</p>
                <a class="ah-link" href={`/sale-types/${item.slug}/`}>مشاهده جزئیات ←</a>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section id="stages" class="ah-section ah-section-tinted" aria-label="مراحل ساخت" data-stage-rotation>
        <div class="container">
          <div class="ah-tabs" role="tablist" aria-label="مراحل ساخت">
            {homeStageCards.map((stage, index) => (
              <button
                class={index === 0 ? "ah-tab active" : "ah-tab"}
                type="button"
                role="tab"
                aria-selected={index === 0 ? "true" : "false"}
                aria-controls="stage-info-panel"
                data-stage-index={index}
              >
                {stage.title}
              </button>
            ))}
          </div>

          <article class="ah-card ah-stage-card" id="stage-info-panel" aria-live="polite">
            <div class="ah-stage-copy">
              <h3 data-stage-title>{initialHomeStage.title}</h3>
              <p data-stage-summary>{initialHomeStage.summary}</p>
            </div>
            <div class="ah-stage-side">
              <span>زمان تصمیم‌گیری سازنده</span>
              <p data-stage-source>{initialHomeStage.sourcePhase}</p>
              <a class="ah-btn ah-btn-primary" data-stage-link href={initialHomeStage.href}>مشاهده اطلاعات بیشتر</a>
            </div>
          </article>
        </div>
        <script is:inline type="application/json" id="home-stage-data" set:html={JSON.stringify(homeStageCards)} />
        <script is:inline>
          (() => {
            const root = document.querySelector("[data-stage-rotation]");
            const dataNode = document.getElementById("home-stage-data");
            if (!root || !dataNode) return;

            const stages = JSON.parse(dataNode.textContent || "[]");
            const buttons = [...root.querySelectorAll("[data-stage-index]")];
            const title = root.querySelector("[data-stage-title]");
            const summary = root.querySelector("[data-stage-summary]");
            const source = root.querySelector("[data-stage-source]");
            const link = root.querySelector("[data-stage-link]");
            let activeIndex = 0;
            let userLocked = false;
            let timerId = null;

            const selectStage = (index, lock = false) => {
              const stage = stages[index];
              if (!stage) return;

              activeIndex = index;
              buttons.forEach((button, buttonIndex) => {
                const isActive = buttonIndex === index;
                button.classList.toggle("active", isActive);
                button.setAttribute("aria-selected", isActive ? "true" : "false");
              });

              if (title) title.textContent = stage.title;
              if (summary) summary.textContent = stage.summary;
              if (source) source.textContent = stage.sourcePhase;
              if (link) link.setAttribute("href", stage.href);

              if (lock && !userLocked) {
                userLocked = true;
                if (timerId) window.clearInterval(timerId);
              }
            };

            buttons.forEach((button) => {
              button.addEventListener("click", () => {
                selectStage(Number(button.dataset.stageIndex), true);
              });
            });

            if (stages.length > 1) {
              timerId = window.setInterval(() => {
                if (!userLocked) selectStage((activeIndex + 1) % stages.length);
              }, 10000);
            }
          })();
        </script>
      </section>

      <section id="sales-flow" class="ah-section">
        <div class="container">
          <div class="ah-heading">
            <h2>{salesFlow.title}</h2>
          </div>

          <div class="ah-flow-grid" role="list" aria-label={salesFlow.ariaLabel}>
            {salesFlow.stages.map((stage) => (
              <article class="ah-card ah-flow-step" role="listitem">
                <span class="ah-step-number">{stage.number}</span>
                <p class="ah-flow-summary"><strong>{stage.title} یعنی</strong> {stage.body}</p>
                <p class="ah-flow-outcome"><strong>نتیجه:</strong> {stage.outcome}</p>
              </article>
            ))}
          </div>

          <div class="ah-flow-footer">
            <a class="ah-btn ah-btn-primary" href="#demo">{salesFlow.cta} ←</a>
          </div>
        </div>
      </section>

      <section id="plans" class="ah-section ah-section-tinted">
        <div class="container">
          <div class="ah-heading ah-heading-centered">
            <h2>{pricing.title}</h2>
            <p>{pricing.description}</p>
          </div>

          <div class="ah-tabs ah-duration-tabs" role="tablist" aria-label="مدت اشتراک" data-active-duration={defaultDuration}>
            {pricing.durations.map((duration) => (
              <button
                class={duration.id === defaultDuration ? "ah-tab active" : "ah-tab"}
                type="button"
                role="tab"
                aria-selected={duration.id === defaultDuration ? "true" : "false"}
                aria-pressed={duration.id === defaultDuration ? "true" : "false"}
                data-plan-duration={duration.id}
              >
                <span class="ah-duration-number">{duration.id}</span>
                <span class="ah-duration-unit">ماهه</span>
              </button>
            ))}
          </div>

          <div class="ah-pricing-grid">
            {pricing.plans.map((plan) => (
              <article class="ah-card ah-price-card">
                <header class="ah-price-head">
                  <span class="ah-plan-mark" role="img" aria-label={plan.iconAlt}>
                    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                      <rect x="3" y="3" width="18" height="18" rx="5" stroke="currentColor" stroke-width="1.5" stroke-dasharray="3 3" />
                      <circle cx="12" cy="12" r="3.5" stroke="currentColor" stroke-width="1.5" />
                    </svg>
                  </span>
                  <h3>{plan.name}</h3>
                </header>
                <strong class="ah-price">
                  <span
                    class="ah-price-number"
                    data-plan-price
                    data-prices={JSON.stringify(plan.prices)}
                  >
                    {plan.prices[defaultDuration]}
                  </span>
                  <span class="ah-price-currency">{pricing.currency}</span>
                </strong>
                <p class="ah-plan-scope">
                  <span>{plan.landLine}</span>
                  <span class="ah-plan-scope-separator" aria-hidden="true">-</span>
                  <span>{pricing.stagesIncluded}</span>
                </p>
                <ul class="ah-plan-highlights">
                  {plan.highlights.map((item) => <li>{item}</li>)}
                </ul>
                <div class="ah-coverage" aria-label={`${pricing.coverage} ${plan.coverageLabel}`}>
                  <strong>{pricing.coverage}</strong>
                  <div class="ah-coverage-meter" aria-hidden="true">
                    {coverageDots.map((dot) => <i class={dot < plan.coverageLevel ? "filled" : ""}></i>)}
                  </div>
                </div>
                <p class="ah-plan-addon">
                  <span>هر مرحله اضافه:</span>
                  <span class="ah-addon-price">
                    <span>{plan.addonPrice}</span>
                    <span>{pricing.currency}</span>
                  </span>
                </p>
                <a class="ah-btn ah-btn-outline" href={`/subscriptions/${plan.slug}/`}>{plan.cta}</a>
              </article>
            ))}
          </div>
        </div>
      </section>

      <script is:inline>
        (() => {
          const plansSection = document.getElementById("plans");
          if (!plansSection) return;

          const durationTabs = plansSection.querySelector(".ah-duration-tabs");
          const buttons = Array.from(plansSection.querySelectorAll("[data-plan-duration]"));
          const priceNodes = Array.from(plansSection.querySelectorAll("[data-plan-price]"));

          const setDuration = (duration) => {
            durationTabs?.setAttribute("data-active-duration", duration);

            buttons.forEach((button) => {
              const isActive = button.getAttribute("data-plan-duration") === duration;
              button.classList.toggle("active", isActive);
              button.setAttribute("aria-selected", String(isActive));
              button.setAttribute("aria-pressed", String(isActive));
            });

            priceNodes.forEach((node) => {
              const prices = JSON.parse(node.getAttribute("data-prices") || "{}");
              if (prices[duration]) {
                node.textContent = prices[duration];
              }
            });
          };

          buttons.forEach((button) => {
            button.addEventListener("click", () => {
              const duration = button.getAttribute("data-plan-duration");
              if (duration) setDuration(duration);
            });
          });
        })();
      </script>

      <section id="faq" class="ah-section">
        <div class="container">
          <div class="ah-heading ah-heading-centered">
            <span class="ah-eyebrow">{faqSection.eyebrow}</span>
            <h2>{faqSection.title}</h2>
            <p>{faqSection.description}</p>
          </div>
          <div class="ah-faq">
            {faqs.map((item) => (
              <details class="ah-faq-item">
                <summary>
                  {item.question}
                  <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path d="M6 9L12 15L18 9" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </summary>
                <p>{item.answer}</p>
              </details>
            ))}
          </div>
        </div>
      </section>

      <section id="demo" class="ah-demo">
        <div class="container ah-demo-grid">
          <div class="ah-demo-copy">
            <h2>{demo.title}</h2>
            <p>{demo.body}</p>

            <div class="ah-demo-path">
              <strong>{demo.pathTitle}</strong>
              <ol>
                {demo.steps.map((step) => (
                  <li>{step}</li>
                ))}
              </ol>
            </div>
          </div>

          <form class="ah-card ah-demo-form" action={`mailto:${site.email}`} method="post" enctype="text/plain">
            <h3>{demo.form.submit}</h3>
            <div class="ah-form-grid">
              <label class="ah-field">
                <span>{demo.form.name}</span>
                <input name="name" autocomplete="name" />
              </label>
              <label class="ah-field">
                <span>{demo.form.phone}</span>
                <input name="phone" autocomplete="tel" inputmode="tel" dir="ltr" />
              </label>
              <label class="ah-field">
                <span>{demo.form.company}</span>
                <input name="company" autocomplete="organization" />
              </label>
              <label class="ah-field">
                <span>{demo.form.referralSource}</span>
                <select name="referralSource">
                  <option value="">{demo.form.choose}</option>
                  {demo.form.referralSourceOptions.map((option) => (
                    <option value={option}>{option}</option>
                  ))}
                </select>
              </label>
            </div>
            <label class="ah-field">
              <span>{demo.form.supplier}</span>
              <select name="supplier">
                <option value="">{demo.form.choose}</option>
                {demoWorkFieldOptions.map((option) => (
                  <option value={option}>{option}</option>
                ))}
              </select>
            </label>
            <button class="ah-btn ah-btn-primary" type="submit">{demo.form.submit}</button>
          </form>
        </div>
      </section>
    </main>

    <SiteFooter />
    <PersianDigitsScript />
  </body>
</html>

<style>
  main.ah-home {
    --ah-paper: #faf9f5;
    --ah-ink: #141413;
    --ah-ink-soft: #3d3d3a;
    --ah-muted: #6e6a60;
    --ah-oat: #f0eee6;
    --ah-card: #ffffff;
    --ah-border: rgba(20, 20, 19, 0.12);
    --ah-border-strong: rgba(20, 20, 19, 0.22);
    --ah-accent: #d97757;
    --ah-accent-ink: #b4552f;
    --ah-accent-soft: rgba(217, 119, 87, 0.12);
    --ah-radius: 1.25rem;
    --ah-radius-sm: 0.75rem;
    background: var(--ah-paper);
    color: var(--ah-ink);
  }

  /* ---------- Primitives (shadcn/ui-like) ---------- */

  .ah-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    border: 1px solid transparent;
    border-radius: 9999px;
    padding: 0.7rem 1.6rem;
    font-size: 0.95rem;
    font-weight: 600;
    line-height: 1.4;
    cursor: pointer;
    white-space: nowrap;
    transition: background-color 160ms ease, color 160ms ease, border-color 160ms ease, transform 160ms ease;
  }

  .ah-btn-primary {
    background: var(--ah-ink);
    color: var(--ah-paper);
  }

  .ah-btn-primary:hover {
    background: var(--ah-ink-soft);
    transform: translateY(-1px);
  }

  .ah-btn-outline {
    background: transparent;
    border-color: var(--ah-border-strong);
    color: var(--ah-ink);
  }

  .ah-btn-outline:hover {
    background: var(--ah-card);
