---
import Layout from "@/layouts/Layout.astro";
import { site } from "@/content/home";
import { projectCities, projectNeighborhoodBySlug } from "@/content/neighborhoods";
import { getCollection, type CollectionEntry } from "astro:content";

const title = "پروژه‌های در حال ساخت بر اساس شهر و محله | پرشین‌سازه";
const description =
  "فهرست شهرها، محله‌ها و محدوده‌های پروژه‌محور پرشین‌سازه برای تامین‌کنندگان ساختمانی که می‌خواهند فرصت‌های فعال را بر اساس موقعیت و مرحله ساخت رصد کنند.";
const canonicalPath = "/projects/";
type NeighborhoodEntry = CollectionEntry<"neighborhoods">;
type DirectoryNeighborhood = {
  entry: NeighborhoodEntry;
  route: NonNullable<ReturnType<typeof projectNeighborhoodBySlug.get>>;
};

const neighborhoodEntries = await getCollection("neighborhoods");
const directoryNeighborhoods = neighborhoodEntries
  .map((entry): DirectoryNeighborhood | null => {
    const route = projectNeighborhoodBySlug.get(entry.data.slug);
    return route ? { entry, route } : null;
  })
  .filter((item): item is DirectoryNeighborhood => item !== null)
  .sort((a, b) => a.route.name.localeCompare(b.route.name, "fa"));

const cityCards = projectCities
  .map((city) => ({
    ...city,
    neighborhoods: directoryNeighborhoods.filter((item) => item.route.projectCitySlug === city.slug),
  }))
  .filter((city) => city.neighborhoods.length > 0);
const totalNeighborhoods = cityCards.reduce((total, city) => total + city.neighborhoods.length, 0);
const neighborhoodListItems = cityCards.flatMap((city) =>
  city.neighborhoods.map(({ entry, route }) => ({
    city,
    entry,
    route,
    href: `/projects/${city.slug}/${route.slug}/`,
  })),
);
const structuredData = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: title,
  description,
  url: new URL(canonicalPath, Astro.site).toString(),
  inLanguage: "fa-IR",
  isPartOf: { "@id": `${site.url}/#website` },
  mainEntity: {
    "@type": "ItemList",
    name: "PersianSaze project location directory",
    itemListElement: neighborhoodListItems.map((item, index) => ({
      "@type": "ListItem",
      position: index + 1,
      name: `${item.entry.data.neighborhood} - ${item.city.name}`,
      url: new URL(item.href, Astro.site).toString(),
      description: item.entry.data.focus,
    })),
  },
  hasPart: cityCards.map((city) => ({
    "@type": "CollectionPage",
    name: city.name,
    url: new URL(`/projects/${city.slug}/`, Astro.site).toString(),
    description: city.summary,
  })),
};
---

<Layout title={title} description={description} canonicalPath={canonicalPath} structuredData={structuredData}>
  <main>
    <section class="content-hero city-index-hero">
      <div class="container content-hero-grid">
        <div>
          <p class="content-eyebrow">پروژه‌ها</p>
          <h1>پروژه‌های ساختمانی را شهر و محله به محله دنبال کنید</h1>
          <p>
            این نقشه محتوایی، شهرها و محدوده‌های پروژه‌محور پرشین‌سازه را به صفحه‌های محله‌ای متصل می‌کند تا تامین‌کننده بتواند بازار هدف را دقیق‌تر انتخاب کند.
          </p>
          <div class="action-row">
            <a class="button button-primary" href="/#demo">درخواست دمو</a>
            <a class="button button-secondary" href="/cities/">پرونده‌های شهری</a>
          </div>
        </div>
        <aside class="content-summary-card city-index-summary">
          <strong>{totalNeighborhoods}</strong>
          <span>صفحه محله‌ای</span>
          <p>خوشه‌بندی شده بر اساس شهر، کریدور ساختمانی و تقاضای فنی تامین‌کنندگان</p>
        </aside>
      </div>
    </section>

    <section class="section project-index-section">
      <div class="container project-directory-layout">
        <aside class="project-directory-summary">
          <p class="content-eyebrow">HTML Sitemap</p>
          <h2>فهرست کامل شهرهای تحت پوشش</h2>
          <p>
            این صفحه همه مسیرهای محله‌ای را از یک نقطه به هم وصل می‌کند؛ هم برای کاربر انسانی، هم برای خزنده‌های گوگل و موتورهای GEO.
          </p>
          <dl class="project-city-meta">
            <div>
              <dt>شهر و کریدور</dt>
              <dd class="project-city-count"><strong>{cityCards.length}</strong><span>خوشه فعال</span></dd>
            </div>
            <div>
              <dt>صفحه محله‌ای</dt>
              <dd class="project-city-count"><strong>{totalNeighborhoods}</strong><span>لینک مستقیم</span></dd>
            </div>
          </dl>
          <nav class="project-directory-city-nav" aria-label="پرش به خوشه‌های شهری">
            {cityCards.map((city) => (
              <a href={`#projects-${city.slug}`}>
                <span>{city.name}</span>
                <strong>{city.neighborhoods.length}</strong>
              </a>
            ))}
          </nav>
        </aside>

        <div class="project-directory-main">
          {cityCards.map((city) => (
            <section class="project-directory-panel" id={`projects-${city.slug}`} aria-labelledby={`projects-${city.slug}-title`}>
              <p class="content-eyebrow">{city.province}</p>
              <h2 id={`projects-${city.slug}-title`}>{city.name}</h2>
              <p>{city.summary}</p>
              <a class="text-link project-city-direct-link" href={`/projects/${city.slug}/`}>
                مشاهده صفحه خوشه {city.name}
              </a>
              <div class="project-neighborhood-grid">
                {city.neighborhoods.map(({ entry, route }) => (
                  <article class="project-neighborhood-card">
                    <div class="project-neighborhood-card-copy">
                      <p class="content-eyebrow">{city.name}</p>
                      <h3>
                        <a href={`/projects/${city.slug}/${route.slug}/`}>{entry.data.neighborhood}</a>
                      </h3>
                      <p><strong>{entry.data.focus}</strong></p>
                    </div>
                    <ul class="project-signal-list">
                      {route.demandSignals.slice(0, 3).map((signal) => (
                        <li>{signal}</li>
                      ))}
                    </ul>
                    <a class="text-link" href={`/projects/${city.slug}/${route.slug}/`}>
                      تحلیل پروژه‌های {entry.data.neighborhood}
                    </a>
                  </article>
                ))}
              </div>
            </section>
          ))}
        </div>
      </div>
    </section>
  </main>
</Layout>
