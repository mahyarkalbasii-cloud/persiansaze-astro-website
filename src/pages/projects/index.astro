---
import Layout from "@/layouts/Layout.astro";
import { site } from "@/content/home";
import { projectHubCities, projectNeighborhoodBySlug, type ProjectHubCity } from "@/content/neighborhoods";
import { getCollection, type CollectionEntry } from "astro:content";

const title = "شهرهای تحت پوشش پروژه‌های در حال ساخت | پرشین‌سازه";
const description =
  "هاب شهرهای پرشین‌سازه برای دسترسی به محله‌ها و محدوده‌های پروژه‌محور تهران، کرج و لواسان.";
const canonicalPath = "/projects/";
type NeighborhoodEntry = CollectionEntry<"neighborhoods">;
type HubCityCard = ProjectHubCity & {
  neighborhoods: NeighborhoodEntry[];
  sampleNames: string[];
};

const neighborhoodEntries = await getCollection("neighborhoods");
const cityCards: HubCityCard[] = projectHubCities.map((city) => {
  const neighborhoods = neighborhoodEntries
    .filter((entry) => entry.data.city === city.slug && projectNeighborhoodBySlug.has(entry.data.slug))
    .sort((a, b) => a.data.neighborhood.localeCompare(b.data.neighborhood, "fa"));

  return {
    ...city,
    neighborhoods,
    sampleNames: neighborhoods.slice(0, 4).map((entry) => entry.data.neighborhood),
  };
});
const totalNeighborhoods = cityCards.reduce((total, city) => total + city.neighborhoods.length, 0);
const structuredData = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: title,
  description,
  url: new URL(canonicalPath, Astro.site).toString(),
  inLanguage: "fa-IR",
  isPartOf: { "@id": `${site.url}/#website` },
  mainEntity: {
    "@type": "ItemList",
    name: "PersianSaze city project hubs",
    itemListElement: cityCards.map((city, index) => ({
      "@type": "ListItem",
      position: index + 1,
      name: city.name,
      url: new URL(`/projects/${city.slug}/`, Astro.site).toString(),
      description: city.seoFocus,
    })),
  },
  hasPart: cityCards.map((city) => ({
    "@type": "CollectionPage",
    name: city.name,
    url: new URL(`/projects/${city.slug}/`, Astro.site).toString(),
    description: city.summary,
  })),
};
---

<Layout title={title} description={description} canonicalPath={canonicalPath} structuredData={structuredData}>
  <main>
    <section class="content-hero city-index-hero">
      <div class="container content-hero-grid">
        <div>
          <p class="content-eyebrow">City Hubs</p>
          <h1>شهر را انتخاب کنید، بعد محله‌های فعال همان شهر را ببینید</h1>
          <p>
            ساختار جدید پروژه‌ها به مدل هاب و اسپوک وصل شده است: اول شهر، بعد محله. این مسیر هم برای کاربر شفاف‌تر است، هم برای گوگل و موتورهای GEO قابل‌فهم‌تر.
          </p>
          <div class="action-row">
            <a class="button button-primary" href="/#demo">درخواست دمو</a>
            <a class="button button-secondary" href="/product/">مشاهده محصول</a>
          </div>
        </div>
        <aside class="content-summary-card city-index-summary">
          <strong>{cityCards.length}</strong>
          <span>هاب شهری اصلی</span>
          <p>{totalNeighborhoods} صفحه محله‌ای زیر این سه مسیر شهری سازمان‌دهی شده‌اند.</p>
        </aside>
      </div>
    </section>

    <section class="section project-index-section" aria-labelledby="project-city-hub-title">
      <div class="container">
        <div class="section-heading project-hub-heading">
          <p class="content-eyebrow">HTML Sitemap</p>
          <h2 id="project-city-hub-title">شهرهای تحت پوشش پرشین‌سازه</h2>
          <p>
            هر کارت یک مسیر مادر است و کاربر را به فهرست محله‌ها و محدوده‌های پروژه‌محور همان شهر می‌برد.
          </p>
        </div>

        <div class="project-city-grid project-hub-grid">
          {cityCards.map((city) => (
            <a class="project-city-card project-hub-card" href={`/projects/${city.slug}/`}>
              <div class="project-hub-card-top">
                <p class="content-eyebrow">{city.province}</p>
                <span>{city.neighborhoods.length} محدوده</span>
              </div>
              <h2>{city.cardName}</h2>
              <p>{city.summary}</p>
              <dl class="project-city-meta">
                <div>
                  <dt>تمرکز بازار</dt>
                  <dd class="project-city-focus"><strong>{city.seoFocus}</strong></dd>
                </div>
              </dl>
              <ul class="project-city-preview-list">
                {city.sampleNames.map((name) => (
                  <li><span>{name}</span></li>
                ))}
              </ul>
              <span class="text-link">مشاهده محله‌های {city.cardName} →</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>
</Layout>
