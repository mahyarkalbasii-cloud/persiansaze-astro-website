---
import ProjectTeaserList from "@/components/ProjectTeaserList.astro";
import RelatedAreas from "@/components/RelatedAreas.astro";
import { projectNeighborhoodRoutes, type ProjectNeighborhoodRoute } from "@/content/growthSilos";
import { projectNeighborhoodBySlug } from "@/content/neighborhoods";
import { site } from "@/content/home";
import Layout from "@/layouts/Layout.astro";
import { getCollection, render, type CollectionEntry } from "astro:content";

type NeighborhoodEntry = CollectionEntry<"neighborhoods">;

export async function getStaticPaths() {
  const entries = await getCollection("neighborhoods");
  const routeBySlug = new Map(projectNeighborhoodRoutes.map((route) => [route.neighborhood, route]));

  return entries.map((entry) => {
    const route = routeBySlug.get(entry.data.slug);
    const neighborhood = projectNeighborhoodBySlug.get(entry.data.slug);

    if (!route || !neighborhood) {
      throw new Error(`Missing route metadata for neighborhood markdown: ${entry.data.slug}`);
    }

    return {
      params: { city: route.city, neighborhood: route.neighborhood },
      props: { route, entry },
    };
  });
}

const { route, entry } = Astro.props as { route: ProjectNeighborhoodRoute; entry: NeighborhoodEntry };
const { Content } = await render(entry);
const canonicalPath = `/projects/${route.city}/${route.neighborhood}/`;
const cityPath = `/projects/${route.city}/`;
const canonicalURL = new URL(canonicalPath, Astro.site).toString();
const title = entry.data.title;
const description = entry.data.description;
const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: title,
    description,
    url: canonicalURL,
    inLanguage: "fa-IR",
    isPartOf: { "@id": `${site.url}/#website` },
    about: [
      { "@type": "Thing", name: "Construction Intelligence" },
      { "@type": "Thing", name: "B2B Sales Leads" },
      { "@type": "Place", name: route.neighborhoodName },
      { "@type": "Place", name: route.cityName },
    ],
    mainEntity: {
      "@type": "ItemList",
      name: `سیگنال‌های تقاضای ساختمانی ${route.neighborhoodName}`,
      itemListElement: route.demandSignals.map((signal, index) => ({
        "@type": "ListItem",
        position: index + 1,
        name: signal,
      })),
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "Article",
    headline: entry.data.title,
    description: entry.data.description,
    inLanguage: "fa-IR",
    url: canonicalURL,
    isPartOf: { "@id": `${site.url}/#website` },
  },
  {
    "@context": "https://schema.org",
    "@type": "Place",
    name: route.neighborhoodName,
    containedInPlace: {
      "@type": "City",
      name: route.cityName,
    },
    description: route.focus,
    url: canonicalURL,
  },
];
---

<Layout title={title} description={description} canonicalPath={canonicalPath} structuredData={structuredData}>
  <main>
    <section class="content-hero city-file-hero">
      <div class="container content-hero-grid city-file-hero-grid">
        <div class="city-file-hero-copy">
          <nav class="breadcrumb" aria-label="مسیر صفحه">
            <a href="/">پرشین‌سازه</a>
            <span aria-hidden="true">›</span>
            <a href={cityPath}>{route.cityName}</a>
            <span aria-hidden="true">›</span>
            <span>{route.neighborhoodName}</span>
          </nav>
          <p class="content-eyebrow">پروژه‌های محله‌ای</p>
          <h1>{route.headline}</h1>
          <p>{entry.data.description}</p>
          <div class="action-row">
            <a class="button button-primary" href="/#demo">درخواست دمو</a>
            <a class="button button-secondary" href={cityPath}>همه محدوده‌های {route.cityName}</a>
          </div>
        </div>
        <aside class="content-summary-card city-pin-card">
          <span class="city-pin" aria-hidden="true">
            <span>{route.neighborhoodName}</span>
          </span>
          <strong>{route.neighborhoodName}</strong>
          <span>{route.cityName}</span>
          <p>{route.focus}</p>
        </aside>
      </div>
    </section>

    <section class="section">
      <div class="container detail-layout">
        <aside class="detail-sidebar">
          <h2>سیگنال‌های این محدوده</h2>
          <dl class="compact-facts">
            <div>
              <dt>{route.cityName}</dt>
              <dd>شهر یا کریدور پروژه‌ای</dd>
            </div>
            <div>
              <dt>{route.neighborhoodName}</dt>
              <dd>محله یا محدوده هدف</dd>
            </div>
            <div>
              <dt>{route.marketCategory}</dt>
              <dd>دسته بازار</dd>
            </div>
          </dl>
          <h2>تقاضای فنی شاخص</h2>
          <ul class="link-list">
            {route.demandSignals.map((signal) => (
              <li>{signal}</li>
            ))}
          </ul>
          <a class="text-link" href="/#demo">دسترسی کامل با دمو →</a>
        </aside>

        <article class="detail-main">
          <section class="neighborhood-article-card">
            <div class="prose prose-fa neighborhood-prose">
              <Content />
            </div>
          </section>

          <ProjectTeaserList route={route} />
          <RelatedAreas current={route} routes={projectNeighborhoodRoutes} />
        </article>
      </div>
    </section>
  </main>
</Layout>
