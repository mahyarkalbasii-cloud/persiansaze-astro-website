---
import { projectNeighborhoodRoutes, type ProjectNeighborhoodRoute } from "@/content/growthSilos";
import { site } from "@/content/home";
import Layout from "@/layouts/Layout.astro";

export function getStaticPaths() {
  return projectNeighborhoodRoutes.map((route) => ({
    params: { city: route.city, neighborhood: route.neighborhood },
    props: { route },
  }));
}

const { route } = Astro.props as { route: ProjectNeighborhoodRoute };
const canonicalPath = `/projects/${route.city}/${route.neighborhood}/`;
const cityPath = `/projects/${route.city}/`;
const canonicalURL = new URL(canonicalPath, Astro.site).toString();
const title = `پروژه‌های در حال ساخت ${route.neighborhoodName} | ${route.cityName} | پرشین‌سازه`;
const description = `${route.headline}: ${route.description}`;
const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: title,
    description,
    url: canonicalURL,
    inLanguage: "fa-IR",
    isPartOf: { "@id": `${site.url}/#website` },
    about: [
      { "@type": "Thing", name: "Construction Intelligence" },
      { "@type": "Thing", name: "B2B Sales Leads" },
      { "@type": "Place", name: route.neighborhoodName },
      { "@type": "Place", name: route.cityName },
    ],
    mainEntity: {
      "@type": "ItemList",
      name: `سیگنال‌های تقاضای ساختمانی ${route.neighborhoodName}`,
      itemListElement: route.demandSignals.map((signal, index) => ({
        "@type": "ListItem",
        position: index + 1,
        name: signal,
      })),
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "Place",
    name: route.neighborhoodName,
    containedInPlace: {
      "@type": "City",
      name: route.cityName,
    },
    description: route.focus,
    url: canonicalURL,
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: [
      {
        "@type": "Question",
        name: `چه تامین‌کنندگانی باید ${route.neighborhoodName} را رصد کنند؟`,
        acceptedAnswer: {
          "@type": "Answer",
          text: `تامین‌کنندگانی که با ${route.focus} مرتبط هستند باید پروژه‌های ${route.neighborhoodName} را بر اساس مرحله ساخت و زمان خرید رصد کنند.`,
        },
      },
      {
        "@type": "Question",
        name: `پرشین‌سازه برای فروش در ${route.neighborhoodName} چه کمکی می‌کند؟`,
        acceptedAnswer: {
          "@type": "Answer",
          text: "پرشین‌سازه مرحله واقعی پروژه، موقعیت و سیگنال‌های اجرایی را به تیم فروش نشان می‌دهد تا تماس قبل از بسته شدن خرید انجام شود.",
        },
      },
    ],
  },
];
---

<Layout title={title} description={description} canonicalURL={canonicalURL} structuredData={structuredData}>
  <main>
    <section class="content-hero city-file-hero">
      <div class="container content-hero-grid city-file-hero-grid">
        <div class="city-file-hero-copy">
          <nav class="breadcrumb" aria-label="مسیر صفحه">
            <a href="/">پرشین‌سازه</a>
            <span aria-hidden="true">›</span>
            <a href={cityPath}>{route.cityName}</a>
            <span aria-hidden="true">›</span>
            <span>{route.neighborhoodName}</span>
          </nav>
          <p class="content-eyebrow">پروژه‌های محله‌ای</p>
          <h1>{route.headline}</h1>
          <p>{route.description}</p>
          <div class="action-row">
            <a class="button button-primary" href="/#demo">درخواست دمو</a>
            <a class="button button-secondary" href={cityPath}>همه محدوده‌های {route.cityName}</a>
          </div>
        </div>
        <aside class="content-summary-card city-pin-card">
          <span class="city-pin" aria-hidden="true">
            <span>{route.neighborhoodName}</span>
          </span>
          <strong>{route.neighborhoodName}</strong>
          <span>{route.cityName}</span>
          <p>{route.focus}</p>
        </aside>
      </div>
    </section>

    <section class="section">
      <div class="container detail-layout">
        <aside class="detail-sidebar">
          <h2>سیگنال‌های این محدوده</h2>
          <dl class="compact-facts">
            <div>
              <dt>{route.cityName}</dt>
              <dd>شهر یا کریدور پروژه‌ای</dd>
            </div>
            <div>
              <dt>{route.neighborhoodName}</dt>
              <dd>محله یا محدوده هدف</dd>
            </div>
            <div>
              <dt>{route.marketCategory}</dt>
              <dd>دسته بازار</dd>
            </div>
          </dl>
          <h2>تقاضای فنی شاخص</h2>
          <ul class="link-list">
            {route.demandSignals.map((signal) => (
              <li>{signal}</li>
            ))}
          </ul>
          <a class="text-link" href="/#demo">دسترسی کامل با دمو →</a>
        </aside>

        <article class="detail-main">
          <section>
            <h2>آناتومی فروش پروژه‌ای در {route.neighborhoodName}</h2>
            <p>
              {route.neighborhoodName} در خوشه {route.cityName} با تمرکز روی {route.focus} تعریف می‌شود. برای تامین‌کننده، ارزش این صفحه در تشخیص نوع پروژه، جنس تقاضای فنی و زمان مناسب ورود به مذاکره است.
            </p>
            <ul class="template-chip-list">
              {route.demandSignals.map((signal) => (
                <li>{signal}</li>
              ))}
            </ul>
          </section>

          <section class="city-narrative-panel">
            <h2>چرا زمان‌بندی فروش در {route.neighborhoodName} مهم است؟</h2>
            <p>
              در بازار پروژه‌محور، یک تامین‌کننده زمانی برنده می‌شود که قبل از نهایی شدن خرید وارد شود. پرشین‌سازه با رصد مرحله ساخت، تیم فروش را از تماس عمومی جدا می‌کند و به سمت پروژه‌هایی می‌برد که همین حالا به محصول یا خدمت مرتبط نزدیک شده‌اند.
            </p>
          </section>

          <section class="city-file-cta">
            <h2>پروژه‌های فعال {route.neighborhoodName} را مرحله‌به‌مرحله ببینید</h2>
            <p>
              اگر محصول شما به مرحله ساخت، موقعیت پروژه و تصمیم سازنده وابسته است، صفحه محله‌ای فقط landing page نیست؛ نقطه شروع اولویت‌بندی فروش در {route.cityName} است.
            </p>
            <div class="action-row">
              <a class="button button-primary" href="/#demo">درخواست دمو</a>
              <a class="button button-secondary" href={cityPath}>بازگشت به خوشه {route.cityName}</a>
            </div>
          </section>
        </article>
      </div>
    </section>
  </main>
</Layout>
