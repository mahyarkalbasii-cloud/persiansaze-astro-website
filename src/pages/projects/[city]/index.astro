---
import Layout from "@/layouts/Layout.astro";
import { site } from "@/content/home";
import { projectHubCities, projectNeighborhoodBySlug, type ProjectHubCity } from "@/content/neighborhoods";
import { getCollection, type CollectionEntry } from "astro:content";

type NeighborhoodEntry = CollectionEntry<"neighborhoods">;
type CityNeighborhood = {
  entry: NeighborhoodEntry;
  route: NonNullable<ReturnType<typeof projectNeighborhoodBySlug.get>>;
};

export function getStaticPaths() {
  return projectHubCities.map((city) => ({
    params: { city: city.slug },
    props: { city },
  }));
}

const { city } = Astro.props as { city: ProjectHubCity };
const neighborhoodEntries = await getCollection("neighborhoods");
const neighborhoods = neighborhoodEntries
  .filter((entry) => entry.data.city === city.slug)
  .map((entry): CityNeighborhood => {
    const route = projectNeighborhoodBySlug.get(entry.data.slug);

    if (!route) {
      throw new Error(`Missing route metadata for neighborhood markdown: ${entry.data.slug}`);
    }

    return { entry, route };
  })
  .sort((a, b) => a.entry.data.neighborhood.localeCompare(b.entry.data.neighborhood, "fa"));

const canonicalPath = `/projects/${city.slug}/`;
const title = `لیست پروژه‌های در حال ساخت ${city.name} | محله‌ها و محدوده‌های فعال | پرشین‌سازه`;
const description = `فهرست محله‌ها و محدوده‌های پروژه‌محور ${city.name} برای تامین‌کنندگان ساختمانی؛ مناسب رصد مرحله ساخت، اولویت‌بندی فروش و تشخیص زمان ورود به پروژه.`;
const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: title,
    description,
    url: new URL(canonicalPath, Astro.site).toString(),
    inLanguage: "fa-IR",
    isPartOf: { "@id": `${site.url}/#website` },
    about: [
      { "@type": "Place", name: city.name },
      { "@type": "Thing", name: "Active construction projects" },
      { "@type": "Thing", name: "B2B construction sales intelligence" },
    ],
    mainEntity: {
      "@type": "ItemList",
      itemListElement: neighborhoods.map(({ entry, route }, index) => ({
        "@type": "ListItem",
        position: index + 1,
        name: entry.data.neighborhood,
        url: new URL(`/projects/${city.slug}/${entry.data.slug}/`, Astro.site).toString(),
        description: route.focus,
      })),
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: [
      {
        "@type": "Question",
        name: `این صفحه چه کمکی به تامین‌کنندگان ساختمانی در ${city.name} می‌کند؟`,
        acceptedAnswer: {
          "@type": "Answer",
          text: `این صفحه محله‌ها و محدوده‌های فعال ${city.name} را به صفحه‌های پروژه‌محور وصل می‌کند تا تیم فروش بتواند فرصت‌ها را بر اساس موقعیت، تیپ ساخت‌وساز و زمان مناسب ورود اولویت‌بندی کند.`,
        },
      },
      {
        "@type": "Question",
        name: "چرا اتصال محله به شهر برای فروش پروژه‌محور مهم است؟",
        acceptedAnswer: {
          "@type": "Answer",
          text: "چون رفتار خرید، نوع مصالح، محدودیت لجستیک، سطح سازنده و زمان تصمیم‌گیری در هر شهر و محله فرق می‌کند. دسته‌بندی شهری کمک می‌کند پیام فروش دقیق‌تر و قابل تبدیل‌تر باشد.",
        },
      },
    ],
  },
];
---

<Layout title={title} description={description} canonicalPath={canonicalPath} structuredData={structuredData}>
  <main>
    <section class="content-hero city-file-hero">
      <div class="container content-hero-grid city-file-hero-grid">
        <div class="city-file-hero-copy">
          <nav class="breadcrumb" aria-label="مسیر صفحه">
            <a href="/">پرشین‌سازه</a>
            <span aria-hidden="true">›</span>
            <a href="/projects/">شهرها</a>
            <span aria-hidden="true">›</span>
            <span>{city.name}</span>
          </nav>
          <p class="content-eyebrow">{city.province}</p>
          <h1>لیست پروژه‌های در حال ساخت {city.name}</h1>
          <p>{city.summary}</p>
          <div class="action-row">
            <a class="button button-primary" href="/#demo">درخواست دمو</a>
            <a class="button button-secondary" href="/projects/">همه شهرها</a>
          </div>
        </div>
        <aside class="content-summary-card city-pin-card">
          <span class="city-pin" aria-hidden="true">
            <span>{city.cardName}</span>
          </span>
          <strong>{neighborhoods.length}</strong>
          <span>محله و محدوده پروژه‌محور</span>
          <p>{city.seoFocus}</p>
        </aside>
      </div>
    </section>

    <section class="section project-directory-section">
      <div class="container project-directory-layout">
        <aside class="project-directory-summary">
          <h2>هاب شهری {city.name}</h2>
          <p>
            این صفحه محله‌های زیرمجموعه {city.name} را از collection محتوایی پرشین‌سازه می‌خواند و هر محله را به صفحه اختصاصی خودش وصل می‌کند.
          </p>
          <dl class="compact-facts">
            <div>
              <dt>{city.name}</dt>
              <dd>شهر مادر</dd>
            </div>
            <div>
              <dt>{neighborhoods.length}</dt>
              <dd>صفحه محله‌ای قابل رصد</dd>
            </div>
          </dl>
        </aside>

        <article class="project-directory-main">
          <section class="project-directory-panel">
            <h2>محله‌ها و محدوده‌های فعال {city.name}</h2>
            <p>
              هر کارت به یک صفحه محله‌ای وصل است که برای تامین‌کنندگان، پیمانکاران و تولیدکنندگان ساختمانی نوشته شده و تیپ ساخت‌وساز، تقاضای فنی و زمان ورود فروش را روشن می‌کند.
            </p>
            <div class="project-neighborhood-grid">
              {neighborhoods.map(({ entry, route }) => (
                <article class="project-neighborhood-card">
                  <div class="project-neighborhood-card-copy">
                    <p class="content-eyebrow">{city.name}</p>
                    <h2>
                      <a href={`/projects/${city.slug}/${entry.data.slug}/`}>{entry.data.neighborhood}</a>
                    </h2>
                    <p><strong>{entry.data.focus}</strong></p>
                  </div>
                  <ul class="project-signal-list">
                    {route.demandSignals.slice(0, 4).map((signal) => (
                      <li>{signal}</li>
                    ))}
                  </ul>
                  <a class="text-link" href={`/projects/${city.slug}/${entry.data.slug}/`}>
                    مشاهده صفحه محله →
                  </a>
                </article>
              ))}
            </div>
          </section>

          <section class="project-directory-panel">
            <h2>پرسش‌های رایج درباره پروژه‌های {city.name}</h2>
            <div class="faq-list">
              <details>
                <summary>این فهرست برای چه تیم‌هایی کاربرد دارد؟</summary>
                <p>
                  برای تیم‌های فروش مصالح، آسانسور، HVAC، نما، تاسیسات، امنیت، محوطه‌سازی، تجهیزات صنعتی و پیمانکارانی که باید قبل از بسته شدن خرید وارد پروژه شوند.
                </p>
              </details>
              <details>
                <summary>پرشین‌سازه در این خوشه چه نقشی دارد؟</summary>
                <p>
                  پرشین‌سازه لایه اطلاعاتی مرحله ساخت، موقعیت و وضعیت پروژه را فراهم می‌کند تا تماس فروش بر اساس نیاز واقعی پروژه انجام شود.
                </p>
              </details>
            </div>
          </section>
        </article>
      </div>
    </section>
  </main>
</Layout>
