---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { absoluteUrl, site } from "@/content/home";
import { aboutStats, aboutValues } from "@/content/company";

const title = "درباره پرشین‌سازه | زیرساخت فروش پروژه‌محور ساختمان";
const description =
  "پرشین‌سازه برای تامین‌کنندگان صنعت ساختمان، داده زنده پروژه‌ها، ابزار فروش، آموزش و پشتیبانی را در یک زیرساخت پروژه‌محور ترکیب می‌کند.";
const companyPillars = [
  {
    title: "داده میدانی زنده",
    body: "پروژه‌ها با موقعیت، مرحله ساخت، وضعیت به‌روزرسانی، تصویر و مسیر ارتباطی قابل بررسی می‌شوند.",
  },
  {
    title: "ابزار تبدیل فرصت به اقدام",
    body: "نقشه، فیلتر، صفحه پروژه، CRM و پیامک هدفمند کمک می‌کنند فرصت فروش در همان سیستم پیگیری شود.",
  },
  {
    title: "آموزش و موفقیت مشتری",
    body: "کاربر باید بداند کدام پروژه ارزش پیگیری دارد، چه زمانی تماس بگیرد و چطور فرصت را از دست ندهد.",
  },
  {
    title: "تصمیم‌یار هوشمند",
    body: "هوش مصنوعی روی داده اختصاصی و رفتار فروش قرار می‌گیرد تا فاصله بین مشاهده پروژه و تصمیم اقدام کوتاه‌تر شود.",
  },
];
const storyPoints = [
  "بازار ساخت‌وساز آگهی‌محور نیست و فرصت‌ها اغلب قبل از دیده شدن از بین می‌روند.",
  "تامین‌کننده به منبعی نیاز دارد که مرحله، زمان فروش و مسیر تماس را کنار هم نشان دهد.",
  "پرشین‌سازه از داده خام عبور کرده و روی تبدیل پروژه به workflow فروش تمرکز می‌کند.",
];
const structuredData = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  name: title,
  description,
  url: absoluteUrl("/about-us/"),
  inLanguage: "fa-IR",
  isPartOf: { "@type": "WebSite", name: site.name, url: site.url },
};
---

<BaseLayout title={title} description={description} canonicalPath="/about-us/" structuredData={structuredData}>
  <main class="company-system-page">
    <section class="content-hero company-story-hero">
      <div class="container product-system-hero-grid">
        <div>
          <p class="content-eyebrow">درباره ما</p>
          <h1>ما پرشین‌سازه را برای فروش دقیق‌تر در بازار پروژه‌های ساختمانی می‌سازیم.</h1>
          <p>
            پرشین‌سازه فقط بانک اطلاعات تماس یا فهرست پروژه نیست. ما زیرساختی می‌سازیم که تامین‌کننده بتواند پروژه
            مناسب را در زمان درست ببیند، ارزیابی کند، ارتباط بگیرد و پیگیری را منظم ادامه دهد.
          </p>
          <div class="action-row">
            <a class="button button-primary" href="/#demo">درخواست دمو</a>
            <a class="button button-secondary" href="/product/">مشاهده محصول</a>
          </div>
        </div>
        <aside class="company-story-card">
          <span>تمرکز ما</span>
          <strong>داده زنده پروژه به اقدام فروش</strong>
          <p>مخاطب اصلی پرشین‌سازه تامین‌کنندگان، تولیدکنندگان و فروشندگان B2B صنعت ساختمان هستند.</p>
        </aside>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="metric-strip">
          {aboutStats.map((item) => (
            <article>
              <strong>{item.value}</strong>
              <span>{item.label}</span>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container product-two-column">
        <div class="section-copy">
          <p class="content-eyebrow">مسئله‌ای که حل می‌کنیم</p>
          <h2>فروش ساختمانی زمانی می‌برد که پروژه، مرحله و مسیر ارتباطی درست کنار هم دیده شوند.</h2>
          <p>
            تیم فروش نمی‌تواند فقط با چند شماره تماس پراکنده، بازار پروژه‌های در حال ساخت را مدیریت کند. ارزش واقعی وقتی
            ساخته می‌شود که داده پروژه زنده باشد، مرحله ساخت مشخص باشد و پیگیری از حالت فردی و شانسی خارج شود.
          </p>
        </div>
        <ul class="business-friction-list">
          {storyPoints.map((item) => <li>{item}</li>)}
        </ul>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="section-heading">
          <h2>پرشین‌سازه را روی چهار ستون می‌سازیم</h2>
          <p>این ستون‌ها مسیر محصول، عملیات داده، آموزش و پشتیبانی ما را کنترل می‌کنند.</p>
        </div>
        <div class="execution-tool-grid company-pillar-grid">
          {companyPillars.map((item) => (
            <article class="execution-tool-card company-pillar-card">
              <h3>{item.title}</h3>
              <p>{item.body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container product-workflow-panel company-story-panel">
        <div class="section-heading">
          <h2>ما داده را تا رفتار فروش دنبال می‌کنیم</h2>
          <p>
            معیار ما فقط تعداد پروژه نیست؛ مهم این است که کاربر بتواند از پروژه، تصمیم عملیاتی بگیرد و نتیجه را در مسیر
            فروش ثبت کند.
          </p>
        </div>
        <ol class="product-workflow-list">
          <li>
            <span>01</span>
            <p>پروژه در میدان شناسایی، کنترل و به‌روزرسانی می‌شود.</p>
          </li>
          <li>
            <span>02</span>
            <p>مرحله ساخت و تناسب آن با محصول تامین‌کننده قابل فهم می‌شود.</p>
          </li>
          <li>
            <span>03</span>
            <p>تیم فروش از مسیر درست تماس، پیامک، یادداشت و پیگیری اقدام می‌کند.</p>
          </li>
        </ol>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="section-heading">
          <h2>ارزش‌هایی که مسیرمان را کنترل می‌کنند</h2>
          <p>این ارزش‌ها مستقیم روی کیفیت داده، پشتیبانی، آموزش و رفتار تیم با مشتری اثر می‌گذارند.</p>
        </div>
        <div class="value-grid">
          {aboutValues.map((item) => (
            <article class="value-card">
              <h3>{item.title}</h3>
              <p>{item.body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
