---
import BaseLayout from "@/layouts/BaseLayout.astro";
import BreadcrumbSchema from "@/components/BreadcrumbSchema.astro";
import CompanyAboutSections from "@/components/CompanyAboutSections.astro";
import { absoluteUrl, site, socialLinks } from "@/content/home";

const title = "تماس با ما | شرکت ارتباطات ماندگار پرشین | پرشین‌سازه";
const description =
  "راه‌های ارتباط با پرشین‌سازه، شماره‌های تماس، آدرس شرکت، ایمیل، ساعت پاسخگویی و معرفی تیم و مسیر شکل‌گیری پرشین‌سازه.";

const heroImage = {
  src: "/assets/company/contact/contact-hero.webp",
  alt: "تیم پرشین سازه در فضای کاری شرکت",
};

const mapUrl =
  "https://www.google.com/maps/place/%D9%BE%D8%B1%D8%B4%DB%8C%D9%86+%D8%B3%D8%A7%D8%B2%D9%87%E2%80%AD/@35.7791964,51.3759454,18.94z/data=!4m6!3m5!1s0x3f8e07a2fa35dbff:0xa2adc10f4130c19e!8m2!3d35.7790528!4d51.3756886!16s%2Fg%2F11tmkkmrxh";

const phoneLinks = [
  site.contacts[2],
  site.contacts[0],
  site.contacts[1],
];

const primarySocialLinks = socialLinks.filter((link) =>
  ["اینستاگرام", "لینکدین", "یوتیوب"].includes(link.label),
);

const socialIconKeyFor = (href: string, label: string) => {
  const source = `${href} ${label}`.toLowerCase();
  if (source.includes("instagram")) return "instagram";
  if (source.includes("linkedin")) return "linkedin";
  return "youtube";
};

const structuredData = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  name: title,
  description,
  url: absoluteUrl("/contact-us/"),
  inLanguage: "fa-IR",
  isPartOf: { "@type": "WebSite", name: site.name, url: site.url },
  mainEntity: {
    "@type": "Organization",
    name: site.legalName,
    url: site.url,
    email: site.email,
    address: {
      "@type": "PostalAddress",
      ...site.postalAddress,
    },
    openingHoursSpecification: site.openingHoursSpecification,
    contactPoint: site.contacts.map((contact) => ({
      "@type": "ContactPoint",
      telephone: contact.telephone,
      contactType: contact.contactType,
      areaServed: "IR",
      availableLanguage: ["fa"],
    })),
    sameAs: site.sameAs,
  },
};
---

<BaseLayout
  title={title}
  description={description}
  canonicalPath="/contact-us/"
  ogImage="/assets/company/contact/contact-hero.webp"
  structuredData={structuredData}
>
  <BreadcrumbSchema items={[{ name: "تماس با ما", path: "/contact-us/" }]} />
  <main class="contact-system-page contact-source-page about-source-page">
    <section class="content-hero contact-operations-hero contact-hero">
      <div class="container contact-hero-grid">
        <div class="contact-hero-copy">
          <p class="content-eyebrow">تماس با ما</p>
          <h1>راه‌های ارتباط با پرشین سازه</h1>
          <p>
            ما در روزهای کاری پاسخگوی شما هستیم. با ما تماس بگیرید و در شبکه‌های اجتماعی همراه‌مان شوید.
          </p>
          <div class="action-row">
            <a class="button button-primary" href={site.contacts[1].href}>تماس با شرکت</a>
            <a class="button button-secondary" href={mapUrl} target="_blank" rel="noreferrer">مشاهده روی نقشه</a>
          </div>
        </div>

        <figure class="image-panel contact-hero-image">
          <img src={heroImage.src} alt={heroImage.alt} width="800" height="400" loading="eager" decoding="async" />
        </figure>
      </div>
    </section>

    <section class="section contact-details-section">
      <div class="container">
        <div class="section-heading">
          <p class="content-eyebrow">مسیرهای تماس</p>
          <h2>شماره‌ها و اطلاعات اصلی</h2>
        </div>

        <div class="contact-method-grid">
          <article class="contact-method-card contact-phone-card">
            <span>شماره تماس</span>
            <div class="contact-phone-list">
              {phoneLinks.map((contact, index) => (
                <>
                  <a href={contact.href}>{contact.phone}</a>
                  {index < phoneLinks.length - 1 && <span class="contact-phone-separator" aria-hidden="true">|</span>}
                </>
              ))}
            </div>
          </article>

          <article class="contact-method-card contact-email-card">
            <span>ایمیل</span>
            <a href={`mailto:${site.email}`} dir="ltr">{site.email}</a>
          </article>

          <article class="contact-method-card contact-social-card">
            <span>شبکه‌های اجتماعی</span>
            <div class="contact-social-row" aria-label="شبکه‌های اجتماعی پرشین سازه">
              {primarySocialLinks.map((link) => (
                <a
                  class={`contact-social-link contact-social-link-${socialIconKeyFor(link.href, link.label)}`}
                  href={link.href}
                  target="_blank"
                  rel="noreferrer"
                  aria-label={link.label}
                  title={link.label}
                >
                  <span class={`contact-social-icon contact-social-icon-${socialIconKeyFor(link.href, link.label)}`} aria-hidden="true"></span>
                </a>
              ))}
            </div>
          </article>

          <article class="contact-method-card contact-address-card">
            <span>آدرس شرکت</span>
            <p>{site.address}</p>
            <a class="contact-map-link" href={mapUrl} target="_blank" rel="noreferrer">مشاهده روی نقشه</a>
          </article>

          <article class="contact-method-card contact-hours-card">
            <span>ساعت پاسخگویی</span>
            <p>{site.openingHoursText}</p>
          </article>
        </div>
      </div>
    </section>

    <CompanyAboutSections />
  </main>
</BaseLayout>
